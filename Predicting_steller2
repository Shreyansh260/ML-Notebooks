\n)\n\ncat_accs = []\nfor fold, (tr_idx, val_idx) in enumerate(skf.split(X_cat, y)):\n    X_tr, X_val = X_cat.iloc[tr_idx], X_cat.iloc[val_idx]\n    y_tr, y_val = y[tr_idx], y[val_idx]\n\n    tr_pool  = Pool(X_tr,  y_tr,  cat_features=CAT_FEATURES_CB)\n    val_pool = Pool(X_val, y_val, cat_features=CAT_FEATURES_CB)\n\n    m = CatBoostClassifier(**cat_params)\n    m.fit(tr_pool, eval_set=val_pool, use_best_model=True)\n\n    oof_cat[val_idx] = m.predict_proba(X_val)\n    test_cat        += m.predict_proba(Pool(X_test_cat, cat_features=CAT_FEATURES_CB))\n\n    acc = accuracy_score(y_val, oof_cat[val_idx].argmax(1))\n    cat_accs.append(acc)\n    print(f\"  [CatBoost] Fold {fold+1}/{N_FOLDS}: {acc:.5f}\")\n\ntest_cat /= N_FOLDS\nprint(f\"CatBoost OOF: {accuracy_score(y, oof_cat.argmax(1)):.5f} | Mean: {np.mean(cat_accs):.5f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-16T05:57:37.979914Z","iopub.execute_input":"2026-06-16T05:57:37.980569Z","iopub.status.idle":"2026-06-16T06:01:50.530394Z","shell.execute_reply.started":"2026-06-16T05:57:37.980523Z","shell.execute_reply":"2026-06-16T06:01:50.529474Z"}},"outputs":[{"name":"stdout","text":"  [CatBoost] Fold 1/10: 0.95140\n  [CatBoost] Fold 2/10: 0.95171\n  [CatBoost] Fold 3/10: 0.95675\n  [CatBoost] Fold 4/10: 0.94385\n  [CatBoost] Fold 5/10: 0.94830\n  [CatBoost] Fold 6/10: 0.93995\n  [CatBoost] Fold 7/10: 0.95485\n  [CatBoost] Fold 8/10: 0.95426\n  [CatBoost] Fold 9/10: 0.95611\n  [CatBoost] Fold 10/10: 0.95342\nCatBoost OOF: 0.95106 | Mean: 0.95106\n","output_type":"stream"}],"execution_count":16},{"id":"535f9ecb-2d64-4e05-843d-c67fd6fa5ffd","cell_type":"code","source":"# ── LightGBM ─────────────────────────────────────────────────────────────────\nfrom lightgbm import early_stopping, log_evaluation\n\nlgbm_params = dict(\n    objective         = 'multiclass',\n    num_class         = N_CLASSES,\n    n_estimators      = 15000,\n    learning_rate     = 0.008,\n    num_leaves        = 255,\n 