, build_model_fn):\n    \"\"\"build_model_fn(X_tr, y_tr, X_val, y_val) -> fitted model with .predict_proba\"\"\"\n    oof = np.zeros((len(X), N_CLASSES))\n    test_p = np.zeros((len(X_test), N_CLASSES))\n    t0 = time.time()\n    for fold, (tr_idx, val_idx) in enumerate(fold_idx):\n        X_tr, X_val = X.iloc[tr_idx], X.iloc[val_idx]\n        y_tr, y_val = y_full[tr_idx], y_full[val_idx]\n        model = build_model_fn(X_tr, y_tr, X_val, y_val)\n        val_p = model.predict_proba(X_val)\n        te_p  = model.predict_proba(X_test)\n        oof[val_idx] = val_p\n        test_p += te_p / N_FOLDS\n        acc = accuracy_score(y_val, val_p.argmax(1))\n        print(f'  [{name}] fold {fold+1}/{N_FOLDS}  acc={acc:.5f}')\n    elapsed = time.time() - t0\n    overall_acc = accuracy_score(y_full, oof.argmax(1))\n    print(f'[{name}] OOF acc = {overall_acc:.5f}   ({elapsed:.1f}s total)\\n')\n    oof_preds[name] = oof\n    test_preds[name] = test_p\n    fold_scores[name] = overall_acc\n    return oof, test_p\n\n\ndef build_xgb(X_tr, y_tr, X_val, y_val):\n    model = xgb.XGBClassifier(**xgb_params, early_stopping_rounds=100)\n    model.fit(X_tr, y_tr, eval_set=[(X_val, y_val)], verbose=False)\n    return model\n\nrun_oof_v2('xgb', build_xgb)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T07:56:34.241723Z","iopub.execute_input":"2026-06-29T07:56:34.242074Z","iopub.status.idle":"2026-06-29T07:58:55.252657Z","shell.execute_reply.started":"2026-06-29T07:56:34.242051Z","shell.execute_reply":"2026-06-29T07:58:55.252056Z"}},"outputs":[{"name":"stdout","text":"  [xgb] fold 1/5  acc=0.96768\n  [xgb] fold 2/5  acc=0.96827\n  [xgb] fold 3/5  acc=0.96708\n  [xgb] fold 4/5  acc=0.96782\n  [xgb] fold 5/5  acc=0.96765\n[xgb] OOF acc = 0.96770   (140.9s total)\n\n","output_type":"stream"},{"execution_count":7,"output_type":"execute_result","data":{"text/plain":"(array([[9.99898434e-01, 9.69800385e-05, 4.58320392e-06],\n        [9.91515875e-01, 1.82144126e-04, 8.30197