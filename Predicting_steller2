isna().any():\n            return None\n    if not set(df[TARGET].unique()).issubset(set(LABELS)):\n        return None\n    return df\n\n\ndef load_probability_consensus(data_dir: Path, ids: np.ndarray) -> tuple[np.ndarray, np.ndarray, np.ndarray, list[str]]:\n    arrays: list[np.ndarray] = []\n    weights: list[float] = []\n    names: list[str] = []\n\n    for path in sorted(data_dir.glob('test_preds__*.csv')):\n        df = pd.read_csv(path)\n        if ID not in df.columns or not set(LABELS).issubset(df.columns):\n            continue\n        if not np.array_equal(df[ID].to_numpy(), ids):\n            continue\n        score = score_from_name(Path(path.name.replace('test_preds__', ''))) or 0.969\n        arr = df[LABELS].to_numpy(np.float64)\n        arr /= arr.sum(axis=1, keepdims=True)\n        arrays.append(arr)\n        weights.append(max(0.25, (score - 0.968) * 1000.0))\n        names.append(path.name)\n\n    for filename, weight in [('cat-3_test_preds__0.96972.npy', 1.7), ('pred_lr_stacker_v9.npy', 3.5)]:\n        path = data_dir / filename\n        if path.exists():\n            arr = np.load(path).astype(np.float64)\n            arr /= arr.sum(axis=1, keepdims=True)\n            arrays.append(arr)\n            weights.append(weight)\n            names.append(filename)\n\n    artifact = data_dir / 'sub_eda03_gbdt_artifact_blend.csv'\n    if artifact.exists():\n        df = pd.read_csv(artifact, usecols=[ID, 'proba_GALAXY', 'proba_QSO', 'proba_STAR'])\n        if np.array_equal(df[ID].to_numpy(), ids):\n            arr = df[['proba_GALAXY', 'proba_QSO', 'proba_STAR']].to_numpy(np.float64)\n            arr /= arr.sum(axis=1, keepdims=True)\n            arrays.append(arr)\n            weights.append(4.0)\n            names.append(artifact.name)\n\n    if not arrays:\n        raise RuntimeError('No probability files found.')\n\n    proba = np.average(np.stack(arrays), axis=0, weights=np.array(weights))\n    proba /= proba.sum(axis=1, keepdims=True)\n    pred = LABELS[proba.argmax(axis=1)]\n    sorted_p = np.sort(proba, axis=1)\n    margin = sorted_p[:, -1] - sorted_p[:, -2]\n    return proba, pred, margin, names","metadata":{"execution":{"iopub.status.busy":"2026-06-17T16:49:58.287856Z","iopub.execute_input":"2026-06-17T16:49:58.288239Z","iopub.status.idle":"2026-06-17T16:49:58.302394Z","shell.execute_reply.started":"2026-06-17T16:49:58.288215Z","shell.execute_reply":"2026-06-17T16:49:58.301493Z"},"papermill":{"duration":0.020602,"end_time":"2026-06-17T07:05:07.493838+00:00","exception":false,"start_time":"2026-06-17T07:05:07.473236+00:00","status":"completed"},"tags":[],"trusted":true},"outputs":[],"execution_count":2},{"id":"ab9bd0eb","cell_type":"markdown","source":"## Load Start Anchor and Probability Files","metadata":{"papermill":{"duration":0.001979,"end_time":"2026-06-17T07:05:07.497937+00:00","exception":false,"start_time":"2026-06-17T07:05:07.495958+00:00","status":"completed"},"tags":[]}},{"id":"c2a19b82","cell_type":"code","source":"anchor_df = read_submission(DATA_DIR / START_ANCHOR_FILE)\nif anchor_df is None:\n    raise FileNotFoundError(DATA_DIR / START_ANCHOR_FILE)\n\nids = anchor_df[ID].to_numpy()\nproba, proba_pred, proba_margin, proba_names = load_probability_consensus(DATA_DIR, ids)\nprint('start anchor:', START_ANCHOR_FILE, START_ANCHOR_SCORE)\nprint('probability sources:', len(proba_names))\nprint(proba_names)","metadata":{"execution":{"iopub.status.busy":"2026-06-17T16:49:58.303559Z","iopub.execute_input":"2026-06-17T16:49:58.303977Z","iopub.status.idle":"2026-06-17T16:50:00.204855Z","shell.execute_reply.started":"2026-06-17T16:49:58.303954Z","shell.execute_reply":"2026-06-17T16:50:00.203747Z"},"papermill":{"duration":2.255367,"end_time":"2026-06-17T07:05:09.756461+00:00","exception":false,"start_time":"2026-06-17T07:05:07.501094+00:00","status":"completed"},"tags":[],"trusted":true},"outputs":[{"name":"stdout","text":"start anchor: 0.97220.csv 0.9722\nprobability sources: 8\n['test_preds__0.968