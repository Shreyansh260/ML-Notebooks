.mean(1)) / (std_safe**4) - 3.0\n\n    # ── 3. Spectral slope (vectorized regression) ─────────────────────────────\n    wave_log = np.array(np.log10([354, 477, 623, 762, 913]), dtype=np.float32)\n    wave_log -= wave_log.mean()\n    wave_sq   = (wave_log**2).sum()\n    mag_dev   = mag - mag.mean(1, keepdims=True)\n    out['spectral_slope']    = (mag_dev * wave_log).sum(1) / wave_sq\n    out['spectral_slope_sq'] = out['spectral_slope']**2\n    wave_q = wave_log**2 - (wave_log**2).mean()\n    out['spectral_curve'] = (mag_dev * wave_q).sum(1)\n\n    # ── 4. BPT / QSO proxy ────────────────────────────────────────────────────\n    ug = out['u_g']; gr = out['g_r']\n    out['u_r']            = out['u_g'] + out['g_r']\n    out['g_i']            = out['g_r'] + out['r_i']\n    out['u_r_sq']         = out['u_r']**2\n    out['qso_color_score']= -(ug + gr)\n\n    # ── 5. Stellar locus offsets ──────────────────────────────────────────────\n    out['stellar_locus_offset']    = out['g_r'] - (0.45 * ug - 0.12)\n    out['stellar_locus_offset_sq'] = out['stellar_locus_offset']**2\n    out['stellar_locus_ri_iz']     = out['r_i'] - (0.90 * out['i_z'] + 0.05)\n\n    # ── 6. Redshift features (all vectorized) ─────────────────────────────────\n    z = df['redshift'].values.astype(np.float32).clip(0)\n    out['log1p_z']      = np.log1p(z)\n    out['log1p_z_sq']   = out['log1p_z']**2\n    out['log1p_z_cb']   = out['log1p_z']**3\n    out['z_sq']         = z**2\n    out['z_sqrt']       = np.sqrt(z)\n    out['z_recip']      = 1.0 / (z + 1e-5)\n    out['z_log_recip']  = np.log1p(1.0 / (z + 1e-5))\n    out['lum_dist_proxy']  = z * (1 + z / 2)\n    out['ang_diam_proxy']  = z / ((1 + z)**2)\n    out['k_corr_g']        = -2.5 * np.log10(1 + z)\n\n    # ── 7. Absolute magnitude proxies ─────────────────────────────────────────\n    dist_mod = 5 * np.log10(np.clip(out['lum_dist_proxy'], 1e-4, None) * 4280e6 / 10)\n    for bi, band in enumerate(bands):\n        out[f'abs_{band}'] = mag[:, bi] - dist_mod\n\n    # ── 8. Flux ratios (Pogson) ───────────────────────────────────────────────\n    for a, b in [('u','g'),('g','r'),('r','i'),('i','z'),('g','z'),('u','z')]:\n        out[f'flux_{a}_{b}'] = 10**(-0.4 * out[f'{a}_{b}'])\n\n    # ── 9. Morphology proxies ─────────────────────────────────────────────────\n    out['conc_proxy']   = out['r_i']\n    out['morpho_proxy'] = out['u_g'] / (out['r_i'] + 0.1)\n\n    # ── 10. Baldwin effect proxy ──────────────────────────────────────────────\n    out['baldwin_proxy'] = out['abs_r'] * out['log1p_z']\n\n    # ── 11. Spectral type numerics ────────────────────────────────────────────\n    spec_map = {'O/B': 0, 'A/F': 1, 'G/K': 2, 'M': 3}\n    out['spec_num']     = df['spectral_type'].map(spec_map).fillna(-1).values.astype(np.float32)\n    out['is_hot_star']  = df['spectral_type'].isin(['O/B','A/F']).values.astype(np.float32)\n    out['is_cool_star'] = (df['spectral_type'] == 'M').values.astype(np.float32)\n\n    # ── 12. Galaxy population ─────────────────────────────────────────────────\n    gal_map = {'Red_Sequence': 0, 'Green_Valley': 1, 'Blue_Cloud': 2}\n    out['is_red_seq']    = (df['galaxy_population'] == 'Red_Sequence').values.astype(np.float32)\n    out['is_blue_cloud'] = (df['galaxy_population'] == 'Blue_Cloud').values.astype(np.float32)\n    out['is_green_val']  = (df['galaxy_population'] == 'Green_Valley').values.astype(np.float32)\n    out['galpop_num']    = df['galaxy_population'].map(gal_map).fillna(-1).values.astype(np.float32)\n\n    # ── 13. Cross-feature interactions (vectorized) ───────────────────────────\n    lz = out['log1p_z']\n    out['z_x_ug']    = lz * out['u_g']\n    out['z_x_gr']    = lz * out['g_r']\n    out['z_x_ri']    = lz * out['r_i']\n    out['z_x_iz']    = lz * out['i_z']\n    out['z_x_slope'] = lz * out['spectral_slope']\n    out['spec_x_ug'] = out['spec_num'] * out['u_g']\n    out['spec_x_gr'] = out['spec_num'] * out['g_r']\n    out['spec_x_z']  = out['spec_num'] * lz\n    out['gal_