c:.5f}')\n\ntest_blend = sum(w * test_preds[n] for w, n in zip(best_w, model_names))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T08:13:42.788552Z","iopub.execute_input":"2026-06-29T08:13:42.788876Z","iopub.status.idle":"2026-06-29T08:13:49.098421Z","shell.execute_reply.started":"2026-06-29T08:13:42.788853Z","shell.execute_reply":"2026-06-29T08:13:49.097505Z"}},"outputs":[{"name":"stdout","text":"Individual OOF accuracies:\n  xgb   : 0.96770\n  lgbm  : 0.96793\n  cat   : 0.96559\n\nOptimized blend weights:\n  xgb   : 0.4190\n  lgbm  : 0.5807\n  cat   : 0.0002\n\nBlended OOF accuracy: 0.96822\n","output_type":"stream"}],"execution_count":10},{"id":"md-pseudo","cell_type":"markdown","source":"## Pseudo-labeling pass\n\nAdd high-confidence test predictions (margin between top-1 and top-2 class probability above a threshold) back into the training set, then refit XGBoost (fastest of the three) once more for a final confidence boost. This only uses the model's own calibrated confidence — no external file scores involved.","metadata":{}},{"id":"cell-10-pseudo","cell_type":"code","source":"sorted_probs = np.sort(test_blend, axis=1)\nmargin = sorted_probs[:, -1] - sorted_probs[:, -2]\nCONF_THRESH = 0.90\n\nconfident_mask = margin > CONF_THRESH\nn_confident = confident_mask.sum()\nprint(f'High-confidence pseudo-label candidates (margin > {CONF_THRESH}): {n_confident} / {len(test_blend)}')\n\nif n_confident > 0:\n    pseudo_X = X_test.loc[confident_mask]\n    pseudo_y = test_blend[confident_mask].argmax(1)\n\n    X_aug = pd.concat([X, pseudo_X], axis=0).reset_index(drop=True)\n    y_aug = np.concatenate([y_full, pseudo_y])\n\n    print('Refitting final XGBoost on augmented data (train + pseudo-labeled test)...')\n    final_folds = StratifiedKFold(n_splits=N_FOLDS, shuffle=True, random_state=SEED + 1)\n    final_test_p = np.zeros((len(X_test), N_CLASSES))\n    for fold, (tr_idx, val_idx) in enumerate(final_folds.split(X_aug, y_aug)):\n        X_tr, X_val = X_aug.iloc[tr_idx], X_aug.iloc[val_idx]\n        y_tr, y_val = y_aug[tr_idx], y_aug[val_idx]\n        model = xgb.XGBClassifier(**xgb_params, early_stopping_rounds=100)\n        model.fit(X_tr, y_tr, eval_set=[(X_val, y_val)], verbose=False)\n        final_test_p += model.predict_proba(X_test) / N_FOLDS\n        acc = accuracy_score(y_val, model.predict_proba(X_val).argmax(1))\n        print(f'  pseudo-fold {fold+1}/{N_FOLDS}  acc={acc:.5f}')\n\n    # Average the pseudo-labeled refit with the original blend for stability\n    final_probs = 0.5 * final_test_p + 0.5 * test_blend\nelse:\n    print('No candidates above threshold — using blend predictions as final.')\n    final_probs = test_blend","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T08:13:49.099552Z","iopub.execute_input":"2026-06-29T08:13:49.099866Z","iopub.status.idle":"2026-06-29T08:16:36.359455Z","shell.execute_reply.started":"2026-06-29T08:13:49.099844Z","shell.execute_reply":"2026-06-29T08:16:36.35874Z"}},"outputs":[{"name":"stdout","text":"High-confidence pseudo-label candidates (margin > 0.9): 214947 / 247435\nRefitting final XGBoost on augmented data (train + pseudo-labeled test)...\n  pseudo-fold 1/5  acc=0.97608\n  pseudo-fold 2/5  acc=0.97629\n  pseudo-fold 3/5  acc=0.97663\n  pseudo-fold 4/5  acc=0.97643\n  pseudo-fold 5/5  acc=0.97697\n","output_type":"stream"}],"execution_count":11},{"id":"cell-11-submit","cell_type":"code","source":"final_pred_idx = final_probs.argmax(1)\nfinal_labels = le.inverse_transform(final_pred_idx)\n\nsubmission = pd.DataFrame({ID: test[ID], TARGET: final_labels})\nsubmission.to_csv('submission.csv', index=False)\n\nprint('submission.csv saved.')\nprint(submission[TARGET].value_counts())\nsubmission.head()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T08:16:36.360469Z","iopub.execute_input":"2026-06-29T08:16:36.360782Z","iopub.status.idle":"2026-06-29T08:16:36.59202Z","shell.execute_reply.started":"2026-06-29T0