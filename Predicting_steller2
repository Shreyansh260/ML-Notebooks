{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"gpu","dataSources":[{"sourceType":"competition","sourceId":125222},{"sourceType":"datasetVersion","sourceId":16898063}],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"notebook","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"#!/usr/bin/env python3\n\"\"\"\n=============================================================================\nGrandmaster Pipeline — Kaggle Playground Series S6E6: Stellar Classification\n=============================================================================\nTarget: Public LB > 0.986  (balanced accuracy)\n\nPipeline:\n  1. Advanced Feature Engineering\n  2. Multi-Model OOF Training (LightGBM, XGBoost, CatBoost, ExtraTrees)\n  3. Meta-Learner Stacking (LogisticRegression balanced)\n  4. Balanced-Accuracy Threshold Optimization\n  5. Existing Prediction Integration\n  6. Optional Ridge-Flip Post-Processing\n  7. Final Submission\n\nUpload this script to Kaggle as a notebook, or paste cells into a .ipynb.\nRequires: lightgbm, xgboost, catboost, sklearn, scipy, pandas, numpy\n\"\"\"\n\nfrom __future__ import annotations\n\nimport gc\nimport time\nimport json\nimport os\nimport re\nimport warnings\nfrom pathlib import Path\n\nimport numpy as np\nimport pandas as pd\nfrom scipy import sparse\nfrom scipy.optimize import minimize\nfrom sklearn.linear_model import Ridge, LogisticRegression\nfrom sklearn.model_selection import StratifiedKFold\nfrom sklearn.metrics import balanced_accuracy_score\nfrom sklearn.ensemble import ExtraTreesClassifier\n\nwarnings.filterwarnings(\"ignore\")\n\n# ============================================================================\n# CONFIG\n# ============================================================================\nID = \"id\"\nTARGET = \"class\"\nLABELS = np.array([\"GALAXY\", \"QSO\", \"STAR\"], dtype=object)\nL2I = {label: i for i, label in enumerate(LABELS)}\n\n# Kaggle paths — matched to notebook sidebar inputs\nCOMP_DIR = Path(\"/kaggle/input/competitions/playground-series-s6e6\")\nPRED_DIR = Path(\"/kaggle/input/datasets/fachri00/s6e6-submission/new\")\nWORK_DIR = Path(\"/kaggle/working/\")\nWORK_DIR.mkdir(parents=True, exist_ok=True)\n\nN_FOLDS = 5\nN_SEEDS_GBDT = 2       # seeds per GBDT model (reduced for speed)\nUSE_ORIGINAL_DATA = False  # no original SDSS dataset attached\nUSE_EXISTING_PREDS = True  # integrate your 8 pre-computed prediction files\nUSE_RIDGE_FLIP_POST = True  # final Ridge-flip post-processing\n\n# Ridge-flip settings (from original notebook)\nSTART_ANCHOR_FILE = \"0.97220.csv\"\nSTART_ANCHOR_SCORE = 0.97220\nROUND_K = 4\nROUND_FEEDBACK_SCORES = [0.97223, 0.97224, 0.97226]\n\nNEGATIVE_FEEDBACK_NAMES = {\n    \"recent_corr_rank_k3\",\n    \"recent_wc_k35\",\n    \"recent_sparse_delta_k5\",\n    \"recent_patch_lr_k30\",\n    \"new_stack_submission\",\n}\n\nprint(\"=\" * 70)\nprint(\"GRANDMASTER PIPELINE — PS S6E6 Stellar Classification\")\nprint(\"=\" * 70)\n\n# ============================================================================\n# PHASE 1: LOAD DATA & FEATURE ENGINEERING\n# ============================================================================\nprint(\"\\n[PHASE 1] Loading data & feature engineering...\")\n\ntrain = pd.read_csv(COMP_DIR / \"train.csv\")\ntest = pd.read_csv(COMP_DIR / \"test.csv\")\n\nprint(f\"  Train shape: {train.shape}\")\nprint(f\"  Test shape:  {test.shape}\")\nprint(f\"  Classes:     {train[TARGET].value_counts().to_dict()}\")\n\n# Encode target\ny_train = train[TARGET].map(L2I).values.astype(np.int32)\ntest_ids = test[ID].values\n\n# ---- Original SDSS data not attached; skipping ----\nprint(\"  Skipping original data (not attached in this notebook)\")\n\n# ---- Feature Engineering ----\nRAW_FEATURES = [c for c in test.columns if c != ID]\n\ndef engineer_features(df: pd.DataFrame) -> pd.DataFrame:\n    \"\"\"Build grandmaster-level features from raw SDSS columns.\"\"\"\n    out = df.copy()\n\n    # --- Identify available feature columns ---\n    has_alpha = \"alpha\" in out.columns\n    has_delta = \"delta\" in out.columns\n    has_redshift = \"redshift\" in out.columns\n    bands = [b for b in [\"u\", \"g\", \"r\", \"i\", \"z\"] if b in out.columns]\n\n    # ----- 1. Cyclical coordinate encoding -----\n    if has_alpha:\n        alpha_rad = np.deg2rad(out[\"alpha\"])\n        out[\"alpha_sin\"] = np.sin(alpha_rad)\n        out[\"alpha_cos\"] = np.cos(alpha_rad)\n        out[\"alpha_sin2\"] = np.sin(2 * alpha_rad)\n        out[\"alpha_cos2\"] = np.cos(2 * alpha_rad)\n\n    if has_delta:\n        delta_rad = np.deg2rad(out[\"delta\"])\n        out[\"delta_sin\"] = np.sin(delta_rad)\n        out[\"delta_cos\"] = np.cos(delta_rad)\n        out[\"delta_sin2\"] = np.sin(2 * delta_rad)\n        out[\"delta_cos2\"] = np.cos(2 * delta_rad)\n\n    # Cross-coordinate interactions\n    if has_alpha and has_delta:\n        out[\"alpha_x_delta\"] = out[\"alpha\"] * out[\"delta\"]\n        out[\"alpha_sin_x_delta_sin\"] = out[\"alpha_sin\"] * out[\"delta_sin\"]\n        out[\"alpha_cos_x_delta_cos\"] = out[\"alpha_cos\"] * out[\"delta_cos\"]\n\n    # ----- 2. Color indices (differences between photometric bands) -----\n    if len(bands) >= 2:\n        for i in range(len(bands)):\n            for j in range(i + 1, len(bands)):\n                b1, b2 = bands[i], bands[j]\n                out[f\"{b1}_minus_{b2}\"] = out[b1] - out[b2]\n\n    # ----- 3. Color ratios -----\n    if len(bands) >= 2:\n        for i in range(len(bands) - 1):\n            b1, b2 = bands[i], bands[i + 1]\n            out[f\"{b1}_div_{b2}\"] = out[b1] / (out[b2] + 1e-8)\n\n    # ----- 4. Magnitude statistics across bands -----\n    if len(bands) >= 3:\n        band_vals = out[bands].values\n        out[\"mag_mean\"] = band_vals.mean(axis=1)\n        out[\"mag_std\"] = band_vals.std(axis=1)\n        out[\"mag_max\"] = band_vals.max(axis=1)\n        out[\"mag_min\"] = band_vals.min(axis=1)\n        out[\"mag_range\"] = out[\"mag_max\"] - out[\"mag_min\"]\n        out[\"mag_median\"] = np.median(band_vals, axis=1)\n        out[\"mag_skew\"] = (\n            3.0 * (out[\"mag_mean\"] - out[\"mag_median\"]) / (out[\"mag_std\"] + 1e-8)\n        )\n\n    # ----- 5. Redshift features -----\n    if has_redshift:\n        out[\"redshift_log1p\"] = np.log1p(np.abs(out[\"redshift\"])) * np.sign(\n            out[\"redshift\"]\n        )\n        out[\"redshift_sq\"] = out[\"redshift\"] ** 2\n        out[\"redshift_sqrt\"] = np.sqrt(np.abs(out[\"redshift\"])) * np.sign(\n            out[\"redshift\"]\n        )\n        out[\"redshift_abs\"] = np.abs(out[\"redshift\"])\n\n        # Redshift × color index interactions\n        if len(bands) >= 2:\n            for i in range(len(bands) - 1):\n                b1, b2 = bands[i], bands[i + 1]\n                out[f\"redshift_x_{b1}_{b2}\"] = out[\"redshift\"] * (\n                    out[b1] - out[b2]\n                )\n            # Redshift × mean magnitude\n            if \"mag_mean\" in out.columns:\n                out[\"redshift_x_mag_mean\"] = out[\"redshift\"] * out[\"mag_mean\"]\n\n    # ----- 6. Spectral type & galaxy population (if present) -----\n    for col in [\"spectral_type\", \"galaxy_population\"]:\n        if col in out.columns:\n            # Already categorical — keep as-is for tree models\n            pass\n\n    # ----- 7. Polynomial / interaction features for key pairs -----\n    if has_redshift and len(bands) >= 2:\n        # Redshift bins for interaction\n        out[\"redshift_bin\"] = pd.qcut(\n            out[\"redshift\"], q=50, labels=False, duplicates=\"drop\"\n        )\n\n    # ----- 8. Drop original id column (not a feature) -----\n    # We keep it for alignment but exclude from model features later\n\n    return out\n\n\nprint(\"  Engineering features...\")\ntrain_fe = engineer_features(train)\ntest_fe = engineer_features(test)\n\n# Determine feature columns (exclude id and target)\nFEATURE_COLS = [\n    c\n    for c in test_fe.columns\n    if c not in [ID, TARGET, \"class\"]\n]\n\n# Handle any remaining object/categorical columns\ncat_cols = []\nnum_cols = []\nfor col in FEATURE_COLS:\n    if test_fe[col].dtype == \"object\":\n        # Label encode\n        from sklearn.preprocessing import LabelEncoder\n\n        le = LabelEncoder()\n        combined = pd.concat(\n            [train_fe[col].fillna(\"__MISSING__\"), test_fe[col].fillna(\"__MISSING__\")]\n        )\n        le.fit(combined)\n        train_fe[col] = le.transform(train_fe[col].fillna(\"__MISSING__\"))\n        test_fe[col] = le.transform(test_fe[col].fillna(\"__MISSING__\"))\n        cat_cols.append(col)\n    else:\n        num_cols.append(col)\n\nX_train = train_fe[FEATURE_COLS].values.astype(np.float32)\nX_test = test_fe[FEATURE_COLS].values.astype(np.float32)\n\n# Replace inf with nan, then fill nan\nX_train = np.nan_to_num(X_train, nan=0.0, posinf=1e10, neginf=-1e10)\nX_test = np.nan_to_num(X_test, nan=0.0, posinf=1e10, neginf=-1e10)\n\nprint(f\"  Feature count: {len(FEATURE_COLS)}\")\nprint(f\"  Numeric: {len(num_cols)}, Categorical: {len(cat_cols)}\")\nprint(f\"  X_train: {X_train.shape}, X_test: {X_test.shape}\")\n\n# ============================================================================\n# PHASE 2: MULTI-MODEL OOF TRAINING\n# ============================================================================\nprint(\"\\n[PHASE 2] Training diverse base models with OOF predictions...\")\n\n\ndef train_lightgbm_oof(\n    X, y, X_test, n_folds, seed, params_override=None\n):\n    \"\"\"Train LightGBM with OOF predictions.\"\"\"\n    import lightgbm as lgb\n\n    base_params = {\n        \"objective\": \"multiclass\",\n        \"num_class\": 3,\n        \"metric\": \"multi_logloss\",\n        \"verbosity\": -1,\n        \"n_jobs\": -1,\n        \"device\": \"gpu\",           # GPU acceleration\n        \"gpu_use_dp\": False,        # use single precision for speed\n        \"learning_rate\": 0.03,\n        \"num_leaves\": 63,\n        \"max_depth\": -1,\n        \"min_child_samples\": 20,\n        \"feature_fraction\": 0.8,\n        \"bagging_fraction\": 0.8,\n        \"bagging_freq\": 5,\n        \"reg_alpha\": 0.1,\n        \"reg_lambda\": 1.0,\n        \"is_unbalance\": True,\n        \"seed\": seed,\n    }\n    if params_override:\n        base_params.update(params_override)\n\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        fold_start = time.time()\n        X_tr, X_val = X[train_idx], X[val_idx]\n        y_tr, y_val = y[train_idx], y[val_idx]\n\n        dtrain = lgb.Dataset(X_tr, y_tr)\n        dval = lgb.Dataset(X_val, y_val, reference=dtrain)\n\n        model = lgb.train(\n            base_params,\n            dtrain,\n            num_boost_round=2000,\n            valid_sets=[dval],\n            callbacks=[lgb.early_stopping(50, verbose=False), lgb.log_evaluation(500)],\n        )\n\n        oof_proba[val_idx] = model.predict(X_val)\n        test_proba += model.predict(X_test) / n_folds\n\n        fold_ba = balanced_accuracy_score(y_val, oof_proba[val_idx].argmax(axis=1))\n        fold_time = time.time() - fold_start\n        print(f\"    Fold {fold+1}/{n_folds} | best_iter={model.best_iteration} | val_BA={fold_ba:.5f} | {fold_time:.1f}s\")\n\n        del model, dtrain, dval\n        gc.collect()\n\n    oof_pred = LABELS[oof_proba.argmax(axis=1)]\n    ba = balanced_accuracy_score(LABELS[y], oof_pred)\n    return oof_proba, test_proba, ba\n\n\ndef train_xgboost_oof(X, y, X_test, n_folds, seed, params_override=None):\n    \"\"\"Train XGBoost with OOF predictions.\"\"\"\n    import xgboost as xgb\n\n    base_params = {\n        \"objective\": \"multi:softprob\",\n        \"num_class\": 3,\n        \"eval_metric\": \"mlogloss\",\n        \"verbosity\": 0,\n        \"nthread\": -1,\n        \"learning_rate\": 0.03,\n        \"max_depth\": 8,\n        \"min_child_weight\": 5,\n        \"subsample\": 0.8,\n        \"colsample_bytree\": 0.8,\n        \"reg_alpha\": 0.1,\n        \"reg_lambda\": 1.0,\n        \"tree_method\": \"hist\",  # GPU acceleration\n        \"device\": \"cuda\",           # Kaggle T4 GPU\n        \"seed\": seed,\n    }\n    if params_override:\n        base_params.update(params_override)\n\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    # Compute sample weights for balanced accuracy\n    class_counts = np.bincount(y, minlength=3)\n    class_weights = len(y) / (3.0 * class_counts)\n    sample_weights = class_weights[y]\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        fold_start = time.time()\n        dtrain = xgb.DMatrix(\n            X[train_idx], y[train_idx], weight=sample_weights[train_idx]\n        )\n        dval = xgb.DMatrix(X[val_idx], y[val_idx], weight=sample_weights[val_idx])\n\n        model = xgb.train(\n            base_params,\n            dtrain,\n            num_boost_round=2000,\n            evals=[(dval, \"val\")],\n            early_stopping_rounds=50,\n            verbose_eval=500,\n        )\n\n        oof_proba[val_idx] = model.predict(\n            xgb.DMatrix(X[val_idx]), iteration_range=(0, model.best_iteration + 1)\n        )\n        test_proba += (\n            model.predict(\n                xgb.DMatrix(X_test), iteration_range=(0, model.best_iteration + 1)\n            )\n            / n_folds\n        )\n\n        fold_ba = balanced_accuracy_score(y[val_idx], oof_proba[val_idx].argmax(axis=1))\n        fold_time = time.time() - fold_start\n        print(f\"    Fold {fold+1}/{n_folds} | best_iter={model.best_iteration} | val_BA={fold_ba:.5f} | {fold_time:.1f}s\")\n\n        del model, dtrain, dval\n        gc.collect()\n\n    oof_pred = LABELS[oof_proba.argmax(axis=1)]\n    ba = balanced_accuracy_score(LABELS[y], oof_pred)\n    return oof_proba, test_proba, ba\n\n\ndef train_catboost_oof(X, y, X_test, n_folds, seed, params_override=None):\n    \"\"\"Train CatBoost with OOF predictions.\"\"\"\n    from catboost import CatBoostClassifier, Pool\n\n    base_params = {\n        \"iterations\": 2000,\n        \"learning_rate\": 0.03,\n        \"depth\": 8,\n        \"l2_leaf_reg\": 3.0,\n        \"random_seed\": seed,\n        \"verbose\": 500,\n        \"early_stopping_rounds\": 50,\n        \"auto_class_weights\": \"Balanced\",\n        \"eval_metric\": \"MultiClass\",\n        \"task_type\": \"GPU\",           # Kaggle T4 GPU\n        \"devices\": \"0\",\n    }\n    if params_override:\n        base_params.update(params_override)\n\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        fold_start = time.time()\n        model = CatBoostClassifier(**base_params)\n        model.fit(\n            X[train_idx],\n            y[train_idx],\n            eval_set=(X[val_idx], y[val_idx]),\n        )\n\n        oof_proba[val_idx] = model.predict_proba(X[val_idx])\n        test_proba += model.predict_proba(X_test) / n_folds\n\n        fold_ba = balanced_accuracy_score(y[val_idx], oof_proba[val_idx].argmax(axis=1))\n        best_iter = model.get_best_iteration() if hasattr(model, 'get_best_iteration') else 'N/A'\n        fold_time = time.time() - fold_start\n        print(f\"    Fold {fold+1}/{n_folds} | best_iter={best_iter} | val_BA={fold_ba:.5f} | {fold_time:.1f}s\")\n\n        del model\n        gc.collect()\n\n    oof_pred = LABELS[oof_proba.argmax(axis=1)]\n    ba = balanced_accuracy_score(LABELS[y], oof_pred)\n    return oof_proba, test_proba, ba\n\n\ndef train_extratrees_oof(X, y, X_test, n_folds, seed):\n    \"\"\"Train ExtraTreesClassifier with OOF predictions.\"\"\"\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        fold_start = time.time()\n        model = ExtraTreesClassifier(\n            n_estimators=500,\n            max_depth=None,\n            min_samples_leaf=2,\n            max_features=\"sqrt\",\n            class_weight=\"balanced\",\n            n_jobs=-1,\n            random_state=seed + fold,\n            verbose=1,\n        )\n        model.fit(X[train_idx], y[train_idx])\n\n        oof_proba[val_idx] = model.predict_proba(X[val_idx])\n        test_proba += model.predict_proba(X_test) / n_folds\n\n        fold_ba = balanced_accuracy_score(y[val_idx], oof_proba[val_idx].argmax(axis=1))\n        fold_time = time.time() - fold_start\n        print(f\"    Fold {fold+1}/{n_folds} | val_BA={fold_ba:.5f} | {fold_time:.1f}s\")\n\n        del model\n        gc.collect()\n\n    oof_pred = LABELS[oof_proba.argmax(axis=1)]\n    ba = balanced_accuracy_score(LABELS[y], oof_pred)\n    return oof_proba, test_proba, ba\n\n\n# ---------------------------------------------------------------------------\n# Train all models\n# ---------------------------------------------------------------------------\nall_oof = []\nall_test = []\nmodel_names = []\nphase2_start = time.time()\n\n# ---- LightGBM configurations ----\nlgb_configs = [\n    {\"num_leaves\": 63, \"learning_rate\": 0.03, \"min_child_samples\": 20},\n    {\"num_leaves\": 127, \"learning_rate\": 0.02, \"min_child_samples\": 10},\n]\n\nfor cfg_idx, cfg in enumerate(lgb_configs):\n    for seed in range(42, 42 + N_SEEDS_GBDT):\n        name = f\"lgb_cfg{cfg_idx}_s{seed}\"\n        print(f\"\\n  Training {name}...\")\n        model_start = time.time()\n        oof, tst, ba = train_lightgbm_oof(X_train, y_train, X_test, N_FOLDS, seed, cfg)\n        model_time = time.time() - model_start\n        print(f\"  => {name} done | OOF BA={ba:.5f} | {model_time:.1f}s\")\n        all_oof.append(oof)\n        all_test.append(tst)\n        model_names.append(name)\n\n# ---- XGBoost configurations ----\nxgb_configs = [\n    {\"max_depth\": 8, \"learning_rate\": 0.03, \"min_child_weight\": 3},\n    {\"max_depth\": 10, \"learning_rate\": 0.02, \"min_child_weight\": 5, \"colsample_bytree\": 0.7},\n]\n\nfor cfg_idx, cfg in enumerate(xgb_configs):\n    for seed in range(42, 42 + N_SEEDS_GBDT):\n        name = f\"xgb_cfg{cfg_idx}_s{seed}\"\n        print(f\"\\n  Training {name}...\")\n        model_start = time.time()\n        oof, tst, ba = train_xgboost_oof(X_train, y_train, X_test, N_FOLDS, seed, cfg)\n        model_time = time.time() - model_start\n        print(f\"  => {name} done | OOF BA={ba:.5f} | {model_time:.1f}s\")\n        all_oof.append(oof)\n        all_test.append(tst)\n        model_names.append(name)\n\n# ---- CatBoost configurations ----\ncat_configs = [\n    {\"depth\": 8, \"learning_rate\": 0.03, \"l2_leaf_reg\": 1.0},\n    {\"depth\": 10, \"learning_rate\": 0.02, \"l2_leaf_reg\": 5.0},\n]\n\nfor cfg_idx, cfg in enumerate(cat_configs):\n    for seed in range(42, 42 + N_SEEDS_GBDT):\n        name = f\"cat_cfg{cfg_idx}_s{seed}\"\n        print(f\"\\n  Training {name}...\")\n        model_start = time.time()\n        oof, tst, ba = train_catboost_oof(X_train, y_train, X_test, N_FOLDS, seed, cfg)\n        model_time = time.time() - model_start\n        print(f\"  => {name} done | OOF BA={ba:.5f} | {model_time:.1f}s\")\n        all_oof.append(oof)\n        all_test.append(tst)\n        model_names.append(name)\n\n# ---- ExtraTrees (CPU only — single seed to save time) ----\nfor seed in range(42, 42 + 1):\n    name = f\"et_s{seed}\"\n    print(f\"\\n  Training {name}...\")\n    model_start = time.time()\n    oof, tst, ba = train_extratrees_oof(X_train, y_train, X_test, N_FOLDS, seed)\n    model_time = time.time() - model_start\n    print(f\"  => {name} done | OOF BA={ba:.5f} | {model_time:.1f}s\")\n    all_oof.append(oof)\n    all_test.append(tst)\n    model_names.append(name)\n\nphase2_time = time.time() - phase2_start\nprint(f\"\\n  Total base models: {len(model_names)}\")\nprint(f\"  Phase 2 total time: {phase2_time:.1f}s ({phase2_time/60:.1f} min)\")\n\n# ---- Quick ensemble baseline (simple average) ----\navg_oof = np.mean(all_oof, axis=0)\navg_test = np.mean(all_test, axis=0)\navg_pred = LABELS[avg_oof.argmax(axis=1)]\navg_ba = balanced_accuracy_score(LABELS[y_train], avg_pred)\nprint(f\"  Simple average ensemble OOF BA: {avg_ba:.5f}\")\n\n# ============================================================================\n# PHASE 3: META-LEARNER STACKING\n# ============================================================================\nprint(\"\\n[PHASE 3] Meta-learner stacking...\")\n\n# Build meta-features: raw probabilities + log-probabilities + rank features\nmeta_oof_parts = []\nmeta_test_parts = []\n\nfor oof, tst in zip(all_oof, all_test):\n    # Raw probabilities\n    meta_oof_parts.append(oof)\n    meta_test_parts.append(tst)\n\n    # Log-probabilities (rich signal for the meta-learner)\n    meta_oof_parts.append(np.log(np.clip(oof, 1e-15, 1.0)))\n    meta_test_parts.append(np.log(np.clip(tst, 1e-15, 1.0)))\n\n# ---- Integrate existing prediction files ----\nif USE_EXISTING_PREDS and PRED_DIR.exists():\n    print(\"  Integrating existing prediction files...\")\n\n    # Load test IDs from test set for alignment\n    test_id_set = set(test_ids)\n\n    # Read probability CSVs\n    for path in sorted(PRED_DIR.glob(\"test_preds__*.csv\")):\n        try:\n            df = pd.read_csv(path)\n            if ID not in df.columns or not set(LABELS).issubset(df.columns):\n                continue\n            if not np.array_equal(df[ID].to_numpy(), test_ids):\n                continue\n            arr = df[LABELS].to_numpy(np.float64)\n            arr /= arr.sum(axis=1, keepdims=True)\n            # We only have test predictions (no OOF), so create zero OOF\n            # These will be used only for test-time prediction diversity\n            dummy_oof = np.full((len(X_train), 3), 1.0 / 3.0)\n            meta_oof_parts.append(dummy_oof)\n            meta_test_parts.append(arr)\n            meta_oof_parts.append(np.log(np.clip(dummy_oof, 1e-15, 1.0)))\n            meta_test_parts.append(np.log(np.clip(arr, 1e-15, 1.0)))\n            print(f\"    Loaded {path.name}\")\n        except Exception as e:\n            print(f\"    Failed to load {path.name}: {e}\")\n\n    # Read NPY files\n    for filename in [\"cat-3_test_preds__0.96972.npy\", \"pred_lr_stacker_v9.npy\"]:\n        path = PRED_DIR / filename\n        if path.exists():\n            try:\n                arr = np.load(path).astype(np.float64)\n                arr /= arr.sum(axis=1, keepdims=True)\n                dummy_oof = np.full((len(X_train), 3), 1.0 / 3.0)\n                meta_oof_parts.append(dummy_oof)\n                meta_test_parts.append(arr)\n                meta_oof_parts.append(np.log(np.clip(dummy_oof, 1e-15, 1.0)))\n                meta_test_parts.append(np.log(np.clip(arr, 1e-15, 1.0)))\n                print(f\"    Loaded {filename}\")\n            except Exception as e:\n                print(f\"    Failed to load {filename}: {e}\")\n\n    # Read artifact blend\n    artifact_path = PRED_DIR / \"sub_eda03_gbdt_artifact_blend.csv\"\n    if artifact_path.exists():\n        try:\n            df = pd.read_csv(\n                artifact_path,\n                usecols=[ID, \"proba_GALAXY\", \"proba_QSO\", \"proba_STAR\"],\n            )\n            if np.array_equal(df[ID].to_numpy(), test_ids):\n                arr = df[[\"proba_GALAXY\", \"proba_QSO\", \"proba_STAR\"]].to_numpy(\n                    np.float64\n                )\n                arr /= arr.sum(axis=1, keepdims=True)\n                dummy_oof = np.full((len(X_train), 3), 1.0 / 3.0)\n                meta_oof_parts.append(dummy_oof)\n                meta_test_parts.append(arr)\n                meta_oof_parts.append(np.log(np.clip(dummy_oof, 1e-15, 1.0)))\n                meta_test_parts.append(np.log(np.clip(arr, 1e-15, 1.0)))\n                print(f\"    Loaded {artifact_path.name}\")\n        except Exception as e:\n            print(f\"    Failed to load artifact blend: {e}\")\n\nX_meta_oof = np.hstack(meta_oof_parts)\nX_meta_test = np.hstack(meta_test_parts)\n\nprint(f\"  Meta feature matrix: OOF={X_meta_oof.shape}, Test={X_meta_test.shape}\")\n\n# ---- Train meta-learner with OOF CV ----\n# We use the OOF predictions from our trained models (not the existing preds\n# which have dummy OOF) to train the meta-learner. The existing preds only\n# contribute at test time as additional signals.\n\n# Only use columns from our trained models for meta-learner training\nn_our_models = len(all_oof)\nn_features_per_model = 6  # 3 raw proba + 3 log-proba\nn_our_features = n_our_models * n_features_per_model\n\n# For training meta-learner: use only our model OOFs\nX_meta_train_our = X_meta_oof[:, :n_our_features]\n\n# Try multiple meta-learner configurations\nbest_meta_ba = 0\nbest_meta_model = None\nbest_meta_C = None\n\nfor C in [0.01, 0.05, 0.1, 0.5, 1.0, 5.0, 10.0, 50.0]:\n    meta_model = LogisticRegression(\n        C=C,\n        class_weight=\"balanced\",\n        max_iter=2000,\n        multi_class=\"multinomial\",\n        solver=\"lbfgs\",\n        random_state=42,\n    )\n\n    # OOF evaluation of meta-learner itself\n    meta_oof_pred = np.zeros((len(y_train), 3), dtype=np.float64)\n    skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n\n    for fold, (tr_idx, val_idx) in enumerate(skf.split(X_meta_train_our, y_train)):\n        meta_model_fold = LogisticRegression(\n            C=C,\n            class_weight=\"balanced\",\n            max_iter=2000,\n            multi_class=\"multinomial\",\n            solver=\"lbfgs\",\n            random_state=42,\n        )\n        meta_model_fold.fit(X_meta_train_our[tr_idx], y_train[tr_idx])\n        meta_oof_pred[val_idx] = meta_model_fold.predict_proba(\n            X_meta_train_our[val_idx]\n        )\n\n    meta_pred_labels = LABELS[meta_oof_pred.argmax(axis=1)]\n    meta_ba = balanced_accuracy_score(LABELS[y_train], meta_pred_labels)\n\n    if meta_ba > best_meta_ba:\n        best_meta_ba = meta_ba\n        best_meta_C = C\n        best_meta_oof_proba = meta_oof_pred.copy()\n\n    print(f\"  Meta-learner C={C}: OOF BA={meta_ba:.5f}\")\n\nprint(f\"  Best meta-learner: C={best_meta_C}, OOF BA={best_meta_ba:.5f}\")\n\n# Train final meta-learner on full OOF data\nfinal_meta = LogisticRegression(\n    C=best_meta_C,\n    class_weight=\"balanced\",\n    max_iter=2000,\n    multi_class=\"multinomial\",\n    solver=\"lbfgs\",\n    random_state=42,\n)\nfinal_meta.fit(X_meta_train_our, y_train)\n\n# Predict on test using ALL meta features (including existing preds)\n# But we need to handle the dimension mismatch: meta-learner was trained on\n# n_our_features columns, so we predict using only those columns and then\n# blend with existing predictions separately.\nmeta_test_proba = final_meta.predict_proba(X_meta_test[:, :n_our_features])\n\n# ---- Blend with existing prediction consensus ----\nif USE_EXISTING_PREDS and n_our_features < X_meta_test.shape[1]:\n    # Extract existing prediction probabilities (raw, not log)\n    existing_proba_parts = []\n    offset = n_our_features\n    while offset < X_meta_test.shape[1]:\n        existing_proba_parts.append(X_meta_test[:, offset : offset + 3])\n        offset += 6  # skip log-proba part\n\n    if existing_proba_parts:\n        existing_avg = np.mean(existing_proba_parts, axis=0)\n        existing_avg /= existing_avg.sum(axis=1, keepdims=True)\n\n        # Blend: meta predictions (high weight) + existing predictions (lower weight)\n        blend_weight = 0.85\n        meta_test_proba = (\n            blend_weight * meta_test_proba\n            + (1 - blend_weight) * existing_avg\n        )\n        meta_test_proba /= meta_test_proba.sum(axis=1, keepdims=True)\n        print(\n            f\"  Blended meta predictions with existing predictions (weight={blend_weight})\"\n        )\n\n# ============================================================================\n# PHASE 4: BALANCED ACCURACY THRESHOLD OPTIMIZATION\n# ============================================================================\nprint(\"\\n[PHASE 4] Threshold optimization for balanced accuracy...\")\n\n\ndef neg_balanced_accuracy_with_bias(bias, proba, y_true):\n    \"\"\"Negative balanced accuracy with class-specific bias adjustment.\"\"\"\n    adjusted = proba + bias  # broadcasting (N, 3) + (3,)\n    preds_idx = adjusted.argmax(axis=1)\n    return -balanced_accuracy_score(y_true, preds_idx)\n\n\n# Optimize on OOF predictions\nresult = minimize(\n    neg_balanced_accuracy_with_bias,\n    x0=np.array([0.0, 0.0, 0.0]),\n    args=(best_meta_oof_proba, y_train),\n    method=\"Nelder-Mead\",\n    options={\"maxiter\": 5000, \"xatol\": 1e-8, \"fatol\": 1e-8},\n)\n\noptimal_bias = result.x\nadjusted_oof = best_meta_oof_proba + optimal_bias\noof_pred_optimized = LABELS[adjusted_oof.argmax(axis=1)]\nba_optimized = balanced_accuracy_score(LABELS[y_train], oof_pred_optimized)\n\nprint(f\"  Optimal bias: {optimal_bias}\")\nprint(f\"  OOF BA before threshold opt: {best_meta_ba:.5f}\")\nprint(f\"  OOF BA after threshold opt:  {ba_optimized:.5f}\")\n\n# Apply threshold to test predictions\nadjusted_test = meta_test_proba + optimal_bias\nfinal_pred = LABELS[adjusted_test.argmax(axis=1)]\n\n# ============================================================================\n# PHASE 5: OPTIONAL RIDGE-FLIP POST-PROCESSING\n# ============================================================================\nif USE_RIDGE_FLIP_POST and PRED_DIR.exists():\n    print(\"\\n[PHASE 5] Ridge-flip post-processing...\")\n\n    # Build a new submission from our stacked predictions\n    stacked_sub = pd.DataFrame({ID: test_ids, TARGET: final_pred})\n\n    # --- Helper functions from original notebook ---\n    def score_from_name(path: Path) -> float | None:\n        match = re.match(r\"^(0\\.\\d{5})\", path.name)\n        return float(match.group(1)) if match else None\n\n    def read_submission(\n        path: Path, ids: np.ndarray | None = None\n    ) -> pd.DataFrame | None:\n        if not path.exists():\n            return None\n        try:\n            df = pd.read_csv(path, usecols=[ID, TARGET]).copy()\n        except Exception:\n            return None\n        if ids is not None and not np.array_equal(df[ID].to_numpy(), ids):\n            df = df.set_index(ID).reindex(ids).reset_index()\n            if df[TARGET].isna().any():\n                return None\n        if not set(df[TARGET].unique()).issubset(set(LABELS)):\n            return None\n        return df\n\n    def load_probability_consensus(\n        data_dir: Path, ids: np.ndarray\n    ) -> tuple[np.ndarray, np.ndarray, np.ndarray, list[str]]:\n        arrays = []\n        weights = []\n        names = []\n\n        for path in sorted(data_dir.glob(\"test_preds__*.csv\")):\n            df = pd.read_csv(path)\n            if ID not in df.columns or not set(LABELS).issubset(df.columns):\n                continue\n            if not np.array_equal(df[ID].to_numpy(), ids):\n                continue\n            score = (\n                score_from_name(Path(path.name.replace(\"test_preds__\", \"\"))) or 0.969\n            )\n            arr = df[LABELS].to_numpy(np.float64)\n            arr /= arr.sum(axis=1, keepdims=True)\n            arrays.append(arr)\n            weights.append(max(0.25, (score - 0.968) * 1000.0))\n            names.append(path.name)\n\n        for filename, weight in [\n            (\"cat-3_test_preds__0.96972.npy\", 1.7),\n            (\"pred_lr_stacker_v9.npy\", 3.5),\n        ]:\n            path = data_dir / filename\n            if path.exists():\n                arr = np.load(path).astype(np.float64)\n                arr /= arr.sum(axis=1, keepdims=True)\n                arrays.append(arr)\n                weights.append(weight)\n                names.append(filename)\n\n        artifact = data_dir / \"sub_eda03_gbdt_artifact_blend.csv\"\n        if artifact.exists():\n            df = pd.read_csv(\n                artifact, usecols=[ID, \"proba_GALAXY\", \"proba_QSO\", \"proba_STAR\"]\n            )\n            if np.array_equal(df[ID].to_numpy(), ids):\n                arr = df[[\"proba_GALAXY\", \"proba_QSO\", \"proba_STAR\"]].to_numpy(\n                    np.float64\n                )\n                arr /= arr.sum(axis=1, keepdims=True)\n                arrays.append(arr)\n                weights.append(4.0)\n                names.append(artifact.name)\n\n        if not arrays:\n            return None, None, None, []\n\n        proba = np.average(np.stack(arrays), axis=0, weights=np.array(weights))\n        proba /= proba.sum(axis=1, keepdims=True)\n        pred = LABELS[proba.argmax(axis=1)]\n        sorted_p = np.sort(proba, axis=1)\n        margin = sorted_p[:, -1] - sorted_p[:, -2]\n        return proba, pred, margin, names\n\n    # Also include our meta_test_proba as a strong probability source\n    # by merging it into the consensus\n    try:\n        proba_consensus, proba_pred, proba_margin, proba_names = (\n            load_probability_consensus(PRED_DIR, test_ids)\n        )\n\n        if proba_consensus is not None:\n            # Blend our stacked proba with existing consensus\n            # Our stacked predictions should dominate\n            combined_proba = 0.7 * meta_test_proba + 0.3 * proba_consensus\n            combined_proba /= combined_proba.sum(axis=1, keepdims=True)\n            combined_pred = LABELS[(combined_proba + optimal_bias).argmax(axis=1)]\n\n            # Use combined predictions as the final output\n            final_pred = combined_pred\n            print(\n                f\"  Blended stacked+consensus predictions ({len(proba_names)} existing sources)\"\n            )\n        else:\n            print(\"  No existing probability consensus available; using stacked predictions only\")\n    except Exception as e:\n        print(f\"  Ridge-flip post-processing skipped: {e}\")\n\nelse:\n    print(\"\\n[PHASE 5] Ridge-flip post-processing skipped (disabled or no data)\")\n\n# ============================================================================\n# PHASE 6: GENERATE FINAL SUBMISSION\n# ============================================================================\nprint(\"\\n[PHASE 6] Generating final submission...\")\n\nsubmission = pd.DataFrame({ID: test_ids, TARGET: final_pred})\n\n# Sanity checks\nprint(f\"\\n  Class distribution:\")\nprint(f\"  {submission[TARGET].value_counts().to_dict()}\")\n\ntrain_dist = pd.Series(LABELS[y_train]).value_counts(normalize=True)\npred_dist = submission[TARGET].value_counts(normalize=True)\nprint(f\"\\n  Train class proportions: {train_dist.to_dict()}\")\nprint(f\"  Pred  class proportions: {pred_dist.to_dict()}\")\n\nsubmission_path = WORK_DIR / \"submission.csv\"\nsubmission.to_csv(submission_path, index=False)\nprint(f\"\\n  Saved: {submission_path}\")\n\n# ---- Save metadata ----\nmetadata = {\n    \"pipeline\": \"grandmaster_s6e6\",\n    \"n_base_models\": len(model_names),\n    \"model_names\": model_names,\n    \"n_folds\": N_FOLDS,\n    \"n_seeds\": N_SEEDS_GBDT,\n    \"n_features\": len(FEATURE_