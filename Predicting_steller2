l_idx], oof_rf[val_idx].argmax(1))\n    rf_accs.append(acc)\n    print(f\"  [RF] Fold {fold+1}/{N_FOLDS}: {acc:.5f}\")\n    del m; gc.collect()\n\ntest_rf /= N_FOLDS\nprint(f\"RandomForest OOF: {accuracy_score(y, oof_rf.argmax(1)):.5f} | \"\n      f\"Mean: {np.mean(rf_accs):.5f} | {time.time()-t0:.0f}s\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-16T11:06:26.720941Z","iopub.execute_input":"2026-06-16T11:06:26.72126Z"}},"outputs":[{"name":"stdout","text":"  [RF] Fold 1/5: 0.85305\n","output_type":"stream"}],"execution_count":null},{"id":"e34e7c4d-612f-47ea-adbc-2f8a09860cf1","cell_type":"markdown","source":"## 🏗️ Layer-2 Stacking Meta-Learner","metadata":{}},{"id":"65b67a45-ab8d-41e2-a3e8-8ee4ecfb72b6","cell_type":"code","source":"# Build stacking meta-features: (N, 15) and (M, 15)\nS_train = np.hstack([oof_cat, oof_lgbm, oof_xgb, oof_et, oof_rf])\nS_test  = np.hstack([test_cat, test_lgbm, test_xgb, test_et, test_rf])\nprint(\"Meta-feature shape:\", S_train.shape)\n\n# ── L2 model 1: Logistic Regression ──────────────────────────────────────────\noof_lr  = np.zeros((len(S_train), N_CLASSES))\ntest_lr = np.zeros((len(S_test),  N_CLASSES))\nscaler  = StandardScaler()\n\nfor fold, (tr_idx, val_idx) in enumerate(skf.split(S_train, y)):\n    Str  = scaler.fit_transform(S_train[tr_idx])\n    Sval = scaler.transform(S_train[val_idx])\n    lr = LogisticRegression(C=10.0, max_iter=3000, solver='lbfgs',\n                            multi_class='multinomial', random_state=SEED)\n    lr.fit(Str, y[tr_idx])\n    oof_lr[val_idx] = lr.predict_proba(Sval)\n    test_lr        += lr.predict_proba(scaler.transform(S_test))\n\ntest_lr /= N_FOLDS\nprint(f\"L2 LogReg OOF: {accuracy_score(y, oof_lr.argmax(1)):.5f}\")\n\n# ── L2 model 2: LGBM meta-learner (GPU) ──────────────────────────────────────\noof_lgbm2  = np.zeros((len(S_train), N_CLASSES))\ntest_lgbm2 = np.zeros((len(S_test),  N_CLASSES))\n\nlgbm2_params = dict(\n    objective        = 'multiclass',\n    num_class        = N_CLASSES,\n    n_estimators     = 8000,\n    learning_rate    = 0.01,\n    num_leaves       = 63,\n    max_depth        = 5,\n    subsample        = 0.8,\n    colsample_bytree = 0.8,\n    device           = 'gpu' ,  # 🚀 GPU meta-learner\n    random_state     = SEED,\n    verbosity        = -1,\n    n_jobs           = -1,\n)\n\nfor fold, (tr_idx, val_idx) in enumerate(skf.split(S_train, y)):\n    m2 = LGBMClassifier(**lgbm2_params)\n    m2.fit(S_train[tr_idx], y[tr_idx],\n           eval_set=[(S_train[val_idx], y[val_idx])],\n           callbacks=[early_stopping(200, verbose=False), log_evaluation(-1)])\n    oof_lgbm2[val_idx] = m2.predict_proba(S_train[val_idx])\n    test_lgbm2        += m2.predict_proba(S_test)\n\ntest_lgbm2 /= N_FOLDS\nprint(f\"L2 LGBM OOF:   {accuracy_score(y, oof_lgbm2.argmax(1)):.5f}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"2ad926b4-beae-4048-8ab3-74c022a7c3d1","cell_type":"markdown","source":"## ⚡ Nelder-Mead Optimised Ensemble Weights","metadata":{}},{"id":"bfb0820d-94ea-4239-b38b-d7b23a35c3be","cell_type":"code","source":"names       = ['CatBoost','LGBM','XGB','ExtraTrees','RF']\noof_models  = [oof_cat, oof_lgbm, oof_xgb, oof_et, oof_rf]\ntest_models = [test_cat, test_lgbm, test_xgb, test_et, test_rf]\n\nprint(\"Layer-1 individual scores:\")\nfor name, oof in zip(names, oof_models):\n    print(f\"  {name:<15} {accuracy_score(y, oof.argmax(1)):.5f}\")\n\ndef neg_acc(weights, oofs, y_true):\n    w   = np.abs(weights) / (np.abs(weights).sum() + 1e-12)\n    ens = sum(w[i] * oofs[i] for i in range(len(oofs)))\n    return -accuracy_score(y_true, ens.argmax(1))\n\n# L1 weight search\nres_l1 = minimize(neg_acc,\n                  x0=np.ones(len(oof_models)) / len(oof_models),\n                  args=(oof_models, y),\n                  method='Nelder-Mead',\n                  options={'maxiter': 10000, 'xatol': 1e-8, 'fatol': 1e-8})\nw_l1 = np.abs(res_l1.x) / np.abs(res_l1.x).sum()\nprint(\"\\nL1 weights:\", dict(zip(names, w_l1.round(4))))\n\noof_l1_ens  = sum(w_l1[i] * oof_models[i]  for i in range(len(oof_models)))\ntest_l1_ens = sum(w_l1[i] * test_models[i] for i in range(len(oof_models)))\nprint(f\"L1 Ensemble OOF: {accuracy_score(y, oof_l1_ens.argmax(1)):.5f}\")\n\n# Final blend: L1 + L2\noof_final_cands  = [oof_l1_ens, oof_lr, oof_lgbm2]\ntest_final_cands = [test_l1_ens, test_lr, test_lgbm2]\nfinal_names      = ['L1_Ensemble','LogReg_L2','LGBM_L2']\n\nres_final = minimize(neg_acc,\n                     x0=np.ones(len(oof_final_cands)) / len(oof_final_cands),\n                     args=(oof_final_cands, y),\n                     method='Nelder-Mead',\n                     options={'maxiter': 10000, 'xatol': 1e-9, 'fatol': 1e-9})\nw_final = np.abs(res_final.x) / np.abs(res_final.x).sum()\nprint(\"\\nFinal blend weights:\", dict(zip(final_names, w_final.round(4))))\n\noof_final  = sum(w_final[i] * oof_final_cands[i]  for i in range(len(oof_final_cands)))\ntest_final = sum(w_final[i] * test_final_cands[i] for i in range(len(oof_final_cands)))\nprint(f\"\\n🎯 FINAL OOF Accuracy: {accuracy_score(y, oof_final.argmax(1)):.5f}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"75a5d03b-20c6-48c4-8b7c-88b4547b5bf3","cell_type":"markdown","source":"## 🔄 Aggressive Pseudo-Labeling (threshold=0.998)","metadata":{}},{"id":"d61a420c-7b6b-4e58-ab14-790c381b2133","cell_type":"code","source":"CONF_THRESHOLD = 0.998   # slightly lower → more pseudo-label samples\n\nmax_proba    = test_final.max(1)\npseudo_mask  = max_proba >= CONF_THRESHOLD\npseudo_labels = test_final.argmax(1)[pseudo_mask]\n\nprint(f\"Pseudo-label candidates: {pseudo_mask.sum()} / {len(max_proba)} \"\n      f\"({100*pseudo_mask.mean():.1f}%)\")\nprint(f\"Class dist: {dict(zip(le.classes_, np.bincount(pseudo_labels, minlength=N_CLASSES)))}\")\n\nif pseudo_mask.sum() > 100:\n    X_aug     = pd.concat([X,     X_test[pseudo_mask].reset_index(drop=True)], ignore_index=True)\n    X_cat_aug = pd.concat([X_cat, X_test_cat[pseudo_mask].reset_index(drop=True)], ignore_index=True)\n    y_aug     = np.concatenate([y, pseudo_labels])\n\n    print(f\"Augmented: {len(X_aug)} samples (was {len(X)})\")\n\n    # Re-train CatBoost (full data, no early stopping)\n    cb_aug = CatBoostClassifier(**{**cat_params,\n                                   'iterations': 8000,\n                                   'task_type': 'GPU' if USE_GPU else 'CPU',\n                                   'early_stopping_rounds': None,\n                                   'verbose': 0})\n    cb_aug.fit(Pool(X_cat_aug, y_aug, cat_features=CAT_FEATURES_CB))\n    test_cat_aug = cb_aug.predict_proba(Pool(X_test_cat, cat_features=CAT_FEATURES_CB))\n    del cb_aug; gc.collect()\n\n    # Re-train LGBM (GPU)\n    lgbm_aug = LGBMClassifier(**{**lgbm_params, 'n_estimators': 10000})\n    lgbm_aug.fit(X_aug, y_aug)\n    test_lgbm_aug = lgbm_aug.predict_proba(X_test)\n    del lgbm_aug; gc.collect()\n\n    # Blend pseudo-augmented predictions with OOF-CV predictions\n    PW = 0.35   # pseudo-label weight\n    test_cat_f  = (1-PW)*test_cat  + PW*test_cat_aug\n    test_lgbm_f = (1-PW)*test_lgbm + PW*test_lgbm_aug\n\n    # Recompute final test preds\n    test_pl_models = [test_cat_f, test_lgbm_f, test_xgb, test_et, test_rf]\n    test_l1_pl     = sum(w_l1[i] * test_pl_models[i] for i in range(5))\n    test_final_pl  = sum(w_final[i] * [test_l1_pl, test_lr, test_lgbm2][i]\n                         for i in range(3))\n    print(\"✅ Pseudo-label augmentation applied.\")\nelse:\n    test_final_pl = test_final\n    print(\"Skipping pseudo-labeling (too few high-confidence samples).\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"9aca2eec-5e5d-4c88-a248-425ae126956e","cell_type":"markdown","source":"## 📊 Summary & Submission","metadata":{}},{"id":"7a8548e5-b5cf-4791-a2ed-279a784d5a9a","cell_type":"code","source":"print(\"\\n\" + \"=\"*60)\nprint(\" MODEL ACCURACY SUMMARY\")\nprint(\"=\"*60)\nrows = (list(zip(names, oof_models)) +\n        [('LogReg L2', oof_lr), ('LGBM L2', oof_lgbm2),\n         ('L1 Ensemble', oof_l1_ens), ('FINAL', oof_final)])\nfor name, oof in rows:\n    acc = accuracy_score(y, oof.argmax(1))\n    bar = '█' * max(0, int(acc * 50 - 48.5))\n    print(f\"  {name:<18} {acc:.5f}  {bar}\")\nprint(\"=\"*60)\nprint(f\"  TARGET LB:         ≥ 0.99000\")\nprint(\"=\"*60)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"d6005927-8267-461a-8f5c-894f2ca714d4","cell_type":"code","source":"# Confidence analysis\nconf = test_final_pl.max(1)\nprint(\"Test prediction confidence:\")\nfor pct in [50, 75, 90, 95, 99, 99.9]:\n    print(f\"  {pct:5.1f}th pct: {np.percentile(conf, pct):.4f}\")\nprint(f\"  Mean: {conf.mean():.4f} | conf>0.99: {(conf>0.99).sum()} ({100*(conf>0.99).mean():.1f}%)\")\n\npred_labels = le.inverse_transform(test_final_pl.argmax(1))\nprint(\"\\nPredicted class distribution:\")\nfor cls, cnt in zip(*np.unique(pred_labels, return_counts=True)):\n    print(f\"  {cls}: {cnt} ({100*cnt/len(pred_labels):.1f}%)\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"aeb86577-e3b0-404c-a567-5e505bf6f07e","cell_type":"code","source":"submission = pd.DataFrame({'id': test_ids, 'class': pred_labels})\nsubmission.to_csv('submission.csv', index=False)\nprint(f\"Submission saved → submission.csv | Shape: {submission.shape}\")\nsubmission.head(10)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"679635a9-b309-443b-9791-a688811998a3","cell_type":"markdown","source":"## 📝 Grandmaster Techniques — Full Inventory\n\n| Technique | Detail |\n|---|---|\n| **Vectorized FE** | Zero `.apply()` calls — pure NumPy matrix ops, 50-100× faster |\n| **140+ features** | Color indices, spectral slope, Lick proxies, Baldwin effect, stellar locus, flux ratios, morphology |\n| **GPU boosters** | CatBoost `GPU`, LightGBM `gpu`, XGBoost `cuda` — all three on-device |\n| **Fast TE** | KFold target encoding via category masks (no slow groupby) |\n| **5-Fold CV** | 2× faster than 10-fold, still tight OOF estimates |\n| **5 base models** | CatBoost + LGBM + XGBoost + ExtraTrees + RandomForest |\n| **2-Level stacking** | L2: LogisticRegression + LGBM meta-learner on 15-dim OOF |\n| **Nelder-Mead** | Optimize ensemble weights on OOF accuracy (not simple average) |\n| **Pseudo-labeling** | threshold=0.998, weight=0.35 — aggressive augmentation |\n| **Memory efficient** | float32, gc.collect() after each fold, no redundant copies |\n| **Higher iterations** | CB=10k, LGBM=20k, XGB=15k with 300-step early stopping |","metadata":{}}]}