_type":"markdown","source":"## Feature Engineering","metadata":{}},{"id":"d7767509-2afc-4b44-a23f-0ef565318fb1","cell_type":"code","source":"def add_features(df):\n    bands = ['u', 'g', 'r', 'i', 'z']\n\n    # --- Photometric colour indices (all adjacent pairs + cross-pairs) ---\n    df['u_g'] = df['u'] - df['g']\n    df['g_r'] = df['g'] - df['r']\n    df['r_i'] = df['r'] - df['i']\n    df['i_z'] = df['i'] - df['z']\n    df['u_r'] = df['u'] - df['r']\n    df['u_z'] = df['u'] - df['z']\n    df['g_z'] = df['g'] - df['z']\n    df['g_i'] = df['g'] - df['i']\n    df['r_z'] = df['r'] - df['z']\n\n    # --- Magnitude statistics ---\n    df['mag_mean']  = df[bands].mean(axis=1)\n    df['mag_std']   = df[bands].std(axis=1)\n    df['mag_range'] = df[bands].max(axis=1) - df[bands].min(axis=1)\n    df['mag_skew']  = df[bands].skew(axis=1)\n\n    # --- Redshift-based features ---\n    df['log1p_redshift'] = np.log1p(df['redshift'].clip(lower=0))\n    df['redshift_sq']    = df['redshift'] ** 2\n\n    # --- Flux proxy: brighter (lower mag) objects stand out ---\n    df['flux_proxy'] = -df['r']          # standard r-band proxy\n    df['lum_proxy']  = df['r'] - 5 * np.log10(df['redshift'].clip(lower=1e-5))\n\n    # --- spectral_type ordinal (keep raw for CatBoost; also numeric copy) ---\n    spec_order = {'O/B': 0, 'A/F': 1, 'G/K': 2, 'M': 3}\n    df['spectral_type_num'] = df['spectral_type'].map(spec_order).fillna(-1).astype(int)\n\n    # --- galaxy_population binary flag ---\n    df['is_red_seq'] = (df['galaxy_population'] == 'Red_Sequence').astype(int)\n\n    return df\n\ntrain = add_features(train)\ntest  = add_features(test)\nprint(\"Feature engineering done. Columns:\", train.shape[1])\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-15T06:15:24.543731Z","iopub.execute_input":"2026-06-15T06:15:24.543931Z","iopub.status.idle":"2026-06-15T06:15:25.438992Z","shell.execute_reply.started":"2026-06-15T06:15:24.543912Z","shell.execute_reply":"2026-06-15T06:15: