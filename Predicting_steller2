ut['r_i'])) * out['log1p_z']\n\n    # Build output DataFrame\n    df_out = df.copy()\n    for k, v in out.items():\n        df_out[k] = v\n    return df_out\n\nt0 = time.time()\ntrain = grandmaster_features_fast(train)\ntest  = grandmaster_features_fast(test)\nprint(f\"Feature engineering: {time.time()-t0:.1f}s | {train.shape[1]} features\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-16T09:42:54.855149Z","iopub.execute_input":"2026-06-16T09:42:54.855461Z","iopub.status.idle":"2026-06-16T09:42:56.52552Z","shell.execute_reply.started":"2026-06-16T09:42:54.855441Z","shell.execute_reply":"2026-06-16T09:42:56.524685Z"}},"outputs":[{"name":"stdout","text":"Feature engineering: 1.6s | 108 features\n","output_type":"stream"}],"execution_count":13},{"id":"5544c51a-b0c2-4630-8aa9-63226c9f8fe0","cell_type":"code","source":"# ── Fast KFold target encoding (pure NumPy, no per-fold groupby) ──────────────\nCAT_COLS = ['spectral_type', 'galaxy_population']\nTARGET   = 'class'\n\nle = LabelEncoder()\ny  = le.fit_transform(train[TARGET])\nprint('Classes:', le.classes_)\n\ndef fast_kfold_target_encode(train_df, test_df, col, y_binary, n_splits=5, seed=42):\n    \"\"\"Vectorized KFold target encoding — uses precomputed category maps.\"\"\"\n    cats      = train_df[col].values\n    unique    = np.unique(cats)\n    global_mean = y_binary.mean()\n    skf       = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=seed)\n    oof_enc   = np.full(len(train_df), global_mean, dtype=np.float64)\n\n    for tr_idx, val_idx in skf.split(np.zeros(len(train_df)), y_binary.astype(int)):\n        for cat in unique:\n            mask_tr  = cats[tr_idx] == cat\n            mask_val = cats[val_idx] == cat\n            if mask_tr.sum() > 0:\n                mean_val = y_binary[tr_idx][mask_tr].mean()\n            else:\n                mean_val = global_mean\n            oof_enc[val_idx[mask_val]] = mean_val\n\n    # Test encoding: global mean per category\n    cat_m