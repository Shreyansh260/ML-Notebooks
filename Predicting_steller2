8:03.26227Z","shell.execute_reply":"2026-06-16T08:14:13.60834Z"}},"outputs":[{"name":"stdout","text":"  [ET] Fold 1/10: 0.95194\n  [ET] Fold 2/10: 0.95410\n  [ET] Fold 3/10: 0.95448\n  [ET] Fold 4/10: 0.95128\n  [ET] Fold 5/10: 0.95214\n  [ET] Fold 6/10: 0.94858\n  [ET] Fold 7/10: 0.95498\n  [ET] Fold 8/10: 0.95313\n  [ET] Fold 9/10: 0.95370\n  [ET] Fold 10/10: 0.95322\nExtraTrees OOF: 0.95275 | Mean: 0.95275\n","output_type":"stream"}],"execution_count":19},{"id":"98b7e9b1-abab-4aff-90b9-8384f166c5b4","cell_type":"code","source":"# ── Random Forest ─────────────────────────────────────────────────────────────\nimport cuml.accel\ncuml.accel.install()\n\nrf_params = dict(\n    n_estimators     = 800,\n    max_features     = 'sqrt',\n    min_samples_leaf = 2,\n    max_depth        = None,\n    bootstrap        = True,\n    random_state     = SEED,\n    n_jobs           = -1,\n)\n\nrf_accs = []\nfor fold, (tr_idx, val_idx) in enumerate(skf.split(X, y)):\n    X_tr, X_val = X.iloc[tr_idx].values, X.iloc[val_idx].values\n    y_tr, y_val = y[tr_idx], y[val_idx]\n\n    m = RandomForestClassifier(**rf_params)\n    m.fit(X_tr, y_tr)\n\n    oof_rf[val_idx] = m.predict_proba(X_val)\n    test_rf        += m.predict_proba(X_test.values)\n\n    acc = accuracy_score(y_val, oof_rf[val_idx].argmax(1))\n    rf_accs.append(acc)\n    print(f\"  [RF] Fold {fold+1}/{N_FOLDS}: {acc:.5f}\")\n\ntest_rf /= N_FOLDS\nprint(f\"RandomForest OOF: {accuracy_score(y, oof_rf.argmax(1)):.5f} | Mean: {np.mean(rf_accs):.5f}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-16T08:16:52.930074Z","iopub.execute_input":"2026-06-16T08:16:52.931389Z"}},"outputs":[],"execution_count":null},{"id":"6826753e-6728-4f20-a2a9-74f30890f07e","cell_type":"markdown","source":"## 🏗️ Layer-2 Stacking Meta-Learner","metadata":{}},{"id":"c0291ccc-8eb1-4fd6-b4d2-46590e80e8cd","cell_type":"code","source":"# Build stacking meta-features\nS_train = np.hstack([oof_cat, oof_lgbm, oof_xgb, oof_et, oof_rf])   # (N, 15)\nS_test  = np.hstack([test_cat, test_lgbm, test_xgb, test_et, test_rf]) # (M, 15)\n\nprint(\"Stacking meta-feature shape:\", S_train.shape)\n\n# ── L2 model 1: Logistic Regression ──────────────────────────────────────────\noof_lr   = np.zeros((len(S_train), N_CLASSES))\ntest_lr  = np.zeros((len(S_test),  N_CLASSES))\n\nscaler = StandardScaler()\nlr_accs = []\nfor fold, (tr_idx, val_idx) in enumerate(skf.split(S_train, y)):\n    Str, Sval = S_train[tr_idx], S_train[val_idx]\n    y_tr, y_val = y[tr_idx], y[val_idx]\n    Str_sc  = scaler.fit_transform(Str)\n    Sval_sc = scaler.transform(Sval)\n\n    lr = LogisticRegression(C=5.0, max_iter=2000, solver='lbfgs',\n                            multi_class='multinomial', random_state=SEED)\n    lr.fit(Str_sc, y_tr)\n\n    oof_lr[val_idx] = lr.predict_proba(Sval_sc)\n    test_lr        += lr.predict_proba(scaler.transform(S_test))\n\n    acc = accuracy_score(y_val, oof_lr[val_idx].argmax(1))\n    lr_accs.append(acc)\n\ntest_lr /= N_FOLDS\nprint(f\"L2 LogReg OOF: {accuracy_score(y, oof_lr.argmax(1)):.5f}\")\n\n# ── L2 model 2: LGBM meta-learner ────────────────────────────────────────────\noof_lgbm2  = np.zeros((len(S_train), N_CLASSES))\ntest_lgbm2 = np.zeros((len(S_test),  N_CLASSES))\n\nlgbm2_params = dict(\n    objective        = 'multiclass',\n    num_class        = N_CLASSES,\n    n_estimators     = 5000,\n    learning_rate    = 0.01,\n    num_leaves       = 31,\n    max_depth        = 4,\n    subsample        = 0.8,\n    colsample_bytree = 0.8,\n    random_state     = SEED,\n    device='gpu',  \n    verbosity        = -1,\n    n_jobs           = -1,\n)\n\nlgbm2_accs = []\nfor fold, (tr_idx, val_idx) in enumerate(skf.split(S_train, y)):\n    Str, Sval = S_train[tr_idx], S_train[val_idx]\n    y_tr, y_val = y[tr_idx], y[val_idx]\n\n    m2 = LGBMClassifier(**lgbm2_params)\n    m2.fit(Str, y_tr,\n           eval_set=[(Sval, y_val)],\n           callbacks=[early_stopping(200, verbose=False), log_evaluation(-1)])\n\n    oof_lgbm2[val_idx] = m2.predict_proba(Sval)\n    test_lgbm2        += m2.predict_proba(S_test)\n\n    acc = accuracy_score(y_val, oof_lgbm2[val_idx].argmax(1))\n    lgbm2_accs.append(acc)\n\ntest_lgbm2 /= N_FOLDS\nprint(f\"L2 LGBM OOF: {accuracy_score(y, oof_lgbm2.argmax(1)):.5f}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"92c674b9-aa69-4feb-8f22-4086ceaf81e2","cell_type":"markdown","source":"## ⚡ Optimised Ensemble (Nelder-Mead weight search)","metadata":{}},{"id":"426be848-7489-4bfd-8040-6c175b105ad2","cell_type":"code","source":"# ── Level-1 ensemble ─────────────────────────────────────────────────────────\noof_models  = [oof_cat, oof_lgbm, oof_xgb, oof_et, oof_rf]\ntest_models = [test_cat, test_lgbm, test_xgb, test_et, test_rf]\nnames       = ['CatBoost','LGBM','XGB','ExtraTrees','RF']\n\nfor name, oof in zip(names, oof_models):\n    print(f\"  {name}: {accuracy_score(y, oof.argmax(1)):.5f}\")\n\ndef neg_acc(weights, oofs, y_true):\n    w = np.abs(weights) / np.abs(weights).sum()\n    ens = sum(w[i] * oofs[i] for i in range(len(oofs)))\n    return -accuracy_score(y_true, ens.argmax(1))\n\n# Optimise L1 weights\nres_l1 = minimize(neg_acc,\n                  x0=np.ones(len(oof_models)) / len(oof_models),\n                  args=(oof_models, y),\n                  method='Nelder-Mead',\n                  options={'maxiter': 5000, 'xatol': 1e-7, 'fatol': 1e-7})\nw_l1 = np.abs(res_l1.x) / np.abs(res_l1.x).sum()\nprint(\"\\nL1 weights:\", dict(zip(names, w_l1.round(4))))\n\noof_l1_ens  = sum(w_l1[i] * oof_models[i]  for i in range(len(oof_models)))\ntest_l1_ens = sum(w_l1[i] * test_models[i] for i in range(len(oof_models)))\nprint(f\"L1 Ensemble OOF: {accuracy_score(y, oof_l1_ens.argmax(1)):.5f}\")\n\n# ── Final ensemble: blend L1 + L2 ────────────────────────────────────────────\noof_final_cands  = [oof_l1_ens, oof_lr, oof_lgbm2]\ntest_final_cands = [test_l1_ens, test_lr, test_lgbm2]\nfinal_names      = ['L1_Ensemble','LogReg_L2','LGBM_L2']\n\nfor name, oof in zip(final_names, oof_final_cands):\n    print(f\"  {name}: {accuracy_score(y, oof.argmax(1)):.5f}\")\n\nres_final = minimize(neg_acc,\n                     x0=np.ones(len(oof_final_cands)) / len(oof_final_cands),\n                     args=(oof_final_cands, y),\n                     method='Nelder-Mead',\n                     options={'maxiter': 5000, 'xatol': 1e-8, 'fatol': 1e-8})\nw_final = np.abs(res_final.x) / np.abs(res_final.x).sum()\nprint(\"\\nFinal weights:\", dict(zip(final_names, w_final.round(4))))\n\noof_final  = sum(w_final[i] * oof_final_cands[i]  for i in range(len(oof_final_cands)))\ntest_final = sum(w_final[i] * test_final_cands[i] for i in range(len(oof_final_cands)))\nprint(f\"\\n🎯 FINAL OOF Accuracy: {accuracy_score(y, oof_final.argmax(1)):.5f}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"991ca644-7a57-437f-8962-de82ce162e34","cell_type":"markdown","source":"## 🔄 Pseudo-Labeling (High-Confidence Test Samples)","metadata":{}},{"id":"23ab7d6f-11a3-4973-9652-681adaa3ff01","cell_type":"code","source":"# Use test samples where max predicted probability > 0.999 as pseudo-labels\nCONF_THRESHOLD = 0.999\n\nmax_proba = test_final.max(axis=1)\npseudo_mask = max_proba >= CONF_THRESHOLD\npseudo_labels = test_final.argmax(axis=1)[pseudo_mask]\n\nprint(f\"High-confidence pseudo-label samples: {pseudo_mask.sum()} / {len(max_proba)}\")\nprint(f\"Class distribution: {dict(zip(le.classes_, np.bincount(pseudo_labels, minlength=N_CLASSES)))}\")\n\nif pseudo_mask.sum() > 100:\n    # Augment training data\n    X_pseudo     = X_test[pseudo_mask]\n    X_cat_pseudo = X_test_cat[pseudo_mask]\n    y_pseudo     = pseudo_labels\n\n    X_aug      = pd.concat([X, X_pseudo], ignore_index=True)\n    X_cat_aug  = pd.concat([X_cat, X_cat_pseudo], ignore_index=True)\n    y_aug      = np.concatenate([y, y_pseudo])\n\n    print(f\"Augmented training set: {len(X_aug)} samples (was {len(X)})\")\n\n    # Re-train CatBoost + LGBM on augmented data (full, no CV - just for final test preds)\n    # CatBoost\n    cb_aug = CatBoostClassifier(**{**cat_params,\n                                   'iterations': 6000,\n                                   'early_stopping_rounds': None,\n                                   'verbose': 0})\n    cb_aug.fit(Pool(X_cat_aug, y_aug, cat_features=CAT_FEATURES_CB))\n    test_cat_aug = cb_aug.predict_proba(Pool(X_test_cat, cat_features=CAT_FEATURES_CB))\n\n    # LGBM\n    lgbm_aug_params = {**lgbm_params, 'n_estimators': 8000}\n    del lgbm_aug_params['device']  # avoid GPU flag issues\n    lgbm_aug_params['device'] = 'cpu'\n    lg_aug = LGBMClassifier(**lgbm_aug_params)\n    lg_aug.fit(X_aug, y_aug)\n    test_lgbm_aug = lg_aug.predict_proba(X_test)\n\n    # Blend pseudo-label augmented predictions with original\n    PSEUDO_WEIGHT = 0.3\n    test_cat_final  = (1 - PSEUDO_WEIGHT) * test_cat  + PSEUDO_WEIGHT * test_cat_aug\n    test_lgbm_final = (1 - PSEUDO_WEIGHT) * test_lgbm + PSEUDO_WEIGHT * test_lgbm_aug\n\n    # Re-blend\n    test_final_pl = (w_l1[0] * test_cat_final + w_l1[1] * test_lgbm_final +\n                     w_l1[2] * test_xgb + w_l1[3] * test_et + w_l1[4] * test_rf)\n    print(\"Pseudo-label augmentation applied to test predictions.\")\nelse:\n    test_final_pl = test_final\n    print(\"Skipping pseudo-labeling (too few high-confidence samples).\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"13f92a20-f651-4ae9-b5eb-64790e32ca1c","cell_type":"markdown","source":"## 📊 Final Summary & Submission","metadata":{}},{"id":"d5892ef0-c375-414a-9939-33ae72378424","cell_type":"code","source":"# ── Final predictions ─────────────────────────────────────────────────────────\npred_proba  = test_final_pl\npred_idx    = pred_proba.argmax(axis=1)\npred_labels = le.inverse_transform(pred_idx)\n\n# ── OOF summary ──────────────────────────────────────────────────────────────\nprint(\"\\n\" + \"=\"*55)\nprint(\" MODEL ACCURACY SUMMARY\")\nprint(\"=\"*55)\nrows = list(zip(names, oof_models)) + [\n    ('LogReg L2',   oof_lr),\n    ('LGBM L2',     oof_lgbm2),\n    ('L1 Ensemble', oof_l1_ens),\n    ('FINAL',       oof_final),\n]\nfor name, oof in rows:\n    acc = accuracy_score(y, oof.argmax(1))\n    bar = '█' * int(acc * 40 - 38.5)\n    print(f\"  {name:<18} {acc:.5f}  {bar}\")\nprint(\"=\"*55)\nprint(f\"  TARGET LB SCORE:   0.99000\")\nprint(\"=\"*55)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"27c19c63-8889-402f-b7c8-57f650b32265","cell_type":"code","source":"# ── Prediction confidence analysis ───────────────────────────────────────────\nconf = pred_proba.max(axis=1)\nprint(\"Test prediction confidence:\")\nfor pct in [50, 75, 90, 95, 99, 99.9]:\n    print(f\"  {pct:5.1f}th percentile: {np.percentile(conf, pct):.4f}\")\nprint(f\"  Mean confidence: {conf.mean():.4f}\")\nprint(f\"  Samples with conf > 0.99: {(conf > 0.99).sum()} ({100*(conf>0.99).mean():.1f}%)\")\n\n# Class distribution\nprint(\"\\nPredicted class distribution:\")\nfor cls, cnt in zip(*np.unique(pred_labels, return_counts=True)):\n    print(f\"  {cls}: {cnt} ({100*cnt/len(pred_labels):.1f}%)\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"ad658423-7d5f-464a-bbb0-5e91d2a1e85f","cell_type":"code","source":"# ── Generate submission ───────────────────────────────────────────────────────\nimport os\nsubmission = pd.DataFrame({'id': test_ids, 'class': pred_labels})\nout_path = 'submission.csv'\nsubmission.to_csv(out_path, index=False)\nprint(f\"Submission saved → {out_path}\")\nprint(f\"Shape: {submission.shape}\")\nprint(submission['class'].value_counts())\nsubmission.head(10)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"3b602cbb-603e-47e3-aeb9-3364e5a65a2a","cell_type":"markdown","source":"## 📝 Grandmaster Techniques Applied\n\n| Technique | Detail |\n|---|---|\n| **Feature Engineering** | 120+ features: all color indices, spectral slope, stellar locus offsets, absolute magnitudes, K-corrections, Baldwin effect proxy, lookback distance, concentration index |\n| **Target Encoding** | 10-Fold KFold leak-safe encoding for `spectral_type` and `galaxy_population` — 6 new TE features |\n| **10-Fold CV** | Doubled from 5-fold → tighter OOF estimates, better uncertainty calibration |\n| **5 Base Models** | CatBoost + LGBM + XGBoost + ExtraTrees + RandomForest |\n| **2-Level Stacking** | L2: LogisticRegression + LGBM meta-learner on 15-dim OOF probabilities |\n| **Nelder-Mead Optimization** | Optimize ensemble weights on OOF accuracy (not simple average) |\n| **Pseudo-Labeling** | Add test samples with conf > 0.999 back to training |\n| **High iter counts** | CatBoost 8000, LGBM 15000, XGB 12000 with early stopping |\n| **Border count 254** | CatBoost: finer binning than default 128 → better splits on smooth mag features |","metadata":{}},{"id":"0bfddda8-796a-4719-926a-b2e75686c915","cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}