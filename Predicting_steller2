formed features using real astronomical knowledge about stellar classification.","metadata":{}},{"id":"8357ff2d-e726-4e31-86d6-dbdacad5974a","cell_type":"code","source":"def grandmaster_features(df):\n    \"\"\"Physics-driven + statistical features for stellar classification.\"\"\"\n    bands = ['u', 'g', 'r', 'i', 'z']\n    d = df.copy()\n\n    # ── 1. ALL photometric color indices ─────────────────────────────────────\n    # SDSS bands: u(354nm) g(477nm) r(623nm) i(762nm) z(913nm)\n    pairs = [(a, b) for i, a in enumerate(bands) for b in bands[i+1:]]\n    for a, b in pairs:\n        d[f'{a}_{b}'] = d[a] - d[b]\n\n    # ── 2. Magnitude statistics (row-wise across bands) ───────────────────────\n    mag_arr = d[bands].values\n    d['mag_mean']     = mag_arr.mean(axis=1)\n    d['mag_std']      = mag_arr.std(axis=1)\n    d['mag_range']    = mag_arr.max(axis=1)  - mag_arr.min(axis=1)\n    d['mag_skew']     = d[bands].skew(axis=1)\n    d['mag_kurt']     = d[bands].apply(lambda r: kurtosis(r.values), axis=1)\n    d['mag_cv']       = d['mag_std'] / (d['mag_mean'].abs() + 1e-8)  # coeff variation\n    d['mag_iqr']      = np.percentile(mag_arr, 75, axis=1) - np.percentile(mag_arr, 25, axis=1)\n    d['mag_median']   = np.median(mag_arr, axis=1)\n    d['mag_q10']      = np.percentile(mag_arr, 10, axis=1)\n    d['mag_q90']      = np.percentile(mag_arr, 90, axis=1)\n    d['mag_q90_q10']  = d['mag_q90'] - d['mag_q10']\n\n    # ── 3. Spectral slope features (linear fit across bands) ──────────────────\n    # Wavelength centers in nm (log scale)\n    wave_log = np.log10([354, 477, 623, 762, 913])  # u g r i z centers\n    wave_log -= wave_log.mean()\n    # Slope: regression coefficient of mag vs log(wavelength)\n    wave_sq = (wave_log**2).sum()\n    mag_dev = mag_arr - mag_arr.mean(axis=1, keepdims=True)\n    d['spectral_slope']    = (mag_dev * wave_log).sum(axis=1) / wave_sq\n    d['spectral_slope_sq'] = d['spectral_slope'] ** 2\n    # Quadratic curvature (deviation from linearity)\n    wave_q = wave_log**2 - (wave_log**2).mean()\n    d['spectral_curve'] = (mag_dev * wave_q).sum(axis=1)\n\n    # ── 4. BPT diagram proxy (QSO vs Galaxy separator) ────────────────────────\n    # Baldwin-Phillips-Terlevich: u-r is sensitive to ionization state\n    d['u_r']     = d['u'] - d['r']\n    d['g_i']     = d['g'] - d['i']\n    d['u_r_sq']  = d['u_r'] ** 2\n    # QSO locus: objects with extreme blue colors (low u-g) & high redshift\n    d['qso_color_score'] = -(d['u_g'] + d['g_r'])  # more negative = bluer\n\n    # ── 5. Stellar locus offsets ──────────────────────────────────────────────\n    # Stars follow a tight locus in color-color space\n    # Canonical stellar locus: g-r ≈ 0.45(u-g) - 0.12  (approx)\n    d['stellar_locus_offset']    = d['g_r'] - (0.45 * d['u_g'] - 0.12)\n    d['stellar_locus_offset_sq'] = d['stellar_locus_offset'] ** 2\n    # ri-iz stellar locus offset\n    d['stellar_locus_ri_iz'] = d['r_i'] - (0.90 * d['i_z'] + 0.05)\n\n    # ── 6. Redshift features ──────────────────────────────────────────────────\n    z = d['redshift'].clip(lower=0)\n    d['log1p_z']     = np.log1p(z)\n    d['log1p_z_sq']  = d['log1p_z'] ** 2\n    d['log1p_z_cb']  = d['log1p_z'] ** 3\n    d['z_sq']        = z ** 2\n    d['z_sqrt']      = np.sqrt(z)\n    d['z_recip']     = 1.0 / (z + 1e-5)\n    d['z_log_recip'] = np.log1p(1.0 / (z + 1e-5))\n    # Lookback distance proxy (Hubble law, flat ΛCDM approx)\n    d['lum_dist_proxy']  = z * (1 + z/2)           # Taylor: comoving dist ≈ cz/H0*(1+z/2)\n    d['ang_diam_proxy']  = z / ((1 + z) ** 2)      # D_A ∝ z/(1+z)^2\n    # K-correction proxy: redshift shifts SED into/out of observed bands\n    d['k_corr_g'] = -2.5 * np.log10(1 + z)         # simplified K-corr\n\n    # ── 7. Absolute magnitude proxies ─────────────────────────────────────────\n    # m - M = 5*log10(dL/10pc), dL ≈ lum_dist_proxy * 4280 Mpc\n    dist_mod = 5 * np.log10(d['lum_dist_proxy'].clip(lower=1e-4) * 4280e6 / 10)\n    for band in bands:\n        d[f'abs_{band}'] = d[band] - dist_mod\n\n    # ── 8. Color ratios (flux ratios) ─────────────────────────────────────────\n    # Pogson: flux ratio = 10^(-0.4 * color_index)\n    for a, b in [('u','g'),('g','r'),('r','i'),('i','z'),('g','z'),('u','z')]:\n        d[f'flux_{a}_{b}'] = 10 ** (-0.4 * (d[a] - d[b]))\n\n    # ── 9. Concentration index (morphology proxy) ─────────────────────────────\n    # C = r_petro_90 / r_petro_50; proxy via band colors\n    d['conc_proxy']    = d['r'] - d['i']            # brighter in r→i = extended?\n    d['morpho_proxy']  = d['u_g'] / (d['r_i'] + 0.1)\n\n    # ── 10. Baldwin effect proxy (QSO: emission line EW ∝ 1/luminosity) ───────\n    d['baldwin_proxy'] = d['abs_r'] * d['log1p_z']  # luminosity × redshift\n\n    # ── 11. Spectral type ordinal ─────────────────────────────────────────────\n    spec_order = {'O/B': 0, 'A/F': 1, 'G/K': 2, 'M': 3}\n    d['spec_num'] = d['spectral_type'].map(spec_order).fillna(-1).astype(int)\n    # Hot/cold star flags\n    d['is_hot_star']  = (d['spectral_type'].isin(['O/B','A/F'])).astype(int)\n    d['is_cool_star'] = (d['spectral_type'] == 'M').astype(int)\n\n    # ── 12. Galaxy population features ───────────────────────────────────────\n    d['is_red_seq']   = (d['galaxy_population'] == 'Red_Sequence').astype(int)\n    d['is_blue_cloud']= (d['galaxy_population'] == 'Blue_Cloud').astype(int)\n    d['is_green_val'] = (d['galaxy_population'] == 'Green_Valley').astype(int)\n    d['galpop_num']   = d['galaxy_population'].map(\n        {'Red_Sequence': 0, 'Green_Valley': 1, 'Blue_Cloud': 2}\n    ).fillna(-1).astype(int)\n\n    # ── 13. Cross-feature interactions ───────────────────────────────────────\n    # Redshift × color (high-z QSOs are blue)\n    d['z_x_ug']    = d['log1p_z'] * d['u_g']\n    d['z_x_gr']    = d['log1p_z'] * d['g_r']\n    d['z_x_ri']    = d['log1p_z'] * d['r_i']\n    d['z_x_iz']    = d['log1p_z'] * d['i_z']\n    d['z_x_slope'] = d['log1p_z'] * d['spectral_slope']\n    # Spectral type × color\n    d['spec_x_ug'] = d['spec_num'] * d['u_g']\n    d['spec_x_gr'] = d['spec_num'] * d['g_r']\n    d['spec_x_z']  = d['spec_num'] * d['log1p_z']\n    # Galaxy pop × redshift\n    d['gal_x_z']   = d['galpop_num'] * d['log1p_z']\n    # Hot stars should have low redshift (galactic)\n    d['hot_x_z']   = d['is_hot_star'] * d['log1p_z']\n    # r-band (optical) vs u-band (UV): color temperature proxy\n    d['color_temp_proxy'] = 10000 / (d['u_r'] + 5 + 1e-5)\n\n    # ── 14. Min-max band pair ratios ─────────────────────────────────────────\n    d['brightest_band_idx'] = mag_arr.argmin(axis=1)   # idx of lowest mag = brightest\n    d['dimmest_band_idx']   = mag_arr.argmax(axis=1)\n    d['peak_to_trough_ratio'] = (d['mag_range'] / (d['mag_mean'].abs() + 1e-5))\n\n    # ── 15. Log-transform raw bands for symmetry ─────────────────────────────\n    # Magnitudes are already log scale; take |band - median| to get deviation\n    for band in bands:\n        d[f'{band}_dev']    = d[band] - d['mag_median']\n        d[f'{band}_dev_sq'] = d[f'{band}_dev'] ** 2\n\n    return d\n\ntrain = grandmaster_features(train)\ntest  = grandmaster_features(test)\nprint(f\"Feature count after engineering: {train.shape[1]}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-16T05:34:06.059261Z","iopub.execute_input":"2026-06-16T05:34:06.059558Z","iopub.status.idle":"2026-06-16T05:41:01.156939Z","shell.execute_reply.started":"2026-06-16T05:34:06.059537Z","shell.execute_reply":"2026-06-16T05:41:01.156013Z"}},"outputs":[{"name":"stdout","text":"Feature count after engineering: 96\n","output_type":"stream"}],"execution_count":11},{"id":"c15e40f8-611a-4a51-a192-b7eb640532f1","cell_type":"code","source":"# ── Target encoding (leak-safe, KFold) ───────────────────────────────────────\nCAT_COLS = ['spectral_type', 'galaxy_population']\nTARGET   = 'class'\n\nle = LabelEncoder()\ny  = le.fit_transform(train[TARGET])\nprint('Classes:', le.classes_)\n\n# KFold target encoding for categorical columns\ndef kfold_target_encode(train_df, test_df, col, target, n_splits=10, seed=42):\n    \"\"\"Smooth mean-target encoding with KFold to avoid leakage.\"\"\"\n    global_mean = target.mean()\n    tr_enc = np.zeros(len(train_df))\n    skf = StratifiedKFold(n_splits=n_splits, shuffle=True, random_state=seed)\n    for tr_idx, val_idx in skf.split(train_df, target):\n        means = (train_df[col].iloc[tr_idx]\n                   .map(pd.Series(target[tr_idx]).groupby(\n                        train_df[col].iloc[tr_idx].values).mean())\n                   .fillna(global_mean))\n        tr_enc[val_idx] = train_df[col].iloc[val_idx].map(\n            pd.Series(target[tr_idx]).groupby(\n                train_df[col].iloc[tr_idx].values).mean()\n        ).fillna(global_mean)\n    te_means = train_df[col].map(\n        pd.Series(target).groupby(train_df[col].values).mean()\n    ).fillna(global_mean)\n    te_enc = test_df[col].map(\n        pd.Series(target).groupby(train_df[col].values).mean()\n    ).fillna(global_mean)\n    return tr_enc, te_enc.values\n\n# Encode for each class (one-vs-rest probability)\nfor c in CAT_COLS:\n    for cls_idx, cls_name in enumerate(le.classes_):\n        y_bin = (y == cls_idx).astype(float)\n        feat_name = f'{c}_te_{cls_name.lower()}'\n        tr_enc, te_enc = kfold_target_encode(train, test, c, y_bin)\n        train[feat_name] = tr_enc\n        test[feat_name]  = te_enc\n\nprint(f\"After target encoding: {train.shape[1]} features\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-16T05:41:01.158001Z","iopub.execute_input":"2026-06-16T05:41:01.159223Z","iopub.status.idle":"2026-06-16T05:41:09.590847Z","shell.execute_reply.started":"2026-06-16T05:41:01.159181Z","shell.execute_reply":"2026-06-16T05:41:09.590224Z"}},"outputs":[{"name":"stdout","text":"Classes: ['GALAXY' 'QSO' 'STAR']\nAfter target encoding: 102 features\n","output_type":"stream"}],"execution_count":12},{"id":"08492ba2-3165-4956-bc8d-1130cfc8f94c","cell_type":"code","source":"# ── Prepare feature matrices ─────────────────────────────────────────────────\nDROP = ['id', 'class'] + CAT_COLS   # keep numerics only for LGBM/XGB\n\nX       = train.drop(columns=[c for c in DROP if c in train.columns])\ntest_ids = test['id'].copy()\nX_test   = test.drop(columns=[c for c in DROP if 'id' in [c] or c in ['id'] + CAT_COLS\n                                and c in test.columns], errors='ignore')\n# Align columns\nX_test = test[[c for c in X.columns if c in test.columns]]\n# Fill any missing cols with 0\nfor c in X.columns:\n    if c not in X_test.columns:\n        X_test[c] = 0\nX_test = X_test[X.columns]\n\n# For CatBoost keep string categoricals too\nX_cat      = train.drop(columns=[c for c in ['id','class'] if c in train.columns])\nX_test_cat = test.drop(columns=[c for c in ['id'] if c in test.columns], errors='ignore')\nfor c in X_cat.columns:\n    if c not in X_test_cat.columns:\n        X_test_cat[c] = 0\nX_test_cat = X_test_cat[X_cat.columns]\n\nprint(\"X shape:\", X.shape)\nprint(\"X_test shape:\", X_test.shape)\nprint(\"X_cat shape:\", X_cat.shape)\n\n# Ensure numeric dtype for X / X_test\nX      = X.astype(np.float32)\nX_test = X_test.astype(np.float32)\n\n# Replace inf / -inf\nX.replace([np.inf, -np.inf], np.nan, inplace=True)\nX_test.replace([np.inf, -np.inf], np.nan, inplace=True)\nX.fillna(X.median(), inplace=True)\nX_test.fillna(X_test.median(), inplace=True)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-16T05:41:09.59253Z","iopub.execute_input":"2026-06-16T05:41:09.592776Z","iopub.status.idle":"2026-06-16T05:41:12.535486Z","shell.execute_reply.started":"2026-06-16T05:41:09.592755Z","shell.execute_reply":"2026-06-16T05:41:12.534851Z"}},"outputs":[{"name":"stdout","text":"X shape: (577347, 98)\nX_test shape: (247435, 98)\nX_cat shape: (577347, 100)\n","output_type":"stream"}],"execution_count":13},{"id":"2576872d-5198-4f13-bb5a-abc100991895","cell_type":"markdown","s