ex(drop=True)\n\n# ── 4. Combined normalised ranking ───────────────────────────────────────────\ndef normalise(series):\n    mn, mx = series.min(), series.max()\n    return (series - mn) / (mx - mn) if mx > mn else series * 0\n\ncombined = (\n    cat_imp.set_index('Feature')['CatBoost']\n    .rename('cat')\n    .to_frame()\n    .join(lgbm_imp.set_index('Feature')['LightGBM'].rename('lgbm'), how='outer')\n    .join(xgb_imp.set_index('Feature')['XGBoost'].rename('xgb'),   how='outer')\n    .fillna(0)\n)\ncombined['norm_cat']  = normalise(combined['cat'])\ncombined['norm_lgbm'] = normalise(combined['lgbm'])\ncombined['norm_xgb']  = normalise(combined['xgb'])\ncombined['mean_score'] = combined[['norm_cat','norm_lgbm','norm_xgb']].mean(axis=1)\ncombined = combined.sort_values('mean_score', ascending=False)\n\nTOP_N = 20\n\n# ── 5. Plot ───────────────────────────────────────────────────────────────────\nfig = plt.figure(figsize=(18, 14))\ngs  = gridspec.GridSpec(2, 2, figure=fig, hspace=0.45, wspace=0.35)\n\nCOLORS = {'CatBoost': '#4C72B0', 'LightGBM': '#55A868', 'XGBoost': '#C44E52', 'Combined': '#8172B2'}\n\ndef bar_plot(ax, df, feat_col, val_col, color, title):\n    top = df.head(TOP_N).copy()\n    ax.barh(top[feat_col][::-1], top[val_col][::-1], color=color, edgecolor='white', linewidth=0.5)\n    ax.set_title(title, fontsize=13, fontweight='bold', pad=8)\n    ax.set_xlabel('Importance Score', fontsize=10)\n    ax.tick_params(axis='y', labelsize=9)\n    ax.spines[['top','right']].set_visible(False)\n    for spine in ['left','bottom']:\n        ax.spines[spine].set_linewidth(0.8)\n\n# CatBoost\nbar_plot(fig.add_subplot(gs[0, 0]),\n         cat_imp, 'Feature', 'CatBoost',\n         COLORS['CatBoost'], 'CatBoost – Feature Importance')\n\n# LightGBM\nbar_plot(fig.add_subplot(gs[0, 1]),\n         lgbm_imp, 'Feature', 'LightGBM',\n         COLORS['LightGBM'], 'LightGBM – Gain Importance')\n\n# XGBoost\nbar_plot(fig.add_subplot(gs[1, 0]),\n         xgb_imp, 'Feature', 'XGBoost',\n         COLORS['XGBoost'], 'XGBoost – Gain Importance')\n\n# Combined normalised\nax_comb = fig.add_subplot(gs[1, 1])\ntop_comb = combined.head(TOP_N).reset_index()\nax_comb.barh(top_comb['Feature'][::-1], top_comb['mean_score'][::-1],\n             color=COLORS['Combined'], edgecolor='white', linewidth=0.5)\nax_comb.set_title('Combined Normalised Score\\n(average across all 3 models)', fontsize=13, fontweight='bold', pad=8)\nax_comb.set_xlabel('Mean Normalised Importance', fontsize=10)\nax_comb.tick_params(axis='y', labelsize=9)\nax_comb.spines[['top','right']].set_visible(False)\n\nfig.suptitle('Feature Importance – Stellar Classification', fontsize=16, fontweight='bold', y=1.01)\nplt.savefig('feature_importance.png', dpi=150, bbox_inches='tight')\nplt.show()\nprint(\"\\nTop 10 features (combined ranking):\")\nprint(combined[['norm_cat','norm_lgbm','norm_xgb','mean_score']].head(10).round(4).to_string())\n","metadata":{"trusted":true,"execution":{"execution_failed":"2026-06-15T07:20:57.479Z"}},"outputs":[],"execution_count":null},{"id":"b3e33680-579b-4afd-920b-2cb399177bf6","cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}