output_type":"stream"}],"execution_count":30},{"cell_type":"markdown","source":"## 4. Part B — Slot Filler (BERT Token Classification / NER)\n\nThis model reads each token in the utterance and tags it as `B-TIME`, `I-TIME`, `B-FOOD`, `I-FOOD`, `B-LOC`, `I-LOC`, or `O` (outside any slot).\n\n### Why BIO tagging?\nBIO (Beginning-Inside-Outside) is the standard format for NER. Each word gets one tag:\n- `B-FOOD` = first word of a food entity  \n- `I-FOOD` = continuation of a food entity  \n- `O`      = not an entity","metadata":{}},{"cell_type":"code","source":"# ── BIO tag builder ─────────────────────────────────────────────────────────\ndef make_bio_tags(text, time_val, food_val, loc_val):\n    \"\"\"\n    Given a sentence and slot values, produce word-level BIO tags.\n    Simple substring matching — works well for this dataset.\n    \"\"\"\n    words = text.lower().split()\n    tags  = ['O'] * len(words)\n\n    def tag_span(slot_value, prefix):\n        if not slot_value:\n            return\n        slot_words = slot_value.lower().split()\n        n = len(slot_words)\n        for i in range(len(words) - n + 1):\n            if words[i:i+n] == slot_words:\n                tags[i] = f'B-{prefix}'\n                for j in range(1, n):\n                    tags[i+j] = f'I-{prefix}'\n\n    tag_span(time_val, 'TIME')\n    tag_span(food_val, 'FOOD')\n    tag_span(loc_val,  'LOC')\n    return words, tags\n\n# Test it\nwords, tags = make_bio_tags(\n    \"Order a burger at 9pm near mall\",\n    time_val=\"9pm\", food_val=\"burger\", loc_val=\"near mall\"\n)\nprint(list(zip(words, tags)))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:01:58.763979Z","iopub.execute_input":"2026-06-21T12:01:58.764375Z","iopub.status.idle":"2026-06-21T12:01:58.774408Z","shell.execute_reply.started":"2026-06-21T12:01:58.764304Z","shell.execute_reply":"2026-06-21T12:01:58.773402Z"}},"outputs":[{"name":"stdout","text":"[('order', 'O'), ('a', 'O'), ('burger', 'B-FOOD'), ('at', 'O'), ('9pm', 'B-TIME'), ('near', 'B-LOC'), ('mall', 'I-LOC')]\n","output_type":"stream"}],"execution_count":31},{"cell_type":"code","source":"# ── Build NER dataset ────────────────────────────────────────────────────────\nNER_LABELS = ['O', 'B-TIME', 'I-TIME', 'B-FOOD', 'I-FOOD', 'B-LOC', 'I-LOC']\nner_label2id = {l: i for i, l in enumerate(NER_LABELS)}\nner_id2label = {i: l for i, l in enumerate(NER_LABELS)}\n\ndef build_ner_rows(row):\n    words, tags = make_bio_tags(\n        row['text'], row['time'], row['food_item'], row['location']\n    )\n    return {'words': words, 'ner_tags': [ner_label2id[t] for t in tags]}\n\nner_rows = df.apply(build_ner_rows, axis=1).tolist()\nner_df   = pd.DataFrame(ner_rows)\n\nprint(f\"NER dataset rows: {len(ner_df)}\")\nprint(ner_df.head(3))","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:01:58.775719Z","iopub.execute_input":"2026-06-21T12:01:58.776013Z","iopub.status.idle":"2026-06-21T12:01:58.829364Z","shell.execute_reply.started":"2026-06-21T12:01:58.775976Z","shell.execute_reply":"2026-06-21T12:01:58.828161Z"}},"outputs":[{"name":"stdout","text":"NER dataset rows: 1200\n                                            words                     ner_tags\n0         [hi,, order, food, for, me, right, now]        [0, 0, 0, 0, 0, 0, 0]\n1                              [hi,, hi, quickly]                    [0, 0, 0]\n2  [hello,, table, for, 4, at, 8, pm, right, now]  [0, 0, 0, 0, 0, 1, 2, 0, 0]\n","output_type":"stream"}],"execution_count":32},{"cell_type":"code","source":"from transformers import BertForTokenClassification, DataCollatorForTokenClassification\n\n# ── Train / Val split ────────────────────────────────────────────────────────\nner_train_df, ner_val_df = train_test_split(ner_df, test_size=0.15, random_state=42)\n\nner_train_ds = Dataset.from_pandas(ner_train_df.reset_index(drop=True))\nner_val_ds   = Dataset.from_pandas(ner_val_df.reset_index(drop=True))\n\n# ── Tokenize with word → subword alignment ───────────────────────────────────\ndef tokenize_and_align_labels(batch):\n    tokenized_inputs = tokenizer(\n        batch['words'],\n        truncation=True,\n        max_length=64,\n        is_split_into_words=True,   # critical: input is already word-split\n    )\n    all_labels = []\n    for i, label in enumerate(batch['ner_tags']):\n        word_ids = tokenized_inputs.word_ids(batch_index=i)\n        prev_word_id = None\n        label_ids = []\n        for word_id in word_ids:\n            if word_id is None:\n                label_ids.append(-100)      # [CLS] / [SEP] tokens — ignored in loss\n            elif word_id != prev_word_id:\n                label_ids.append(label[word_id])\n            else:\n                label_ids.append(-100)      # subsequent subword tokens — ignored\n            prev_word_id = word_id\n        all_labels.append(label_ids)\n    tokenized_inputs['labels'] = all_labels\n    return tokenized_inputs\n\nner_train_tok = ner_train_ds.map(tokenize_and_align_labels, batched=True,\n                                  remove_columns=['words', 'ner_tags'])\nner_val_tok   = ner_val_ds.map(tokenize_and_align_labels, batched=True,\n                                remove_columns=['words', 'ner_tags'])\nner_train_tok.set_format('torch')\nner_val_tok.set_format('torch')\n\nprint(\"NER tokenized:\", ner_train_tok)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:01:58.830601Z","iopub.execute_input":"2026-06-21T12:01:58.831036Z","iopub.status.idle":"2026-06-21T12:01:59.311689Z","shell.execute_reply.started":"2026-06-21T12:01:58.831002Z","shell.execute_reply":"2026-06-21T12:01:59.310533Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Map:   0%|          | 0/1020 [00:00<?, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"f731273bb8b2440fb5c0214a1895b944"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Map:   0%|          | 0/180 [00:00<?, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"2fc80e0d852b40178f7818b2abfdc1e7"}},"metadata":{}},{"name":"stdout","text":"NER tokenized: Dataset({\n    features: ['input_ids', 'token_type_ids', 'attention_mask', 'labels'],\n    num_rows: 1020\n})\n","output_type":"stream"}],"execution_count":33},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import numpy as np\nimport torch\nimport evaluate\n\nfrom transformers import (\n    BertForTokenClassification,\n    TrainingArguments,\n    Trainer,\n    DataCollatorForTokenClassification\n)\n\n# ── Metrics ─────────────────────────────────────────────────────────────────\nseqeval = evaluate.load(\"seqeval\")\n\ndef compute_ner_metrics(eval_pred):\n    logits, labels = eval_pred\n\n    predictions = np.argmax(logits, axis=-1)\n\n    true_predictions = []\n    true_labels = []\n\n    for prediction_row, label_row in zip(predictions, labels):\n        filtered_predictions = []\n        filtered_labels = []\n\n        for prediction_id, label_id in zip(prediction_row, label_row):\n            if label_id != -100:\n                filtered_predictions.append(ner_id2label[prediction_id])\n                filtered_labels.append(ner_id2label[label_id])\n\n        true_predictions.append(filtered_predictions)\n        true_labels.append(filtered_labels)\n\n    results = seqeval.compute(\n        predictions=true_predictions,\n        references=true_labels\n    )\n\n    return {\n        \"precision\": results[\"overall_precision\"],\n        \"recall\": results[\"overall_recall\"],\n        \"f1\": results[\"overall_f1\"],\n        \"accuracy\": results[\"overall_accuracy\"],\n    }\n\n# ── Model ───────────────────────────────────────────────────────────────────\nner_model = BertForTokenClassification.from_pretrained(\n    \"bert-base-uncased\",\n    num_labels=len(NER_LABELS),\n    id2label=ner_id2label,\n    label2id=ner_label2id,\n)\n\n# ── Training arguments ──────────────────────────────────────────────────────\nner_args = TrainingArguments(\n    output_dir=\"./ner_model\",\n\n    num_train_epochs=10,\n    learning_rate=3e-5,\n    weight_decay=0.01,\n    warmup_ratio=0.1,\n\n    per_device_train_batch_size=16,\n    per_device_eval_batch_size=32,\n\n    eval_strategy=\"epoch\",\n    save_strategy=\"epoch\",\n\n    load_best_model_at_end=False, # Fix: must be False when save_strategy='no'\n    metric_for_best_model=\"f1\",\n    greater_is_better=True,\n\n    logging_steps=20,\n    fp16=torch.cuda.is_available(),\n\n    report_to=\"none\",\n    seed=42\n)\n\n# ── Trainer ─────────────────────────────────────────────────────────────────\nner_trainer = Trainer(\n    model=ner_model,\n    args=ner_args,\n\n    train_dataset=ner_train_tok,\n    eval_dataset=ner_val_tok,\n\n    processing_class=tokenizer,\n    data_collator=DataCollatorForTokenClassification(tokenizer=tokenizer),\n\n    compute_metrics=compute_ner_metrics,\n)\n\nprint(\"Training on:\", \"GPU\" if torch.cuda.is_available() else \"CPU\")\n\nner_trainer.train()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:05:34.286243Z","iopub.execute_input":"2026-06-21T12:05:34.286684Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/197 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"d357821166274674b50027d825e540e9"}},"metadata":{}},{"name":"stderr","text":"BertForTokenClassification LOAD REPORT from: bert-base-uncased\nKey                                        | Status     | \n-------------------------------------------+------------+-\ncls.predictions.transform.LayerNorm.bias   | UNEXPECTED | \nbert.pooler.dense.weight                   | UNEXPECTED | \ncls.seq_relationship.bias                  | UNEXPECTED | \ncls.seq_relationship.we