ning_rate=2e-5,\n    weight_decay=0.01,\n    warmup_ratio=0.1,\n\n    per_device_train_batch_size=16,\n    per_device_eval_batch_size=32,\n\n    eval_strategy=\"epoch\",\n    save_strategy=\"epoch\",\n\n    load_best_model_at_end=True,\n    metric_for_best_model=\"f1\",\n    greater_is_better=True,\n\n    logging_steps=20,\n    fp16=torch.cuda.is_available(),\n\n    report_to=\"none\",\n    seed=42\n)\n\n# ── Trainer ─────────────────────────────────────────────────────────────────\nintent_trainer = Trainer(\n    model=intent_model,\n    args=intent_args,\n\n    train_dataset=tokenized[\"train\"],\n    eval_dataset=tokenized[\"validation\"],\n\n    processing_class=tokenizer,\n    data_collator=DataCollatorWithPadding(tokenizer=tokenizer),\n\n    compute_metrics=compute_intent_metrics,\n)\n\nprint(\"Training on:\", \"GPU\" if torch.cuda.is_available() else \"CPU\")\n\nintent_trainer.train()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T10:22:02.416148Z","iopub.execute_input":"2026-06-21T10:22:02.416542Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/199 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"36ba2abd88f84c539c600588c5c4a4dc"}},"metadata":{}},{"name":"stderr","text":"BertForSequenceClassification LOAD REPORT from: bert-base-uncased\nKey                                        | Status     | \n-------------------------------------------+------------+-\ncls.predictions.transform.LayerNorm.bias   | UNEXPECTED | \ncls.seq_relationship.bias                  | UNEXPECTED | \ncls.seq_relationship.weight                | UNEXPECTED | \ncls.predictions.transform.LayerNorm.weight | UNEXPECTED | \ncls.predictions.bias                       | UNEXPECTED | \ncls.predictions.transform.dense.weight     | UNEXPECTED | \ncls.predictions.transform.dense.bias       | UNEXPECTED | \nclassifier.weight                          | MISSING   