ds_output.label_ids\n\nprint(classification_report(\n    true_labels, pred_labels,\n    target_names=le.classes_\n))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Save intent model ────────────────────────────────────────────────────────\nintent_trainer.save_model('./restaurant_intent_model')\ntokenizer.save_pretrained('./restaurant_intent_model')\nprint(\"Intent model saved.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 4. Part B — Slot Filler (BERT Token Classification / NER)\n\nThis model reads each token in the utterance and tags it as `B-TIME`, `I-TIME`, `B-FOOD`, `I-FOOD`, `B-LOC`, `I-LOC`, or `O` (outside any slot).\n\n### Why BIO tagging?\nBIO (Beginning-Inside-Outside) is the standard format for NER. Each word gets one tag:\n- `B-FOOD` = first word of a food entity  \n- `I-FOOD` = continuation of a food entity  \n- `O`      = not an entity","metadata":{}},{"cell_type":"code","source":"# ── BIO tag builder ─────────────────────────────────────────────────────────\ndef make_bio_tags(text, time_val, food_val, loc_val):\n    \"\"\"\n    Given a sentence and slot values, produce word-level BIO tags.\n    Simple substring matching — works well for this dataset.\n    \"\"\"\n    words = text.lower().split()\n    tags  = ['O'] * len(words)\n\n    def tag_span(slot_value, prefix):\n        if not slot_value:\n            return\n        slot_words = slot_value.lower().split()\n        n = len(slot_words)\n        for i in range(len(words) - n + 1):\n            if words[i:i+n] == slot_words:\n                tags[i] = f'B-{prefix}'\n                for j in range(1, n):\n                    tags[i+j] = f'I-{prefix}'\n\n    tag_span(time_val, 'TIME')\n    tag_span(food_val, 'FOOD')\n    tag_span(loc_val,  'LOC')\n    return words, tags\n\n# Test it\nwords, tags = make_bio_tags(\n    \"Order a burger at 9pm near mall\",\n    time_val=\"9pm\", food_val=\"burger\", loc_val=\"near mall\"\n)\nprint(list(zip(words, tags)))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Build NER dataset ────────────────────────────────────────────────────────\nNER_LABELS = ['O', 'B-TIME', 'I-TIME', 'B-FOOD', 'I-FOOD', 'B-LOC', 'I-LOC']\nner_label2id = {l: i for i, l in enumerate(NER_LABELS)}\nner_id2label = {i: l for i, l in enumerate(NER_LABELS)}\n\ndef build_ner_rows(row):\n    words, tags = make_bio_tags(\n        row['text'], row['time'], row['food_item'], row['location']\n    )\n    return {'words': words, 'ner_tags': [ner_label2id[t] for t in tags]}\n\nner_rows = df.apply(build_ner_rows, axis=1).tolist()\nner_df   = pd.DataFrame(ner_rows)\n\nprint(f\"NER dataset rows: {len(ner_df)}\")\nprint(ner_df.head(3))","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"from transformers import BertForTokenClassification, DataCollatorForTokenClassification\n\n# ── Train / Val split ────────────────────────────────────────────────────────\nner_train_df, ner_val_df = train_test_split(ner_df, test_size=0.15, random_state=42)\n\nner_train_ds = Dataset.from_pandas(ner_train_df.reset_index(drop=True))\nner_val_ds   = Dataset.from_pandas(ner_val_df.reset_index(drop=True))\n\n# ── Tokenize with word → subword alignment ───────────────────────────────────\ndef tokenize_and_align_labels(batch):\n    tokenized_inputs = tokenizer(\n        batch['words'],\n        truncation=True,\n        max_length=64,\n        is_split_into_words=True,   # critical: input is already word-split\n    )\n    all_labels = []\n    for i, label in enumerate(batch['ner_tags']):\n        word_ids = tokenized_inputs.word_ids(batch_index=i)\n        prev_word_id = None\n        label_ids = []\n        for word_id in word_ids:\n            if word_id is None:\n                label_ids.append(-100)      # [CLS] / [SEP] tokens — ignored in loss\n            elif word_id != prev_word_id:\n                label_ids.append(label[word_id])\n            else:\n                label_ids.append(-100)      # subsequent subword tokens — ignored\n            prev_word_id = word_id\n        all_labels.append(label_ids)\n    tokenized_inputs['labels'] = all_labels\n    return tokenized_inputs\n\nner_train_tok = ner_train_ds.map(tokenize_and_align_labels, batched=True,\n                                  remove_columns=['words', 'ner_tags'])\nner_val_tok   = ner_val_ds.map(tokenize_and_align_labels, batched=True,\n                                remove_columns=['words', 'ner_tags'])\nner_train_tok.set_format('torch')\nner_val_tok.set_format('torch')\n\nprint(\"NER tokenized:\", ner_train_tok)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"seqeval = evaluate.load('seqeval')\n\ndef compute_ner_metrics(eval_pred):\n    logits, labels = eval_pred\n    preds = np.argmax(logits, axis=-1)\n    true_preds, true_labels = [], []\n    for pred_row, label_row in zip(preds, labels):\n        true_preds.append([ner_id2label[p] for p, l in zip(pred_row, label_row) if l != -100])\n        true_labels.append([ner_id2label[l] for l in label_row if l != -100])\n    results = seqeval.compute(predictions=true_preds, references=true_labels)\n    return {\n        'precision': results['overall_precision'],\n        'recall':    results['overall_recall'],\n        'f1':        results['overall_f1'],\n        'accuracy':  results['overall_accuracy'],\n    }\n\nner_model = BertForTokenClassification.from_pretrained(\n    'bert-base-uncased',\n    num_labels=len(NER_LABELS),\n    id2label=ner_id2label,\n    label2id=ner_label2id,\n)\n\nner_args = TrainingArguments(\n    output_dir='./ner_model',\n    num_train_epochs=10,\n    per_device_train_batch_size=16,\n    per_device_eval_batch_size=32,\n    learning_rate=3e-5,\n    weight_decay=0.01,\n    warmup_ratio=0.1,\n    evaluation_strategy='epoch',\n    save_strategy='epoch',\n    load_best_model_at_end=True,\n    metric_for_best_model='f1',\n    logging_steps=20,\n    fp16=torch.cuda.is_available(),\n    report_to='none',\n)\n\nner_trainer = Trainer(\n    model=ner_model,\n    args=ner_args,\n    train_dataset=ner_train_tok,\n    eval_dataset=ner_val_tok,\n    tokenizer=tokenizer,\n    data_collator=DataCollatorForTokenClassification(tokenizer),\n    compute_metrics=compute_ner_metrics,\n)\n\nner_trainer.train()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"ner_results = ner_trainer.evaluate()\nprint(f\"\\n✅ NER Precision : {ner_results['eval_precision']:.4f}\")\nprint(f\"✅ NER Recall    : {ner_results['eval_recall']:.4f}\")\nprint(f\"✅ NER F1        : {ner_results['eval_f1']:.4f}\")\n\nner_trainer.save_model('./restaurant_ner_model')\nprint(\"NER model saved.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 5. Inference — Joint Pipeline\n\nWire both models together into a single `predict()` function that takes a raw utterance and returns a clean structured dict.","metadata":{}},{"cell_type":"code","source":"from transformers import pipeline as hf_pipeline\n\n# ── Load both fine-tuned models ───────────────────────────────────────────────\nintent_pipe = hf_pipeline(\n    'text-classification',\n    model='./restaurant_intent_model',\n    tokenizer='./restaurant_intent_model',\n    device=0 if torch.cuda.is_available() else -1,\n)\n\nner_pipe = hf_pipeline(\n    'token-classification',\n    model='./restaurant_ner_model',\n    tokenizer='./restaurant_ner_model',\n    aggregation_strategy='simple',   # merges B/I tokens into one span\n    device=0 if torch.cuda.is_available() else -1,\n)\n\nprint(\"Both pipelines loaded ✅\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def predict(utterance: str) -> dict:\n    \"\"\"\n    Run a user utterance through both models and return a structured result.\n    \n    Returns:\n        {\n          'text':      original utterance,\n          'intent':    predicted intent label,\n          'confidence': float (0-1),\n          'slots': {\n            'time':      extracted time string or None,\n            'food_item': extracted food string or None,\n            'location':  extracted location string or None,\n          }\n        }\n    \"\"\"\n    # Intent\n    intent_out  = intent_pipe(utterance)[0]\n    intent_label = intent_out['label']\n    intent_score = round(intent_out['score'], 4)\n\n    # Slots\n    ner_out = ner_pipe(utterance)\n    slots = {'time': None, 'food_item': None, 'location': None}\n    label_map = {'TIME': 'time', 'FOOD': 'food_item', 'LOC': 'location'}\n    for span in ner_out:\n        key = label_map.get(span['entity_group'])\n        if key:\n            slots[key] = span['word'].strip()\n\n    return {\n        'text':       utterance,\n        'intent':     intent_label,\n        'confidence': intent_score,\n        'slots':      slots,\n    }\n\nprint(\"predict() ready.\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import json\n\n# ── Test with examples ────────────────────────────────────────────────────────\ntest_cases = [\n    \"want a burger at 7pm today\",\n    \"Table for 4 at 8 PM near mall\",\n    \"Hi, Order food for me right now\",\n    \"I want to cancel my reservation please\",\n    \"Is my pizza ready? I ordered 30 minutes ago\",\n    \"Do you have pasta available downtown?\",\n]\n\nfor utterance in test_cases:\n    result = predict(utterance)\n    print(json.dumps(result, indent=2))\n    print(\"-\" * 50)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 6. (Optional) Push to Hugging Face Hub","metadata":{}},{"cell_type":"code","source":"# Uncomment and set your HF username first\nfrom huggingface_hub import notebook_login\nnotebook_login()\n\nintent_trainer.push_to_hub('Shreyansh234/restaurant-intent-bert')\nner_trainer.push_to_hub('Shreyansh234/restaurant-ner-bert')","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 7. Summary & Expected Results\n\n| Model | Task | Expected Val F1 |\n|---|---|---|\n| `BertForSequenceClassification` | Intent (6 classes) | 0.93 – 0.98 |\n| `BertForTokenClassification` | Slot filling (NER) | 0.88 – 0.95 |\n\n### Why so much better than GPT-2?\n- **BERT is an encoder** — it reads the whole sentence bidirectionally before making a decision, which is exactly what classification needs.\n- **GPT-2 is a decoder** — it predicts the next token given past tokens, which is what text *generation* needs, not classification.\n- Using the right metric (accuracy / F1 instead of perplexity) gives you a meaningful, interpretable score.\n\n### If you want even higher accuracy:\n- Swap `bert-base-uncased` → `roberta-base` (usually +1–2% F1)\n- Add data augmentation (paraphrase your training sentences)\n- Use a joint multi-task model that shares a BERT encoder and has two separate classification heads","metadata":{}},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}