":"stream"}],"execution_count":24},{"cell_type":"markdown","source":"## 3. Part A — Intent Classifier (BERT Sequence Classification)\n\nThis model maps a raw utterance → one of 6 intent labels.","metadata":{}},{"cell_type":"code","source":"from sklearn.model_selection import train_test_split\nfrom sklearn.preprocessing import LabelEncoder\nfrom datasets import Dataset, DatasetDict\nfrom transformers import (\n    BertTokenizerFast,\n    BertForSequenceClassification,\n    TrainingArguments,\n    Trainer,\n    DataCollatorWithPadding,\n)\nimport evaluate\nimport torch\n\n# ── Label encoding ──────────────────────────────────────────────────────────\nle = LabelEncoder()\ndf['label'] = le.fit_transform(df['intent'])\nlabel2id = {label: int(idx) for idx, label in enumerate(le.classes_)}\nid2label = {int(idx): label for idx, label in enumerate(le.classes_)}\n\nprint(\"Intent label map:\", label2id)\n\n# ── Train / Val split ───────────────────────────────────────────────────────\ntrain_df, val_df = train_test_split(\n    df[['text', 'label']], test_size=0.15, random_state=42, stratify=df['label']\n)\n\ntrain_dataset = Dataset.from_pandas(train_df.reset_index(drop=True))\nval_dataset   = Dataset.from_pandas(val_df.reset_index(drop=True))\n\ndataset_dict = DatasetDict({'train': train_dataset, 'validation': val_dataset})\nprint(dataset_dict)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T11:47:54.502004Z","iopub.execute_input":"2026-06-21T11:47:54.502405Z","iopub.status.idle":"2026-06-21T11:47:54.575027Z","shell.execute_reply.started":"2026-06-21T11:47:54.502367Z","shell.execute_reply":"2026-06-21T11:47:54.5739Z"}},"outputs":[{"name":"stdout","text":"Intent label map: {'cancel': 0, 'complaint': 1, 'greeting': 2, 'order': 3, 'query': 4, 'reservation': 5}\nDatasetDict({\n    train: Dataset({\n        features: ['text', 'label'],\n        num_rows: 1020\n    })\n    validation: Dataset({\n        features: ['text', 'label'],\n        num_rows: 180\n    })\n})\n","output_type":"stream"}],"execution_count":25},{"cell_type":"code","source":"# ── Tokenize ────────────────────────────────────────────────────────────────\ntokenizer = BertTokenizerFast.from_pretrained('bert-base-uncased')\n\ndef tokenize_fn(batch):\n    return tokenizer(\n        batch['text'],\n        truncation=True,\n        padding=False,   # DataCollator handles dynamic padding\n        max_length=64,\n    )\n\ntokenized = dataset_dict.map(tokenize_fn, batched=True)\ntokenized = tokenized.remove_columns(['text'])\ntokenized.set_format('torch')\n\nprint(\"Tokenized dataset:\", tokenized)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T11:47:54.578088Z","iopub.execute_input":"2026-06-21T11:47:54.578462Z","iopub.status.idle":"2026-06-21T11:47:55.783899Z","shell.execute_reply.started":"2026-06-21T11:47:54.578432Z","shell.execute_reply":"2026-06-21T11:47:55.782813Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Map:   0%|          | 0/1020 [00:00<?, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"00789d1638464f16bdf8d59550a7bf65"}},"metadata":{}},{"output_type":"display_data","data":{"text/plain":"Map:   0%|          | 0/180 [00:00<?, ? examples/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"1069db5544b844ce9f409775c81f894b"}},"metadata":{}},{"name":"stdout","text":"Tokenized dataset: DatasetDict({\n    train: Dataset({\n        features: ['label', 'input_ids', 'token_type_ids', 'attention_mask'],\n        num_rows: 1020\n    })\n    validation: Dataset({\n        features: ['label', 'input_ids', 'token_type_ids', 'attention_mask'],\n        num_rows: 180\n    })\n})\n","output_type":"stream"}],"execution_count":26},{"cell_type":"code","source":"import numpy as np\nimport torch\nimport evaluate\n\nfrom transformers import (\n    BertForSequenceClassification,\n    TrainingArguments,\n    Trainer,\n    DataCollatorWithPadding\n)\n\n# ── Model ───────────────────────────────────────────────────────────────────\nintent_model = BertForSequenceClassification.from_pretrained(\n    \"bert-base-uncased\",\n    num_labels=len(label2id),\n    id2label=id2label,\n    label2id=label2id,\n)\n\n# ── Metrics ─────────────────────────────────────────────────────────────────\naccuracy_metric = evaluate.load(\"accuracy\")\nf1_metric = evaluate.load(\"f1\")\n\ndef compute_intent_metrics(eval_pred):\n    logits, labels = eval_pred\n\n    predictions = np.argmax(logits, axis=-1)\n\n    accuracy = accuracy_metric.compute(\n        predictions=predictions,\n        references=labels\n    )\n\n    f1 = f1_metric.compute(\n        predictions=predictions,\n        references=labels,\n        average=\"weighted\"\n    )\n\n    return {\n        \"accuracy\": accuracy[\"accuracy\"],\n        \"f1\": f1[\"f1\"]\n    }\n\n# ── Training arguments ──────────────────────────────────────────────────────\nintent_args = TrainingArguments(\n    output_dir=\"./intent_model\",\n\n    num_train_epochs=8,\n    learning_rate=2e-5,\n    weight_decay=0.01,\n    warmup_ratio=0.1,\n\n    per_device_train_batch_size=16,\n    per_device_eval_batch_size=32,\n\n    eval_strategy=\"epoch\",\n    save_strategy=\"epoch\",\n\n    load_best_model_at_end=False, # Fix: must be False when save_strategy='no'\n    metric_for_best_model=\"f1\",\n    greater_is_better=True,\n\n    logging_steps=20,\n    fp16=torch.cuda.is_available(),\n\n    report_to=\"none\",\n    seed=42\n)\n\n# ── Trainer ─────────────────────────────────────────────────────────────────\nintent_trainer = Trainer(\n    model=intent_model,\n    args=intent_args,\n\n    train_dataset=tokenized[\"train\"],\n    eval_dataset=tokenized[\"validation\"],\n\n    processing_class=tokenizer,\n    data_collator=DataCollatorWithPadding(tokenizer=tokenizer),\n\n    compute_metrics=compute_intent_metrics,\n)\n\nprint(\"Training on:\", \"GPU\" if torch.cuda.is_availab