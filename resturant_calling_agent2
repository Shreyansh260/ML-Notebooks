\n    output_dir=\"./ner_model\",\n\n    num_train_epochs=10,\n    learning_rate=3e-5,\n    weight_decay=0.01,\n    warmup_ratio=0.1,\n\n    per_device_train_batch_size=16,\n    per_device_eval_batch_size=32,\n\n    eval_strategy=\"epoch\",\n    save_strategy=\"epoch\",\n\n    load_best_model_at_end=True,\n    metric_for_best_model=\"f1\",\n    greater_is_better=True,\n\n    logging_steps=20,\n    fp16=torch.cuda.is_available(),\n\n    report_to=\"none\",\n    seed=42\n)\n\n# ── Trainer ─────────────────────────────────────────────────────────────────\nner_trainer = Trainer(\n    model=ner_model,\n    args=ner_args,\n\n    train_dataset=ner_train_tok,\n    eval_dataset=ner_val_tok,\n\n    processing_class=tokenizer,\n    data_collator=DataCollatorForTokenClassification(tokenizer=tokenizer),\n\n    compute_metrics=compute_ner_metrics,\n)\n\nprint(\"Training on:\", \"GPU\" if torch.cuda.is_available() else \"CPU\")\n\nner_trainer.train()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T10:37:16.195606Z","iopub.execute_input":"2026-06-21T10:37:16.197154Z","iopub.status.idle":"2026-06-21T10:50:14.642794Z","shell.execute_reply.started":"2026-06-21T10:37:16.197095Z","shell.execute_reply":"2026-06-21T10:50:14.640787Z"}},"outputs":[{"output_type":"display_data","data":{"text/plain":"Loading weights:   0%|          | 0/197 [00:00<?, ?it/s]","application/vnd.jupyter.widget-view+json":{"version_major":2,"version_minor":0,"model_id":"2823f86d1f6143738944fdcff643a7ec"}},"metadata":{}},{"name":"stderr","text":"BertForTokenClassification LOAD REPORT from: bert-base-uncased\nKey                                        | Status     | \n-------------------------------------------+------------+-\ncls.predictions.transform.LayerNorm.bias   | UNEXPECTED | \nbert.pooler.dense.weight                   | UNEXPECTED | \ncls.seq_relationship.bias                  | UNEXPECTED | \ncls.seq_relationship.weight                | UNEXPECTED | \nbert.pooler.dense.bias        