valuate.load(\"seqeval\")\n\ndef compute_ner_metrics(eval_pred):\n    logits, labels = eval_pred\n\n    predictions = np.argmax(logits, axis=-1)\n\n    true_predictions = []\n    true_labels = []\n\n    for prediction_row, label_row in zip(predictions, labels):\n        filtered_predictions = []\n        filtered_labels = []\n\n        for prediction_id, label_id in zip(prediction_row, label_row):\n            if label_id != -100:\n                filtered_predictions.append(ner_id2label[prediction_id])\n                filtered_labels.append(ner_id2label[label_id])\n\n        true_predictions.append(filtered_predictions)\n        true_labels.append(filtered_labels)\n\n    results = seqeval.compute(\n        predictions=true_predictions,\n        references=true_labels\n    )\n\n    return {\n        \"precision\": results[\"overall_precision\"],\n        \"recall\": results[\"overall_recall\"],\n        \"f1\": results[\"overall_f1\"],\n        \"accuracy\": results[\"overall_accuracy\"],\n    }\n\n# ── Model ───────────────────────────────────────────────────────────────────\nner_model = BertForTokenClassification.from_pretrained(\n    \"bert-base-uncased\",\n    num_labels=len(NER_LABELS),\n    id2label=ner_id2label,\n    label2id=ner_label2id,\n)\n\n# ── Training arguments ──────────────────────────────────────────────────────\nner_args = TrainingArguments(\n    output_dir=\"./ner_model\",\n\n    num_train_epochs=10,\n    learning_rate=3e-5,\n    weight_decay=0.01,\n    warmup_ratio=0.1,\n\n    per_device_train_batch_size=16,\n    per_device_eval_batch_size=32,\n\n    eval_strategy=\"epoch\",\n    save_strategy=\"epoch\",\n\n    load_best_model_at_end=False, # Fix: must be False when save_strategy='no'\n    metric_for_best_model=\"f1\",\n    greater_is_better=True,\n\n    logging_steps=20,\n    fp16=torch.cuda.is_available(),\n\n    report_to=\"none\",\n    seed=42\n)\n\n# ── Trainer ─────────────────────────────────────────────────────────────────\nner_trainer = Trainer(\n    model=ner_model,\n    args=ner_args,\n\n    train_dataset=ner_train_tok,\n    eval_dataset=ner_val_tok,\n\n    processing_class=tokenizer,\n    data_collator=DataCollatorForTokenClassification(tokenizer=tokenizer),\n\n    compute_metrics=compute_ner_metrics,\n)\n\nprint(\"Training on:\", \"GPU\" if torch.cuda.is_available() else \"CPU\")\n\nner_trainer.train()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:25:21.619823Z","iopub.status.idle":"2026-06-21T12:25:21.62014Z","shell.execute_reply.started":"2026-06-21T12:25:21.619985Z","shell.execute_reply":"2026-06-21T12:25:21.620002Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"ner_results = ner_trainer.evaluate()\nprint(f'\\n✅ NER Precision : {ner_results[\"eval_precision\"]:.4f}')\nprint(f'✅ NER Recall    : {ner_results[\"eval_recall\"]:.4f}')\nprint(f'✅ NER F1        : {ner_results[\"eval_f1\"]:.4f}')\n\n# Fix: safe save — safetensors format\nsave_dir = '/kaggle/working/restaurant_ner_model'\nif os.path.exists(save_dir):\n    shutil.rmtree(save_dir)\nos.makedirs(save_dir, exist_ok=True)\n\nner_model.save_pretrained(save_dir, safe_serialization=True)\ntokenizer.save_pretrained(save_dir)\nprint('NER model saved to', save_dir)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:25:21.621754Z","iopub.status.idle":"2026-06-21T12:25:21.622238Z","shell.execute_reply.started":"2026-06-21T12:25:21.621987Z","shell.execute_reply":"2026-06-21T12:25:21.622016Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 5. Inference — Joint Pipeline\n\nWire both models together into a single `predict()` function that takes a raw utterance and returns a clean structured dict.","metadata":{}},{"cell_type":"code","source":"from transformers import pipeline as hf_pipeline\n\n# ── Load both fine-tuned models ───────────────────────────────────────────────\nintent_pipe = hf_pipeline(\n    'text-classification',\n    model='/kaggle/working/restaurant_intent_model',\n    tokenizer='/kaggle/working/restaurant_intent_model',\n    device=0 if torch.cuda.is_available() else -1,\n)\n\nner_pipe = hf_pipeline(\n    'token-classification',\n    model='/kaggle/working/restaurant_ner_model',\n    tokenizer='/kaggle/working/restaurant_ner_model',\n    aggregation_strategy='simple',   # merges B/I tokens into one span\n    device=0 if torch.cuda.is_available() else -1,\n)\n\nprint(\"Both pipelines loaded ✅\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:25:21.623884Z","iopub.status.idle":"2026-06-21T12:25:21.624287Z","shell.execute_reply.started":"2026-06-21T12:25:21.624077Z","shell.execute_reply":"2026-06-21T12:25:21.624146Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def predict(utterance: str) -> dict:\n    \"\"\"\n    Run a user utterance through both models and return a structured result.\n    \n    Returns:\n        {\n          'text':      original utterance,\n          'intent':    predicted intent label,\n          'confidence': float (0-1),\n          'slots': {\n            'time':      extracted time string or None,\n            'food_item': extracted food string or None,\n            'location':  extracted location string or None,\n          }\n        }\n    \"\"\"\n    # Intent\n    intent_out  = intent_pipe(utterance)[0]\n    intent_label = intent_out['label']\n    intent_score = round(intent_out['score'], 4)\n\n    # Slots\n    ner_out = ner_pipe(utterance)\n    slots = {'time': None, 'food_item': None, 'location': None}\n    label_map = {'TIME': 'time', 'FOOD': 'food_item', 'LOC': 'location'}\n    for span in ner_out:\n        key = label_map.get(span['entity_group'])\n        if key:\n            slots[key] = span['word'].strip()\n\n    return {\n        'text':       utterance,\n        'intent':     intent_label,\n        'confidence': intent_score,\n        'slots':      slots,\n    }\n\nprint(\"predict() ready.\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:25:21.625494Z","iopub.status.idle":"2026-06-21T12:25:21.625884Z","shell.execute_reply.started":"2026-06-21T12:25:21.625714Z","shell.execute_reply":"2026-06-21T12:25:21.62574Z"}},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import json\n\n# ── Test with examples ────────────────────────────────────────────────────────\ntest_cases = [\n    \"want a burger at 7pm today\",\n    \"Table for 4 at 8 PM near mall\",\n    \"Hi, Order food for me right now\",\n    \"I want to cancel my reservation please\",\n    \"Is my pizza ready? I ordered 30 minutes ago\",\n    \"Do you have pasta available downtown?\",\n]\n\nfor utterance in test_cases:\n    result = predict(utterance)\n    print(json.dumps(result, indent=2))\n    print(\"-\" * 50)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:25:21.627348Z","iopub.status.idle":"2026-06-21T12:25:21.627667Z","shell.execute_reply.started":"2026-06-21T12:25:21.627533Z","shell.execute_reply":"2026-06-21T12:25:21.627551Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 6. (Optional) Push to Hugging Face Hub","metadata":{}},{"cell_type":"code","source":"# Uncomment and set your HF username first\nfrom huggingface_hub import notebook_login\nnotebook_login()\n\nintent_trainer.push_to_hub('Shreyansh234/restaurant-intent-bert')\nner_trainer.push_to_hub('Shreyansh234/restaurant-ner-bert')","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-21T12:24:45.710015Z","iopub.status.idle":"2026-06-21T12:24:45.710393Z","shell.execute_reply.started":"2026-06-21T12:24:45.710246Z","shell.execute_reply":"2026-06-21T12:24:45.710268Z"}},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## 7. Summary & Expected Results\n\n| Model | Task | Expected Val F1 |\n|---|---|---|\n| `BertForSequenceClassification` | Intent (6 classes) | 0.93 – 0.98 |\n| `BertForTokenClassification` | Slot filling (NER) | 0.88 – 0.95 |\n\n### Why so much better than GPT-2?\n- **BERT is an encoder** — it reads the whole sentence bidirectionally before making a decision, which is exactly what classification needs.\n- **GPT-2 is a decoder** — it predicts the next token given past tokens, which is what text *generation* needs, not classification.\n- Using the right metric (accuracy / F1 instead of perplexity) gives you a meaningful, interpretable score.\n\n### If you want even higher accuracy:\n- Swap `bert-base-uncased` → `roberta-base` (usually +1–2% F1)\n- Add data augmentation (paraphrase your training sentences)\n- Use a joint multi-task model that shares a BERT encoder and has two separate classification heads","metadata":{}},{"cell_type":"code","source":"","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}