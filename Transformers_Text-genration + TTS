dfile as sf\n\nfrom transformers import pipeline\nfrom kokoro import KPipeline\nfrom IPython.display import Audio, display\n\ngenerator = pipeline(\n    \"text-generation\",\n    model=\"HuggingFaceTB/SmolLM2-360M-Instruct\",\n    device=-1   # CPU\n)\n\nuser_question = \"Explain zero-shot classification in NLP in simple words.\"\n\nmessages = [\n    {\n        \"role\": \"system\",\n        \"content\": \"You are a helpful NLP chatbot. Reply simply and shortly.\"\n    },\n    {\n        \"role\": \"user\",\n        \"content\": user_question\n    }\n]\n\nresult = generator(\n    messages,\n    max_new_tokens=120,\n    do_sample=True,\n    temperature=0.7,\n    top_p=0.9\n)\n\n\ngenerated_response = result[0][\"generated_text\"][-1][\"content\"]\n\nprint(\"Chatbot response:\\n\")\nprint(generated_response)\n\n\ntts = KPipeline(lang_code=\"a\")  # English\n\naudio_parts = []\n\nfor _, _, audio in tts(\n    generated_response,\n    voice=\"af_heart\"\n):\n    audio_parts.append(audio)\n\nfinal_audio = np.concatenate(audio_parts)\n\noutput_file = \"bot_response.wav\"\nsf.write(output_file, final_audio, 24000)\n\nprint(f\"\\nVoice file created: {output_file}\")\n\n\ndisplay(Audio(output_file, autoplay=True))","metadata":{"id":"xK0RNN30LNeR","colab":{"base_uri":"https://localhost:8080/","height":214,"referenced_widgets":["8a2fb0eb13614260a0136d086824f33a","759bcab6f8af4c028bd4b6491fc3bef9","218f2f13339e47ec8099a165334bc869","a780cd8cf972415781fd1f362fa1c023","2415e9fdcf1e439b9b785b086994c09b","b568422470ef412cb3aca5d024afdd60","d0e45a4ef26f45d69b3693703beda133","766557a0a19b474995bb3e45c6eacede","3746569122e94ca3afbf46a61515d9de","d7a393c256ce445da84cb7a01271d829","c0fe6114e5cf4046bf0982836b003b5e"]},"executionInfo":{"status":"ok","timestamp":1781937608190,"user_tz":-330,"elapsed":15020,"user":{"displayName":"Shreyansh Singh Rathore","userId":"18445992357477972612"}},"outputId":"8ab89698-c97c-4539-811f-e0deb1fbc71f","trusted":true,"execution":{"iopub.status.busy":"2026-0