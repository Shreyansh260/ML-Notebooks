Temporal + Statistical","metadata":{}},{"cell_type":"code","source":"def engineer_features(df):\n    df = df.copy()\n    grp = df.groupby(['Driver', 'Race', 'Year'])\n    \n    # ===== TEMPORAL / LAG FEATURES =====\n    df['LapTime_Lag1'] = grp['LapTime (s)'].transform(lambda x: x.shift(1))\n    df['LapTime_Lag2'] = grp['LapTime (s)'].transform(lambda x: x.shift(2))\n    df['LT_Lag1_Delta'] = df['LapTime (s)'] - df['LapTime_Lag1']\n    df['LT_Lag2_Delta'] = df['LapTime (s)'] - df['LapTime_Lag2']\n    df['LT_Acceleration'] = df['LT_Lag1_Delta'] - df['LT_Lag2_Delta'].fillna(0)\n    \n    # Rolling stats\n    df['LT_Roll3_Mean'] = grp['LapTime (s)'].transform(lambda x: x.rolling(3, min_periods=1).mean())\n    df['LT_Roll5_Mean'] = grp['LapTime (s)'].transform(lambda x: x.rolling(5, min_periods=1).mean())\n    df['LT_Roll3_Std']  = grp['LapTime (s)'].transform(lambda x: x.rolling(3, min_periods=1).std())\n    df['LT_Trend5'] = grp['LT_Roll5_Mean'].transform(lambda x: x.diff())\n    \n    # Driver context\n    df['LT_vs_DriverMedian'] = df['LapTime (s)'] - grp['LapTime (s)'].transform('median')\n    df['LT_vs_BestLap'] = df['LapTime (s)'] - grp['LapTime (s)'].transform('min')\n    \n    # TyreLife change\n    df['TyreLife_Lag1'] = grp['TyreLife'].transform(lambda x: x.shift(1))\n    df['TyreLife_Change'] = df['TyreLife'] - df['TyreLife_Lag1']\n    \n    # Cumulative pits\n    df['PitStop_Cumul'] = grp['PitStop'].transform(lambda x: x.cumsum().shift(1).fillna(0))\n    \n    # Position change rolling\n    if 'Position_Change' in df.columns:\n        df['PosChange_Roll3'] = grp['Position_Change'].transform(\n            lambda x: x.rolling(3, min_periods=1).sum())\n    \n    # ===== PHYSICS-BASED TIRE DEGRADATION =====\n    deg_rates = {'SOFT': 3.0, 'MEDIUM': 2.0, 'HARD': 1.0, 'INTERMEDIATE': 1.5, 'WET': 0.5, 'Unknown': 1.5}\n    life_map  = {'SOFT': 15, 'MEDIUM': 25, 'HARD': 40, 'INTERMEDIATE': 30, 'WET': 20, 'Unknown': 25}\n    comp_enc  = {'SOFT': 3, 'MEDIUM': 2, 'HARD': 1, 'INTERMEDIATE': 0, 'WET': -1, 'Unknown': 0}\n    \n    df['CompoundDegRate']   = df['Compound'].map(deg_rates).fillna(1.5)\n    df['CompoundLifespan']  = df['Compound'].map(life_map).fillna(25)\n    df['CompoundEncoded']   = df['Compound'].map(comp_enc).fillna(0)\n    \n    # Non-linear tire wear model\n    df['TyreWear_Physics']    = df['CompoundDegRate'] * (df['TyreLife'] ** 1.3)\n    df['TyreLife_vs_Expected'] = df['TyreLife'] / (df['CompoundLifespan'] + 1)\n    df['Stint_Len_Deviation'] = df['TyreLife'] - df.groupby('Compound')['TyreLife'].transform('median')\n    \n    # ===== RACE STRATEGY =====\n    if 'RaceProgress' in df.columns:\n        df['LapsRemaining'] = ((1 - df['RaceProgress']) * df['LapNumber'] / (df['RaceProgress'] + 0.001)).clip(0, 200)\n        df['IsEarlyRace'] = (df['RaceProgress'] < 0.25).astype(int)\n        df['IsMidRace']   = ((df['RaceProgress'] >= 0.25) & (df['RaceProgress'] < 0.65)).astype(int)\n        df['IsLateRace']  = (df['RaceProgress'] >= 0.65).astype(int)\n        df['IsEndgame']   = (df['RaceProgress'] >= 0.85).astype(int)\n    \n    df['In_Mandatory_Window'] = (\n        (df['RaceProgress'] > 0.7) & (df['TyreLife_vs_Expected'] > 0.8) & (df['PitStop_Cumul'] < 1)\n    ).astype(int)\n    \n    # ===== TYRE FEATURES =====\n    df['TyreLife_sq']   = df['TyreLife'] ** 2\n    df['TyreLife_log']  = np.log1p(df['TyreLife'])\n    \n    # ===== DEGRADATION FEATURES =====\n    if 'Cumulative_Degradation' in df.columns:\n        df['Deg_per_lap']     = df['Cumulative_Degradation'] / (df['TyreLife'] + 1)\n        df['Deg_x_TyreLife']  = df['Cumulative_Degradation'] * df['TyreLife']\n        df['AbsDeg']          = df['Cumulative_Degradation'].abs()\n        df['DegIntensity']    = df['Cumulative_Degradation'] * df['RaceProgress']\n        df['Cumul_Deg_x_Stint'] = df['Cumulative_Degradation'] * df['Stint']\n    \n    df['laptime_degradation'] = df['LapTime (s)'] - df['LT_Roll3_Mean']\n    \n    # ===== INTERACTIONS =====\n    df['Stint_x_TyreLife']   = df['Stint'] * df['TyreLife']\n    df['lap_per_stint']      = df['LapNumber'] / (df['Stint'] + 1)\n    df['lap_progress_ratio'] = df['LapNumber'] * df['RaceProgress']\n    df['tyre_life_ratio']    = df['TyreLife'] / (df['LapNumber'] + 1)\n    df['Progress_x_TyreLife'] = df['RaceProgress'] * df['TyreLife']\n    df['Position_x_Progress'] = df['Position'] * df['RaceProgress']\n    \n    # Row-level stats\n    num_cols = df.select_dtypes(include=['int64','float64']).columns\n    num_cols = [c for c in num_cols if c not in [CFG.ID, CFG.TARGET, 'Year']]\n    if len(num_cols) > 0:\n        df['num_std']   = df[num_cols].std(axis=1)\n        df['num_range'] = df[num_cols].max(axis=1) - df[num_cols].min(axis=1)\n    \n    # Year encoding\n    if 'Year' in df.columns:\n        df['Year_sin'] = np.sin(2 * np.pi * df['Year'] / 2025)\n        df['Year_cos'] = np.cos(2 * np.pi * df['Year'] / 2025)\n    \n    # Fill lags\n    for c in ['LapTime_Lag1','LapTime_Lag2','LT_Lag1_Delta','LT_Lag2_Delta',\n              'LT_Acceleration','LT_Trend5','TyreLife_Lag1','TyreLife_Change','LT_Roll3_Std']:\n        if c in df.columns:\n            df[c] = df[c].fillna(df[c].median())\n    \n    df.replace([np.inf, -np.inf], np.nan, inplace=True)\n    return df\n\ntrain_fe = engineer_features(train)\ntest_fe  = engineer_features(test)\nprint(f\"Train: {train_fe.shape} | Test: {test_fe.shape}\")\nprint(f\"New features: {train_fe.shape[1] - train.shape[1]}\")","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-29T08:45:00.341940Z","iopub.execute_input":"2026-05-29T08:45:00.342255Z","iopub.status.idle":"2026-05-29T08:46:58.335146Z","shell.execute_reply.started":"2026-05-29T08:45:00.342221Z","shell.execute_reply":"2026-05-29T08:46:58.334301Z"}},"outputs":[{"name":"stdout","text":"Train: (540511, 60) | Test: (188165, 60)\nNew features: 45\n","output_type":"stream"}],"execution_count":11},{"cell_type":"markdown","source":"## 4. Target Encoding + Preprocessing","metadata":{}},{"cell_type":"code","source":"X = train_fe.drop(columns=[CFG.TARGET], errors='ignore')\ny = train_fe[CFG.TARGET]\nX_test = test_fe.drop(columns=[CFG.ID], errors='ignore')\nif CFG.ID in X.columns:\n    X = X.drop(columns=[CFG.ID])\n\n# ===== OOF TARGET ENCODING =====\nSMOOTHING = 10\nfor col in ['Driver', 'Compound', 'Race']:\n    if col not in X.columns:\n        continue\n    te_col = f\"{col}_TE\"\n    kf_enc = KFold(n_splits=5, shuffle=True, random_state=CFG.SEED)\n    encoded = np.zeros(len(X))\n    gmean = y.mean()\n    \n    for tr_i, val_i in kf_enc.split(X):\n        tmp = pd.DataFrame({col: X.iloc[tr_i][col], 't': y.iloc[tr_i]})\n        st = tmp.groupby(col)['t'].agg(['mean','count'])\n        sm = (st['mean']*st['count'] + gmean*SMOOTHING) / (st['count']+SMOOTHING)\n        encoded[val_i] = X.iloc[val_i][col].map(sm).fillna(gmean).values\n    X[te_col] = encoded\n    \n    tmp_f = pd.DataFrame({col: X[col], 't': y})\n    st_f = tmp_f.groupby(col)['t'].agg(['mean','count'])\n    sm_f = (st_f['mean']*st_f['count'] + gmean*SMOOTHING) / (st_f['count']+SMOOTHING)\n    X_test[te_col] = X_test[col].map(sm_f).fillna(gmean).values\n    print(f\"  TE: {col} -> {te_col}\")\n\n# ===== LABEL ENCODE =====\ncombined = pd.concat([X, X_test], axis=0, ignore_index=True)\ncat_cols = combined.select_dtypes(include=['object','category','bool']).columns.tolist()\nfor col in cat_cols:\n    combined[col] = LabelEncoder().fit_transform(combined[col].astype(str).fillna('missing'))\ncombined = combined.fillna(combined.median(numeric_only=True))\nX = combined.iloc[:len(X)].reset_index(drop=True)\nX_test = combined.iloc[len(X):].reset_index(drop=True)\n\nprint(f\"\\nFinal: X={X.shape} | X_test={X_test.shape}\")\ndel combined; gc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-05-29T08:46:58.336313Z","iopub.execute_input":"2026-05-29T08:46:58.336734Z","iopub.status.idle":"2026-05-29T08:47:03.524252Z","shell.execute_reply.started":"2026-05-29T08:46:5