df[TARGET].values))\n\nentries.sort(key=lambda x: x[1], reverse=True)\nanch_name, anch_score, anch_lbl = entries[0]\nanchor = patch(pd.DataFrame({ID: ids, TARGET: anch_lbl}))\nprint(f'\\nAnchor : {anch_name}  ({anch_score:.5f})')\nprint(f'Refs   : {len(entries) - 1}')\n\n# ── 3. Load & blend soft-label probabilities (Optuna 150 trials + TPE) ────────\np_arrays = []\nfor f in soft:\n    try:\n        if f.endswith('.npy'):\n            a = np.load(f).astype(np.float32)\n            if a.shape == (len(ids), 3):\n                a /= a.sum(1, keepdims=True)\n                p_arrays.append(a)\n        else:\n            df   = pd.read_csv(f).set_index(ID).reindex(ids).reset_index()\n            cols = [c for c in df.columns if any(k in c for k in ['GALAXY', 'QSO', 'STAR'])]\n            if len(cols) >= 3:\n                ordered = []\n                for target in ['GALAXY', 'QSO', 'STAR']:\n                    exact = [c for c in cols if target in c]\n                    ordered.append(exact[0] if exact else cols[len(ordered)])\n                a = df[ordered].values.astype(np.float32)\n                a /= a.sum(1, keepdims=True)\n                p_arrays.append(a)\n    except:\n        pass\n\nprint(f'\\nLoaded {len(p_arrays)} probability arrays')\n\nif p_arrays:\n    # Objective: maximise agreement with anchor\n    def obj(trial):\n        T = trial.suggest_float('T', 1.0, 2.5)\n        w = np.array([trial.suggest_float(f'w{i}', 0.1, 5.0)\n                      for i in range(len(p_arrays))])\n        pb = np.average([a ** T for a in p_arrays], axis=0, weights=w)\n        pb /= pb.sum(1, keepdims=True)\n        return -np.mean(LABELS[pb.argmax(1)] == anchor[TARGET].values)\n\n    # FIX 1: 150 trials + explicit TPE sampler (was 30 trials, no sampler specified)\n    study = optuna.create_study(\n        direction='minimize',\n        sampler=optuna.samplers.TPESampler(seed=42)\n    )\n    study.optimize(obj, n_trials=150, show_progress_bar=False)\n\n    Tb = study.best_params['T']\n    wb = np.array([study.best_params[f'w{i}'] for i in range(len(p_arrays))])\n    prob = np.average([a ** Tb for a in p_arrays], axis=0, weights=wb)\n    prob /= prob.sum(1, keepdims=True)\n    prob_pred   = LABELS[prob.argmax(1)]\n    prob_margin = np.sort(prob, 1)[:, -1] - np.sort(prob, 1)[:, -2]\n\n    agree_rate = np.mean(prob_pred == anchor[TARGET].values)\n    print(f'Optuna agree with anchor : {agree_rate:.4f}')\n    print(f'Prob disagrees with anchor on {(prob_pred != anchor[TARGET].values).sum()} rows')\n    print(f'  → high-margin disagrees (>0.85) : '\n          f'{((prob_pred != anchor[TARGET].values) & (prob_margin > 0.85)).sum()}')\n\n    # ── Submission A: pure probability ─────────────────────────────────────────\n    sub_prob = patch(pd.DataFrame({ID: ids, TARGET: prob_pred}))\n    sub_prob.to_csv('submission_prob.csv', index=False)\n    print('\\n[A] submission_prob.csv saved (pure Optuna-blended probabilities)')\n\n    # ── Submission B: high-confidence probability overrides on anchor ───────────\n    sub_hybrid = anchor.copy()\n    cl_h       = sub_hybrid.columns.get_loc(TARGET)\n    overrides  = 0\n    for i in range(len(ids)):\n        if prob_pred[i] != anchor[TARGET].values[i] and prob_margin[i] > 0.85:\n            sub_hybrid.iat[i, cl_h] = prob_pred[i]\n            overrides += 1\n    sub_hybrid = patch(sub_hybrid)\n    sub_hybrid.to_csv('submission_hybrid.csv', index=False)\n    print(f'[B] submission_hybrid.csv saved ({overrides} overrides at prob_margin > 0.85)')\n\nelse:\n    prob = prob_pred = prob_margin = None\n    print('No probability arrays loaded — Ridge-only mode.')\n\n# ── 4. Build Ridge feature matrix ─────────────────────────────────────────────\nf2c, rows, cols = {}, [], []\nfor i, (_, sc, lbl) in enumerate(entries):\n    for p in np.flatnonzero(lbl != anchor[TARGET].values):\n        key = (int(ids[p]), str(lbl[p]))\n        c   = f2c.setdefault(key, len(f2c))\n        rows.append(i)\n        cols.append(c)\n\nX    = sparse.csr_matrix(\n           (np.ones(len(rows), dtype=np.float32), (rows, cols)),\n           shape=(len(entries), len(f2c))\n       )\ny    = np.array([sc - anch_score for _, sc, _ in entries])\nsupp = np.asarray((X > 0).sum(0)).ravel()\ninv  = {c: k for k, c in f2c.items()}\n\ntopN      = min(3, len(entries))\ntop_bonus = [(entries[i][2], w)\n             for i, w in zip(range(topN), [3.5e-5, 2.5e-5, 1.5e-5])]\n\n# ── 5. Fit Ridge ensemble across 4 quality masks ──────────────────────────────\n# FIX 2: added 0.972 mask (was only 0.968 / 0.970 / 0.971)\n# FIX 3: steeper sample weights (multiplier 1400 → 1600)\nmodels = []\nfor ms in [0.968, 0.970, 0.971, 0.972]:\n    mask = np.array([sc >= ms for _, sc, _ in entries])\n    if mask.sum() < 5:\n        continue\n    Xm = X[mask]\n    ym = y[mask]\n    sw = np.array([max(0.15, (sc - 0.968) * 1600)\n                   for _, sc, _ in entries if sc >= ms])\n    for alpha in [0.1, 1, 10, 100]:\n        try:\n            m = Ridge(alpha=alpha, fit_intercept=True).fit(Xm, ym, sample_weight=sw)\n            models.append(m.coef_)\n        except:\n            pass\n\nprint(f'\\nRidge models fitted : {len(models)}')\n\ncoef     = np.vstack(models)\npos_rate = (coef > 0).mean(0)\nmed      = np.median(coef, 0)\nq25      = np.quantile(coef, 0.25, 0)\nq10      = np.quantile(coef, 0.10, 0)\nmpos     = np.maximum(coef, 0).mean(0)\nstdc     = coef.std(0)\n\n# ── 6. Score every (id, flip-label) candidate ─────────────────────────────────\nrank_rows = []\nfor col, (rid, lbl) in inv.items():\n    p     = id2p[int(rid)]\n    ai    = L2I[anchor[TARGET].iat[p]]\n    li    = L2I[lbl]\n    bonus = sum(w for larr, w in top_bonus if str(larr[p]) == lbl)\n\n    var_pen = -1.5e-5 * min(1.0, stdc[col] / (abs(med[col]) + 1e-9))\n    score   = (med[col]\n               + 0.7  * q25[col]\n               + 0.15 * q10[col]\n               + 0.2  * mpos[col]\n               + bonus + var_pen)\n\n    if prob is not None:\n        delta = float(prob[p, li] - prob[p, ai])\n        agree = (prob_pred[p] == lbl)\n\n        # FIX 4: marg_pen was inverted — high-margin agreement was penalised.\n        # Now: reward confident agreement, penalise confident disagreement.\n        if agree:\n            prob_boost = 3e-5 if prob_margin[p] > 0.7 else 1.5e-5\n        else:\n            prob_boost = -4e-5 if prob_margin[p] > 0.7 else -1e-5\n\n        # FIX 5: delta coefficient scaled 2e-5 → 4e-5\n        score += prob_boost + 4e-5 * np.tanh(delta * 10)\n\n    rank_rows.append((int(rid), lbl, supp[col], pos_rate[col], score))\n\n# ── 7. Filter candidates ──────────────────────────────────────────────────────\nrank_pre = pd.DataFrame(rank_rows,\n                        columns=['id', 'class', 'support', 'pos_rate', 'score'])\n\n# Debug: show where candidates are dropping out\nprint(f'\\nPre-filter total        : {len(rank_pre)}')\nprint(f'  score > 0             : {(rank_pre.score > 0).sum()}')\nprint(f'  pos_rate >= 0.20      : {(rank_pre.pos_rate >= 0.20).sum()}')\nprint(f'  support >= 1          : {(rank_pre.support >= 1).sum()}')\nprint(f'  all three combined    : '\n      f'{((rank_pre.score > 0) & (rank_pre.pos_rate >= 0.20) & (rank_pre.support >= 1)).sum()}')\n\n# FIX 6: pos_rate threshold lowered from 0.35 → 0.20\nrank = rank_pre[\n    (rank_pre.support  >= 1) &\n    (rank_pre.pos_rate >= 0.20) &\n    (rank_pre.score    >  0)\n].copy()\nrank.sort_values(['score', 'pos_rate', 'support'], ascending=False, inplace=True)\nprint(f'\\nCandidates after filter : {len(rank)}')\nif len(rank):\n    print(rank.head(15).to_string(index=False))\n\n# ── 8. Multi-K sweep (dynamic — every K from 1 to len(rank)) ─────────────────\n# FIX 7: was hardcoded [94..110] which were all > 5 → zero submissions generated\nMULTI_K = list(range(1, min(len(rank) + 1, 120)))\n\nfor k in MULTI_K:\n    sub = anchor.copy()\n    cl  = sub.columns.get_loc(TARGET)\n    for _, r in rank.head(k).iterrows():\n        sub.iat[id2p[int(r['id'])], cl] = r['class']\n    sub = patch(sub)\n    sub.to_csv(f'submission_k{k}.csv', index=False)\n\nif MULTI_K:\n    print(f'\\n[C] Saved submission_k1 … submission_k{MULTI_K[-1]}  ({len(MULTI_K)} files)')\nelse:\n    print('\\n[C] No Ridge candidates found — no k-sweep files saved.')\n\n# ── 9. Default submission (conservative K) ────────────────────────────────────\nbest_k = min(15, len(rank))   # start conservative; tune after LB feedback\nsub    = anchor.copy()\ncl     = sub.columns.get_loc(TARGET)\nfor _, r in rank.head(best_k).iterrows():\n    sub.iat[id2p[int(r['id'])], cl] = r['class']\nsub = patch(sub)\nsub.to_csv('submission.csv', index=False)\nprint(f'[D] submission.csv saved  (K={best_k})')\n\nprint('\\n── Done ──────────────────────────────────────────────────────────────────')\nprint('Files generated:')\nprint('  submission_prob.csv    → pure probability consensus')\nprint('  submission_hybrid.csv  → anchor + high-confidence prob overrides')\nif MULTI_K:\n    print(f'  submission_k1 … k{MULTI_K[-1]} → Ridge flip sweep')\nprint('  submission.csv         → Ridge flip default (conservative K)')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-29T06:52:09.090372Z","iopub.execute_input":"2026-06-29T06:52:09.090738Z","iopub.status.idle":"2026-06-29T06:54:18.972661Z","shell.execute_reply.started":"2026-06-29T06:52:09.090702Z","shell.execute_reply":"2026-06-29T06:54:18.971649Z"}},"outputs":[{"name":"stdout","text":"Hard label files : 421\nSoft label files : 24\n\nAnchor : submission 0.97254.csv  (0.97254)\nRefs   : 420\n\nLoaded 24 probability arrays\nOptuna agree with anchor : 0.9969\nProb disagrees with anchor on 762 rows\n  → high-margin disagrees (>0.85) : 0\n\n[A] submission_prob.csv saved (pure Optuna-blended probabilities)\n[B] submission_hybrid.csv saved (0 overrides at prob_margin > 0.85)\n\nRidge models fitted : 16\n\nPre-filter total        : 11196\n  score > 0             : 755\n  pos_rate >= 0.20      : 908\n  support >= 1      