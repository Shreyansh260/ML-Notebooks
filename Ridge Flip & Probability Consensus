shape}, Test={X_meta_test.shape}\")\n\n# Find best meta-learner C via OOF CV\nbest_meta_ba = 0\nbest_meta_C = None\nbest_meta_oof_proba = None\n\nfor C in [0.01, 0.05, 0.1, 0.5, 1.0, 5.0, 10.0, 50.0]:\n    meta_oof_pred = np.zeros((len(y_train), 3), dtype=np.float64)\n    skf = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)\n\n    for fold, (tr_idx, val_idx) in enumerate(skf.split(X_meta_oof, y_train)):\n        meta_model = LogisticRegression(\n            C=C, class_weight=\"balanced\", max_iter=2000,\n            multi_class=\"multinomial\", solver=\"lbfgs\", random_state=42,\n        )\n        meta_model.fit(X_meta_oof[tr_idx], y_train[tr_idx])\n        meta_oof_pred[val_idx] = meta_model.predict_proba(X_meta_oof[val_idx])\n\n    meta_ba = balanced_accuracy_score(LABELS[y_train], LABELS[meta_oof_pred.argmax(axis=1)])\n    print(f\"  C={C}: OOF BA={meta_ba:.5f}\")\n\n    if meta_ba > best_meta_ba:\n        best_meta_ba = meta_ba\n        best_meta_C = C\n        best_meta_oof_proba = meta_oof_pred.copy()\n\nprint(f\"  Best meta-learner: C={best_meta_C}, OOF BA={best_meta_ba:.5f}\")\n\n# Train final meta-learner\nfinal_meta = LogisticRegression(\n    C=best_meta_C, class_weight=\"balanced\", max_iter=2000,\n    multi_class=\"multinomial\", solver=\"lbfgs\", random_state=42,\n)\nfinal_meta.fit(X_meta_oof, y_train)\nstacked_test_proba = final_meta.predict_proba(X_meta_test)\n\n# Threshold optimization\ndef neg_ba_with_bias(bias, proba, y_true):\n    adjusted = proba + bias\n    return -balanced_accuracy_score(y_true, adjusted.argmax(axis=1))\n\nresult = minimize(\n    neg_ba_with_bias, x0=np.array([0.0, 0.0, 0.0]),\n    args=(best_meta_oof_proba, y_train),\n    method=\"Nelder-Mead\",\n    options={\"maxiter\": 5000, \"xatol\": 1e-8, \"fatol\": 1e-8},\n)\noptimal_bias = result.x\nba_optimized = -result.fun\nprint(f\"  Threshold-optimized OOF BA: {ba_optimized:.5f}\")\nprint(f\"  Optimal bias: {optimal_bias}\")\n\n# Apply bias to test predictions\nadjusted_test_proba = stacked_test_proba + optimal_bias\nadjusted_test_proba /= adjusted_test_proba.sum(axis=1, keepdims=True)\n\n# Save stacked proba for later use\nnp.save(WORK_DIR / \"stacked_test_proba.npy\", adjusted_test_proba)\nstacked_pred = LABELS[adjusted_test_proba.argmax(axis=1)]\n\n# Create initial submission from stacked predictions\nstacked_sub = pd.DataFrame({ID: test_ids, TARGET: stacked_pred})\nstacked_sub.to_csv(WORK_DIR / \"stacked_submission.csv\", index=False)\nprint(f\"  Stacked submission class dist: {stacked_sub[TARGET].value_counts().to_dict()}\")\n\n# Free memory\ndel X_train, X_test, X_meta_oof, X_meta_test, meta_oof_parts, meta_test_parts\ndel all_oof, all_test, best_meta_oof_proba\ngc.collect()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"9d532791-ac83-455a-8703-3070bab5cd33","cell_type":"markdown","source":"## PHASE 3: PROBABILITY CONSENSUS WITH POWER BLENDING","metadata":{}},{"id":"fbad8bc2-534e-4d13-9d61-7f63899880f7","cell_type":"code","source":"print(\"\\n[PHASE 3] Building probability consensus with power blending...\")\n\n\ndef score_from_name(path: Path) -> float | None:\n    match = re.search(r'(0\\.\\d{5})', path.name)\n    return float(match.group(1)) if match else None\n\n\ndef read_submission(path: Path, ids: np.ndarray | None = None) -> pd.DataFrame | None:\n    if not path.exists():\n        return None\n    try:\n        df = pd.read_csv(path, usecols=[ID, TARGET]).copy()\n    except Exception:\n        return None\n    if ids is not None and not np.array_equal(df[ID].to_numpy(), ids):\n        df = df.set_index(ID).reindex(ids).reset_index()\n        if df[TARGET].isna().any():\n            return None\n    if not set(df[TARGET].unique()).issubset(set(LABELS)):\n        return None\n    return df\n\n\n# Load anchor\nanchor_df = read_submission(START_ANCHOR_FILE)\nif anchor_df is None:\n    raise FileNotFoundError(START_ANCHOR_FILE)\n\nids = anchor_df[ID].to_numpy()\nanchor_labels_init = anchor_df[TARGET].to_numpy()\n\n# Load external probability sources\ndef load_probability_sources(data_dir: Path, ids: np.ndarray) -> tuple[list, list, list]:\n    arrays = []\n    weights = []\n    names = []\n\n    for path in sorted(data_dir.glob('test_preds__*.csv')):\n        df = pd.read_csv(path)\n        if ID not in df.columns or not set(LABELS).issubset(df.columns):\n            continue\n        if not np.array_equal(df[ID].to_numpy(), ids):\n            continue\n        score = score_from_name(Path(path.name.replace('test_preds__', ''))) or 0.969\n        arr = df[LABELS].to_numpy(np.float64)\n        arr /= arr.sum(axis=1, keepdims=True)\n        arrays.append(arr)\n        weights.append(max(0.25, (score - 0.968) * 1000.0))\n        names.append(path.name)\n\n    for filename, weight in [('cat-3_test_preds__0.96972.npy', 1.7),\n                              ('pred_lr_stacker_v9.npy', 3.5)]:\n        path = data_dir / filename\n        if path.exists():\n            arr = np.load(path).astype(np.float64)\n            arr /= arr.sum(axis=1, keepdims=True)\n            arrays.append(arr)\n            weights.append(weight)\n            names.append(filename)\n\n    artifact = data_dir / 'sub_eda03_gbdt_artifact_blend.csv'\n    if artifact.exists():\n        df = pd.read_csv(artifact, usecols=[ID, 'proba_GALAXY', 'proba_QSO', 'proba_STAR'])\n        if np.array_equal(df[ID].to_numpy(), ids):\n            arr = df[['proba_GALAXY', 'proba_QSO', 'proba_STAR']].to_numpy(np.float64)\n            arr /= arr.sum(axis=1, keepdims=True)\n            arrays.append(arr)\n            weights.append(4.0)\n            names.append(artifact.name)\n\n    return arrays, weights, names\n\n\nraw_arrays, raw_weights, proba_names = load_probability_sources(DATA_DIR, ids)\n\n# Add stacked predictions as the strongest probability source\n# Map test_ids to the same order as ids\nstacked_proba_aligned = np.full((len(ids), 3), 1.0 / 3.0)\nid_to_test_pos = {int(tid): i for i, tid in enumerate(test_ids)}\nfor i, row_id in enumerate(ids):\n    pos = id_to_test_pos.get(int(row_id))\n    if pos is not None:\n        stacked_proba_aligned[i] = adjusted_test_proba[pos]\n\nraw_arrays.append(stacked_proba_aligned)\nraw_weights.append(10.0)  # Highest weight — our stacked model is the strongest\nproba_names.append(\"stacked_grandmaster_v4\")\n\nprint(f\"  Probability sources: {len(proba_names)}\")\nfor name, w in zip(proba_names, raw_weights):\n    print(f\"    {name}: weight={w:.2f}\")\n\n\n# Power blending with temperature + weight optimization\ndef optimize_power_blend(arrays, base_weights, anchor_labels, n_trials=100):\n    \"\"\"Optimize weights and temperature for power blending.\"\"\"\n    n = len(arrays)\n\n    def objective(trial):\n        T = trial.suggest_float('temperature', 1.0, 5.0)\n        w = np.array([trial.suggest_float(f'w_{i}', 0.1, max(bw * 4, 8.0))\n                       for i, bw in enumerate(base_weights)])\n\n        # Power blend: raise each probability to power T, then weighted average\n        powered = []\n        for arr in arrays:\n            p = np.clip(arr, 1e-10, 1.0)\n            p_t = p ** T\n            p_t /= p_t.sum(axis=1, keepdims=True)\n            powered.append(p_t)\n\n        blended = np.average(np.stack(powered), axis=0, weights=w)\n        blended /= blended.sum(axis=1, keepdims=True)\n        pred = LABELS[blended.argmax(axis=1)]\n        return -(pred == anchor_labels).mean()\n\n    study = optuna.create_study(direction='minimize',\n                                 sampler=optuna.samplers.TPESampler(seed=42))\n    study.optimize(objective, n_trials=n_trials, show_progress_bar=False)\n\n    best = study.best_params\n    T_opt = best['temperature']\n    w_opt = np.array([best[f'w_{i}'] for i in range(n)])\n\n    print(f\"  Power blend optimization: agreement={-study.best_value:.5f}, T={T_opt:.2f}\")\n    return w_opt, T_opt\n\n\nopt_weights, opt_temp = optimize_power_blend(\n    raw_arrays, raw_weights, anchor_labels_init, n_trials=120\n)\n\n# Apply optimized power blend\npowered_arrays = []\nfor arr in raw_arrays:\n    p = np.clip(arr, 1e-10, 1.0)\n    p_t = p ** opt_temp\n    p_t /= p_t.sum(axis=1, keepdims=True)\n    powered_arrays.append(p_t)\n\nproba = np.average(np.stack(powered_arrays), axis=0, weights=opt_weights)\nproba /= proba.sum(axis=1, keepdims=True)\nproba_pred = LABELS[proba.argmax(axis=1)]\nsorted_p = np.sort(proba, axis=1)\nproba_margin = sorted_p[:, -1] - sorted_p[:, -2]\n\nprint(f\"  Consensus prediction agreement with anchor: {(proba_pred == anchor_labels_init).mean():.5f}\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"id":"c75012a5-2e59-48ea-a6e8-d5aa75d164f9","cell_type":"markdown","source":"## PHASE 4: ENHANCED RIDGE-FLIP HILL CLIMBING","metadata":{}},{"id":"f2f50c7c-df40-4240-8447-905b54280ea9","cell_type":"code","source":"print(\"\\n[PHASE 4] Enhanced Ridge-Flip Hill Climbing...\")\n\n# Scoring parameters — more aggressive than V3\nSCORING_PARAMS = {\n    'w_median':    0.7,\n    'w_q25':       0.4,\n    'w_mean_pos':  0.1,\n    'w_prob_agree': 3.5e-5,\n    'w_prob_delta': 5.0e-5,\n    'w_negative':  -1.0e-4,\n    'w_support_penalty': 5.0e-5,\n    'w_stacked_agree': 6.0e-5,  # NEW: bonus if stacked model agrees\n}\n\n\ndef compute_flip_score(row_data: dict, sp: dict, max_support: int) -> float:\n    support_ratio = row_data['support'] / max(1, max_support)\n    support_penalty = sp.get('w_support_penalty', 0.0) * (1.0 - support_ratio)\n\n    return (\n        sp['w_median']     * row_data['median_coef']\n        + sp['w_q25']      * row_data['q25_coef']\n        + sp['w_mean_pos'] * row_data['mean_pos_coef']\n        + (sp['w_prob_agree'] if row_data['prob_agree'] else 0.0)\n        + sp['w_prob_delta'] * np.tanh(row_data['prob_delta'] * 10)\n        + (sp['w_negative'] if row_data['in_negative_feedback'] else 0.0)\n        + (sp.get('w_stacked_agree', 0.0) if row_data.get('stacked_agree', False) else 0.0)\n        - support_penalty\n    )\n\n\ndef load_scored_entries(max_score: float, ids: np.ndarray, generated_entries: list[dict]) -> list[dict]:\n    entries = []\n    seen: set[bytes] = set()\n\n    def add(name, path, score, labels=None):\n        if labels is None:\n            df = read_submission(path, ids)\n            if df is None:\n                return\n            labels_arr = df[TARGET].to_numpy()\n        else:\n            labels_arr = labels\n        key = labels_arr.tobytes()\n        if key in seen:\n            return\n        seen.add(key)\n        entries.append({'name': name, 'score': float(score), 'labels': labels_arr})\n\n    for d_dir in [DATA_DIR, NEW_DATA_DIR]:\n        if d_dir.exists():\n            for path in sorted(d_dir.glob('*.csv')):\n                score = score_from_name(path)\n                if score is not None and score <= max_score:\n                    add(path.name, path, score)\n\n    if FEEDBACK_CSV.exists():\n        fb = pd.read_csv(FEEDBACK_CSV)\n        for row in fb.itertuples(index=False):\n            score = float(row.score)\n            if score <= max_score:\n                path = Path(row.path)\n                if not path.is_absolute():\n                    path = DATA_DIR / path\n                add(getattr(row, 'name', path.name), path, score)\n\n    # Add stacked submission from our trained models\n    stacked_score = max_score  # Assume our stacked model is at least this good\n    add(\"stacked_grandmaster_v4\", WORK_DIR / \"stacked_submission.csv\", stacked_score)\n\n    for item in generated_entries:\n        if item['score'] <= max_score:\n            add(item['name'], None, item['score'], item['labels'])\n\n    entries.sort(key=lambda x: x['score'], reverse=True)\n    return entries\n\n\ndef build_rank(current_anchor: pd.DataFrame, current_score: float,\n               generated_entries: list[dict],\n               scoring_params: dict | None = None,\n               optimize_scoring_weights: bool = False) -> tuple[pd.DataFrame, list[dict], list[dict]]:\n    sp = scoring_params if scoring_params is not None else SCORING_PARAMS\n    anchor_labels = current_anchor[TARGET].to_numpy()\n    entries = load_scored_entries(current_score, ids, generated_entries)\n\n    feature_to_col: dict[tuple[int, str], int] = {}\n    rows = []\n    cols = []\n    for i, entry in enumerate(entries):\n        changed = np.flatnonzero(entry['labels'] != anchor_labels)\n        for pos in changed:\n            key = (int(ids[pos]), str(entry['labels'][pos]))\n            col = feature_to_col.setdefault(key, len(feature_to_col))\n            rows.append(i)\n            cols.append(col)\n\n    if not feature_to_col:\n        return pd.DataFrame(), entries, []\n\n    X_all = sparse.csr_matrix(\n        (np.ones(len(rows), dtype=np.float64), (rows, cols)),\n        shape=(len(entries), len(feature_to_col))\n    )\n    y_all = np.array([entry['score'] - current_score for entry in entries], dtype=np.float64)\n    support_all = np.asarray((X_all > 0).sum(axis=0)).ravel()\n\n    inv = [None] * len(feature_to_col)\n    for key, col in feature_to_col.items():\n        inv[col] = key\n\n    # Ridge Optuna hyperparameter search\n    def ridge_objective(trial):\n        min_score_t = trial.suggest_float('min_score', 0.965, 0.972)\n        alpha_t = trial.suggest_float('alpha', 0.01, 100.0, log=True)\n        use_bayes = trial.suggest_categorical('use_bayes', [True, False])\n\n        row_mask = np.array([e['score'] >= min_score_t for e in entries])\n        if row_mask.sum() < 10:\n            return float('inf')\n\n        X = X_all[row_mask]\n        y = y_all[row_mask]\n        sw = np.array([max(0.15, (e['score'] - 0.965) * 500.0)\n                        for e, keep in zip(entries, row_mask) if keep])\n        try:\n            if use_bayes:\n                model = BayesianRidge(fit_intercept=True)\n                model.fit(X.toarray(), y, sample_weight=sw)\n            else:\n                model = Ridge(alpha=alpha_t, fit_intercept=True)\n                model.fit(X, y, sample_weight=sw)\n        except Exception:\n            return float('inf')\n        pred = model.predict(X.toarray() if use_bayes else X)\n        return float(np.mean((y - pred) ** 2))\n\n    optuna_n = min(80, max(30, len(entries) * 2))\n    study = optuna.create_study(direction='minimize',\n                                 sampler=optuna.samplers.TPESampler(seed=42))\n    study.optimize(ridge_objective, n_trials=optuna_n, show_progress_bar=False)\n    best_p = study.best_params\n    print(f\"  Ridge Optuna: min_score={best_p['min_score']:.4f}, \"\n          f\"alpha={best_p['alpha']:.3f}, bayes={best_p['use_bayes']}\")\n\n    # Build diverse model ensemble: Ridge + BayesianRidge + ElasticNet + Lasso\n    models = []\n    for min_score in [0.965, 0.968, 0.970, 0.971, best_p['min_score']]:\n        row_mask = np.array([e['score'] >= min_score for e in entries])\n        if row_mask.sum() < 10:\n            continue\n        X = X_all[row_mask]\n        y = y_all[row_mask]\n        sw = np.array([max(0.15, (e['score'] - 0.965) * 500.0)\n                        for e, keep in zip(entries, row_mask) if keep])\n\n        # Ridge models with varied alpha\n        for alpha in [0.01, 0.03, 0.1, 0.3, 1.0, 3.0, 10.0, 30.0, 100.0, best_p['alpha']]:\n            model = Ridge(alpha=alpha, fit_intercept=True)\n            model.fit(X, y, sample_weight=sw)\n            models.append({'coef': np.asarray(model.coef_, dtype=np.float64), 'type': 'ridge'})\n\n        # ElasticNet models\n        for alpha in [0.001, 0.01, 0.1]:\n            for l1_ratio in [0.3, 0.5, 0.7]:\n                try:\n                    model = ElasticNet(alpha=alpha, l1_ratio=l1_ratio, fit_intercept=True, max_iter=5000)\n                    model.fit(X.toarray(), y, sample_weight=sw)\n                    models.append({'coef': np.asarray(model.coef_, dtype=np.float64), 'type': 'elastic'})\n                except Exception:\n                    pass\n\n        # Lasso models\n        for alpha in [0.0001, 0.001, 0.01]:\n            try:\n                model = Lasso(alpha=alpha, fit_intercept=True, max_iter=5000)\n                model.fit(X.toarray(), y, sample_weight=sw)\n                models.append({'coef': np.asarray(model.coef_, dtype=np.float64), 'type': 'lasso'})\n            except Exception:\n                pass\n\n        # BayesianRidge\n        if row_mask.sum() >= 15 and best_p['use_bayes']:\n            try:\n                bay = BayesianRidge(fit_intercept=True)\n                bay.fit(X.toarray(), y, sample_weight=sw)\n                coef_mean = bay.coef_\n                coef_std = np.sqrt(np.diag(bay.sigma_))\n                confident_coef = np.where(np.abs(coef_mean) > coef_std, coef_mean, 0.0)\n                models.append({'coef': confident_coef, 'type': 'bayesian'})\n                models.append({'coef': confident_coef, 'type': 'bayesian_dup'})\n            except Exception:\n                pass\n\n        # Bootstrapped Ridge for uncertainty estimation\n        rng = np.random.RandomState(42)\n        for boot_idx in range(5):\n            n_samples = X.shape[0]\n            boot_idx_arr = rng.choice(n_samples, size=n_samples, replace=True)\n            try:\n                model = Ridge(alpha=best_p['alpha'], fit_intercept=True)\n                model.fit(X[boot_idx_arr], y[boot_idx_arr], sample_weight=sw[boot_idx_arr])\n                models.append({'coef': np.asarray(model.coef_, dtype=np.float64), 'type': 'bootstrap'})\n            except Exception:\n                pass\n\n    if not models:\n        return pd.DataFrame(), entries, []\n\n    coef_mat = np.vstack([m['coef'] for m in models])\n    pos_rate = (coef_mat > 0).mean(axis=0)\n    median_coef = np.median(coef_mat, axis=0)\n    q25_coef = np.quantile(coef_mat, 0.25, axis=0)\n    mean_pos_coef = np.maximum(coef_mat, 0).mean(axis=0)\n    id_to_pos = {int(row_id): i for i, row_id in enumerate(ids)}\n\n