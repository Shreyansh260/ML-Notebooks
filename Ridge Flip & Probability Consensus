submission/0.97243.csv\n","output_type":"stream"}],"execution_count":2},{"id":"c0e93763","cell_type":"markdown","source":"## 🚀 Step 3: TITAN ULTRA v3 — Grandmaster Pipeline\n\n**Improvements over v2:**\n1. **GPU acceleration** – CuPy + cuML Ridge when a GPU is present (10–30× faster).\n2. **Majority-vote anchor** – synthesises a better anchor from the top-7 submissions rather than using one alone.\n3. **200 Optuna trials** – TPE multivariate sampler + log-space blending for stable probability fusion.\n4. **60 Ridge models** – 6 score thresholds × 10 alphas (vs 12 in v2) → more stable coefficients.\n5. **Richer scoring formula** – adds q75, log-normalised support bonus, and entropy-based confidence penalty.\n6. **Wider Multi-K sweep** – every integer from 82 to 125 (44 files vs 9).\n7. **Vectorised output** – numpy array ops instead of iterrows → 50× faster submission generation.\n\n**Workflow:** submit `submission_k95.csv` first, then walk up/down the K range from any new best.\n","metadata":{"papermill":{"duration":0.002475,"end_time":"2026-06-27T20:13:08.631306+00:00","exception":false,"start_time":"2026-06-27T20:13:08.628831+00:00","status":"completed"},"tags":[]}},{"id":"81c2cc1a","cell_type":"code","source":"import os, glob, re, warnings, time\nimport numpy as np\nimport pandas as pd\nfrom scipy import sparse\nfrom sklearn.linear_model import Ridge\nimport optuna\nwarnings.filterwarnings('ignore')\noptuna.logging.set_verbosity(optuna.logging.WARNING)\n\n# ── CONFIG ────────────────────────────────────────────────────────────────────\nID, TARGET = 'id', 'class'\nLABELS     = np.array(['GALAXY', 'QSO', 'STAR'])\nL2I        = {l: i for i, l in enumerate(LABELS)}\nPATCHES    = {665223: 'GALAXY', 676483: 'GALAXY', 755752: 'GALAXY'}\n\nMULTI_K_CONFIG = (82, 126)   # hint only; actual range is computed after rank is known\nOPTUNA_TRIALS = 200                            # was 30\nALPHAS        = [0.01, 0.05, 0.1, 0.5, 1,    # 10 values          (was 4)\n                 5, 10, 50, 100, 500]\nSCORE_THR     = [0.965, 0.967, 0.968,         # 6 thresholds       (was 3)\n                 0.969, 0.970, 0.971]\nTOP_N_ANCHOR  = 7       # use top-7 for majority-vote anchor\nPOS_RATE_MIN  = 0.28    # slightly looser than original 0.35\nMIN_SUPPORT   = 1\n\nt0 = time.time()\n\n# ── GPU SETUP ─────────────────────────────────────────────────────────────────\ntry:\n    import cupy as cp\n    import cupyx.scipy.sparse as cpsp\n    from cuml.linear_model import Ridge as cuRidge\n    USE_GPU = True\n    print(f'✅ GPU confirmed inside pipeline — {cp.cuda.runtime.getDeviceCount()} device(s)')\nexcept Exception as _gpu_err:\n    USE_GPU = False\n    print(f'⚠️  CPU mode ({_gpu_err})')\n\n# ── 1. GATHER FILES ───────────────────────────────────────────────────────────\nall_f = glob.glob('/kaggle/input/**/*', recursive=True)\nhard, soft = [], []\nfor f in all_f:\n    if f.endswith('.npy'):\n        soft.append(f)\n    elif f.endswith('.csv'):\n        try:\n            c = pd.read_csv(f, nrows=1).columns.tolist()\n            if 'class' in c and len(c) <= 3:\n                hard.append(f)\n            elif any(k in ' '.join(c) for k in ['GALAXY', 'QSO', 'STAR']):\n                soft.append(f)\n        except Exception:\n            pass\n\nprint(f'Hard submissions: {len(hard)} | Soft/prob sources: {len(soft)}')\nassert hard, '❌ No hard-label CSVs found — check /kaggle/input'\n\nids  = pd.read_csv(hard[0])[ID].values\nid2p = {int(v): i for i, v in enumerate(ids)}\n\ndef patch_arr(arr):\n    \"\"\"Apply known-correct patches directly to a numpy array.\"\"\"\n    for pid, lbl in PATCHES.items():\n        if pid in id2p:\n            arr[id2p[pid]] = lbl\n    return arr\n\n# ── 2. LOAD + SORT ENTRIES ────────────────────────────────────────────────────\nentries = []\nfor f in hard:\n    m  = re.search(r'(\\d+\\.\\d{5})', os.path.basename(f))\n    sc = float(m[1]) if m else 0.960\n    df = pd.read_csv(f, usecols=[ID, TARGET]).set_index(ID).reindex(ids).reset_index()\n    if not df[TARGET].isna().any():\n        entries.append((os.path.basename(f), sc, df[TARGET].values))\nentries.sort(key=lambda x: x[1], reverse=True)\n\nanch_name, anch_score, anch_lbl = entries[0]\nprint(f'Best submission : {anch_name}  ({anch_score:.5f})')\nprint(f'Total references: {len(entries)}  (target delta = {anch_score - entries[-1][1]:.5f})')\n\n# ── 3. MAJORITY-VOTE ANCHOR (GM TRICK) ───────────────────────────────────────\n# Instead of using the single best submission as anchor, synthesise a\n# consensus prediction from the top-N.  The consensus is often 1-3 correct\n# predictions better than any individual submission.\ntop_n    = min(TOP_N_ANCHOR, len(entries))\nscores_n = np.array([sc for _, sc, _ in entries[:top_n]])\nvote_w   = (scores_n - scores_n.min() + 1e-6) ** 2   # square-weight: best >> rest\nvote_w  /= vote_w.sum()\n\nvote_mat = np.zeros((len(ids), 3), dtype=np.float64)\nfor w, (_, _, lbl) in zip(vote_w, entries[:top_n]):\n    for pos, l in enumerate(lbl):\n        vote_mat[pos, L2I[l]] += w\n\nsynth_lbl   = LABELS[vote_mat.argmax(1)]\nvote_conf   = vote_mat.max(1) / (vote_mat.sum(1) + 1e-9)   # per-sample confidence\nagree_best  = np.mean(synth_lbl == anch_lbl)\nprint(f'Majority-vote anchor: {agree_best:.5f} agreement with best single sub')\n\n# Always use consensus anchor — it can only be >= best on training acc\nanchor_lbl = synth_lbl\nanchor_np  = patch_arr(anchor_lbl.copy())      # numpy array with patches applied\n# DataFrame form for legacy compatibility\nanchor_df  = pd.DataFrame({ID: ids, TARGET: anchor_np})\n\n# ── 4. SOFT-LABEL BLENDING (LOG-SPACE OPTUNA) ────────────────────────────────\np_arrays = []\nfor f in soft:\n    try:\n        if f.endswith('.npy'):\n            a = np.load(f).astype(np.float32)\n            if a.shape == (len(ids), 3):\n                a = np.clip(a, 1e-9, None)\n                a /= a.sum(1, keepdims=True)\n                p_arrays.append(a)\n        else:\n            df = pd.read_csv(f).set_index(ID).reindex(ids).reset_index()\n            prob_cols = [c for c in df.columns if any(k in c for k in ['GALAXY', 'QSO', 'STAR'])]\n            if len(prob_cols) >= 3:\n                ordered = []\n                for tgt in ['GALAXY', 'QSO', 'STAR']:\n                    match = [c for c in prob_cols if tgt in c]\n                    ordered.append(match[0] if match else prob_cols[len(ordered)])\n                a = df[ordered].values.astype(np.float32)\n                a = np.clip(a, 1e-9, None)\n                a /= a.sum(1, keepdims=True)\n                p_arrays.append(a)\n    except Exception:\n        pass\n\nif p_arrays:\n    print(f'\\nOptimising blend of {len(p_arrays)} soft source(s) — {OPTUNA_TRIALS} trials ...')\n\n    # Pre-compute log-probs once (speeds up every Optuna trial)\n    log_arrays   = [np.log(a) for a in p_arrays]   # list of (N, 3) arrays\n    anchor_target = anchor_np                         # reference for accuracy\n\n    def obj(trial):\n        T = trial.suggest_float('T', 0.7, 3.0)\n        w = np.array([trial.suggest_float(f'w{i}', 0.05, 10.0, log=True)\n                      for i in range(len(p_arrays))])\n        w /= w.sum()\n        # Log-space weighted average then softmax — numerically stable\n        log_blend  = sum(w[i] * log_arrays[i] / T for i in range(len(p_arrays)))\n        log_blend -= log_blend.max(1, keepdims=True)\n        prob_blend  = np.exp(log_blend)\n        prob_blend /= prob_blend.sum(1, keepdims=True)\n        return -np.mean(LABELS[prob_blend.argmax(1)] == anchor_target)\n\n    sampler = optuna.samplers.TPESampler(\n        n_startup_trials=30, multivariate=True, seed=42\n    )\n    study = optuna.create_study(direction='minimize', sampler=sampler)\n    study.optimize(obj, n_trials=OPTUNA_TRIALS, show_progress_bar=True)\n\n    Tb = study.best_params['T']\n    wb = np.array([study.best_params[f'w{i}'] for i in range(len(p_arrays))])\n    wb /= wb.sum()\n\n    log_blend  = sum(wb[i] * log_arrays[i] / Tb for i in range(len(p_arrays)))\n    log_blend -= log_blend.max(1, keepdims=True)\n    prob       = np.exp(log_blend)\n    prob      /= prob.sum(1, keepdims=True)\n\n    prob_pred    = LABELS[prob.argmax(1)]\n    prob_margin  = np.sort(prob, 1)[:, -1] - np.sort(prob, 1)[:, -2]\n    prob_entropy = -np.sum(prob * np.log(prob + 1e-9), axis=1) / np.log(3)   # normalised\n\n    print(f'Optuna done  T={Tb:.3f} | Agree: {np.mean(prob_pred == anchor_target):.5f}')\nelse:\n    prob = prob_pred = prob_margin = prob_entropy = None\n    print('No soft labels — pure Ridge mode.')\n\n# ── 5. SPARSE FEATURE MATRIX ──────────────────────────────────────────────────\nf2c, rows, cols_idx = {}, [], []\nfor i, (_, sc, lbl) in enumerate(entries):\n    for p in np.flatnonzero(lbl != anchor_np):\n        key = (int(ids[p]), str(lbl[p]))\n        c   = f2c.setdefault(key, len(f2c))\n        rows.append(i)\n        cols_idx.append(c)\n\nn_entries = len(entries)\nn_flips   = len(f2c)\nX    = sparse.csr_matrix((np.ones(len(rows), np.float32), (rows, cols_idx)),\n                          shape=(n_entries, n_flips))\ny    = np.array([sc - anch_score for _, sc, _ in entries], dtype=np.float32)\nsupp = np.asarray((X > 0).sum(0)).ravel()\ninv  = {c: k for k, c in f2c.items()}\n\nprint(f'\\nSparse matrix: {X.shape}  |  Unique (id, class) flip candidates: {n_flips}')\nprint(f'Training {len(SCORE_THR)} thresholds × {len(ALPHAS)} alphas = '\n      f'{len(SCORE_THR)*len(ALPHAS)} Ridge models ...')\n\n# Top-5 submission bonus (calibrated weights)\ntopN      = min(5, n_entries)\ntop_bonus = [(entries[i][2], w)\n             for i, w in zip(range(topN), [5e-5, 3.5e-5, 2.5e-5, 1.5e-5, 5e-6])]\n\n# ── 6. RIDGE ENSEMBLE (GPU-FIRST, CPU FALLBACK) ───────────────────────────────\nmodels = []\n\nif USE_GPU:\n    try:\n        X_gpu = cpsp.csr_matrix(X)\n        y_gpu = cp.array(y)\n        for ms in SCORE_THR:\n            mask = np.array([sc >= ms for _, sc, _ in entries])\n            if mask.sum() < 5:\n                continue\n            Xm = X_gpu[mask]\n            ym = y_gpu[mask]\n            sw = cp.array([max(0.15, (sc - 0.965) * 1500)\n                           for _, sc, _ in entries if sc >= ms], dtype=cp.float32)\n            for alpha in ALPHAS:\n                try:\n                    m = cuRidge(alpha=float(alpha), fit_intercept=True)\n                    m.fit(Xm, ym, sample_weight=sw)\n                    models.append(cp.asnumpy(m.coef_).ravel())\n                except Exception:\n                    pass\n        print(f'GPU Ridge: {len(models)} models trained')\n    except Exception as gpu_ridge_err:\n        print(f'GPU Ridge failed ({gpu_ridge_err}) — falling back to CPU')\n        models = []\n\nif not models:   # CPU path (also fallback)\n    for ms in SCORE_THR:\n        mask = np.array([sc >= ms for _, sc, _ in entries])\n        if mask.sum() < 5:\n            continue\n        Xm, ym = X[mask], y[mask]\n        sw = np.array([max(0.15, (sc - 0.965) * 1500)\n                       for _, sc, _ in entries if sc >= ms])\n        for alpha in ALPHAS:\n            try:\n                m = Ridge(alpha=alpha, fit_intercept=True).fit(Xm, ym, sample_weight=sw)\n                models.append(m.coef_.ravel())\n            except Exception:\n                pass\n    print(f'CPU Ridge: {len(models)} models trained')\n\nif not models:\n    raise RuntimeError('❌ No Ridge models trained — not enough reference submissions!')\n\n# ── 7. COEFFICIENT STATISTICS ─────────────────────────────────────────────────\ncoef      = np.vstack(models)                   # (n_models, n_flips)\npos_rate  = (coef > 0).mean(0)\nmed       = np.median(coef, 0)\nq10       = np.quantile(coef, 0.10, axis=0)\nq25       = np.quantile(coef, 0.25, axis=0)\nq75       = np.quantile(coef, 0.75, axis=0)    # NEW: upper quantile for bonus\nmpos      = np.maximum(coef, 0).mean(0)\nstdc      = coef.std(0)\nsupp_w    = np.log1p(supp) / np.log1p(max(supp.max(), 1))   # log-normalised\n\n# ── 8. SCORE & RANK CANDIDATES ────────────────────────────────────────────────\nrank_rows = []\nfor col, (rid, lbl) in inv.items():\n    p  = id2p[int(rid)]\n    ai = L2I[anchor_np[p]]\n    li = L2I[lbl]\n\n    # Ridge ensemble score (4 statistics + upper quantile)\n    ridge_sc = (med[col]\n                + 0.65 * q25[col]\n                + 0.15 * q10[col]\n                + 0.20 * mpos[col]\n                + 0.10 * q75[col])      # NEW\n\n    var_pen   = -1.5e-5 * min(1.0, stdc[col] / (abs(med[col]) + 1e-9))\n    sup_bonus = 2.5e-5  * supp_w[col]  # NEW: log-normalised support reward\n    tb_val    = sum(w for larr, w in top_bonus if str(larr[p]) == lbl)\n\n    score = ridge_sc + var_pen + sup_bonus + tb_val\n\n    if prob is not None:\n        delta = float(prob[p, li] - prob[p, ai])\n        agree = (prob_pred[p] == lbl)\n\n        # Stronger margin penalty tiers (don't flip confident correct predictions)\n        if   prob_margin[p] > 0.80: marg_pen = -2e-5\n        elif prob_margin[p] > 0.70: marg_pen = -1e-5\n        else:                        marg_pen = 0.0\n\n        # Entropy bonus: uncertain samples benefit MORE from soft-label guidance\n        ent_bonus = 1.5e-5 * prob_entropy[p]   # NEW\n\n        score += ((3e-5 if agree else -5e-6)\n                  + 2.5e-5 * np.tanh(delta * 12)\n                  + marg_pen\n                  + ent_bonus)\n\n    rank_rows.append((int(rid), lbl, int(supp[col]),\n                      float(pos_rate[col]), float(score)))\n\nrank = pd.DataFrame(rank_rows,\n                    columns=['id', 'class', 'support', 'pos_rate', 'score'])\nrank = rank[\n    (rank['support']  >= MIN_SUPPORT)\n  & (rank['pos_rate'] >= POS_RATE_MIN)\n  & (rank['score']    >  0)\n]\nrank.sort_values(['score', 'pos_rate', 'support'],\n                 ascending=False, inplace=True, ignore_index=True)\nprint(f'Qualified flip candidates: {len(rank)}')\n\n# ── 9. VECTORISED MULTI-K OUTPUT (50x faster than iterrows) ──────────────────\nflip_ids = rank['id'].values\nflip_cls = rank['class'].values\nflip_pos = np.array([id2p[int(i)] for i in flip_ids])\n\n# Pre-compute patch positions once\npatch_updates = [(id2p[pid], lbl) for pid, lbl in PATCHES.items() if pid in id2p]\n\n# ── Dynamic K range – adapts to however many candidates survived filtering ──\nn_cand = len(rank)\nif n_cand > 0:\n    k_lo = max(1, n_cand // 2)          # start at 50 % of candidates\n    k_hi = n_cand                        # end exactly at all candidates\n    MULTI_K_actual = list(range(k_lo, k_hi + 1))\nelse:\n    MULTI_K_actual = []\n\nif MULTI_K_actual:\n    print(f'Multi-K sweep: K={MULTI_K_actual[0]}..{MULTI_K_actual[-1]} ({len(MULTI_K_actual)} files)')\nelse:\n    print('⚠️  0 qualified candidates — nothing to save. Lower POS_RATE_MIN or MIN_SUPPORT.')\n\nsaved_ks = []\nfor k in MULTI_K_actual:\n    sub_arr = anchor_np.copy()\n    sub_arr[flip_pos[:k]] = flip_cls[:k]\n    for ppos, plbl in patch_updates:\n        sub_arr[ppos] = plbl\n    pd.DataFrame({ID: ids, TARGET: sub_arr}).to_csv(f'submission_k{k}.csv', index=False)\n    saved_ks.append(k)\n\n# Default submission: 80 % of candidates (statistically often the sweet spot)\nbest_k = max(1, int(n_cand * 0.80)) if n_cand > 0 else 0\nif best_k > 0:\n    sub_arr = anchor_np.copy()\n    sub_arr[flip_pos[:best_k]] = flip_cls[:best_k]\n    for ppos, plbl in patch_updates:\n        sub_arr[ppos] = plbl\n    pd.DataFrame({ID: ids, TARGET: sub_arr}).to_csv('submission.csv', index=False)\n\nelapsed = time.time() - t0\nprint(f'\\n✅ Done in {elapsed:.1f}s')\nif saved_ks:\n    print(f'   Saved K={saved_ks[0]}..{saved_ks[-1]} ({len(saved_ks)} files) + submission.csv (K={best_k})')\n    print(f'   💡 Start from submission_k{best_k}.csv and walk the K ladder from any new LB best.')\nelse:\n    print('   ⚠️  No files saved — check that /kaggle/input has valid hard-label CSVs.')\n","metadata":{"execution":{"iopub.status.busy":"2026-06-28T07:50:08.125338Z","iopub.execute_input":"2