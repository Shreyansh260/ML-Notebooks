ut[f\"{b1}_minus_{b2}\"] = out[b1] - out[b2]\n\n    # 3. Color ratios (adjacent bands)\n    if len(bands) >= 2:\n        for i in range(len(bands) - 1):\n            b1, b2 = bands[i], bands[i + 1]\n            out[f\"{b1}_div_{b2}\"] = out[b1] / (out[b2] + 1e-8)\n\n    # 4. Magnitude statistics\n    if len(bands) >= 3:\n        band_vals = out[bands].values\n        out[\"mag_mean\"] = band_vals.mean(axis=1)\n        out[\"mag_std\"] = band_vals.std(axis=1)\n        out[\"mag_max\"] = band_vals.max(axis=1)\n        out[\"mag_min\"] = band_vals.min(axis=1)\n        out[\"mag_range\"] = out[\"mag_max\"] - out[\"mag_min\"]\n        out[\"mag_median\"] = np.median(band_vals, axis=1)\n        out[\"mag_skew\"] = (\n            3.0 * (out[\"mag_mean\"] - out[\"mag_median\"]) / (out[\"mag_std\"] + 1e-8)\n        )\n        out[\"mag_kurtosis\"] = (\n            ((band_vals - band_vals.mean(axis=1, keepdims=True)) ** 4).mean(axis=1)\n            / ((band_vals.var(axis=1) + 1e-8) ** 2)\n            - 3.0\n        )\n\n    # 5. Redshift features\n    if has_redshift:\n        out[\"redshift_log1p\"] = np.log1p(np.abs(out[\"redshift\"])) * np.sign(out[\"redshift\"])\n        out[\"redshift_sq\"] = out[\"redshift\"] ** 2\n        out[\"redshift_cube\"] = out[\"redshift\"] ** 3\n        out[\"redshift_sqrt\"] = np.sqrt(np.abs(out[\"redshift\"])) * np.sign(out[\"redshift\"])\n        out[\"redshift_abs\"] = np.abs(out[\"redshift\"])\n        out[\"redshift_inv\"] = 1.0 / (np.abs(out[\"redshift\"]) + 1e-8)\n\n        if len(bands) >= 2:\n            for i in range(len(bands) - 1):\n                b1, b2 = bands[i], bands[i + 1]\n                out[f\"redshift_x_{b1}_{b2}\"] = out[\"redshift\"] * (out[b1] - out[b2])\n            if \"mag_mean\" in out.columns:\n                out[\"redshift_x_mag_mean\"] = out[\"redshift\"] * out[\"mag_mean\"]\n            if \"mag_std\" in out.columns:\n                out[\"redshift_x_mag_std\"] = out[\"redshift\"] * out[\"mag_std\"]\n\n    # 6. Redshift bins\n    if has_redshift and len(bands) >= 2:\n        out[\"redshift_bin\"] = pd.qcut(\n            out[\"redshift\"], q=50, labels=False, duplicates=\"drop\"\n        )\n\n    return out\n\n\ntrain_df = pd.read_csv(COMP_DIR / \"train.csv\")\ntest_df = pd.read_csv(COMP_DIR / \"test.csv\")\n\nprint(f\"  Train shape: {train_df.shape}\")\nprint(f\"  Test shape:  {test_df.shape}\")\nprint(f\"  Classes:     {train_df[TARGET].value_counts().to_dict()}\")\n\ny_train = train_df[TARGET].map(L2I).values.astype(np.int32)\ntest_ids = test_df[ID].values\n\ntrain_fe = engineer_features(train_df)\ntest_fe = engineer_features(test_df)\n\nFEATURE_COLS = [c for c in test_fe.columns if c not in [ID, TARGET, \"class\"]]\n\n# Handle categorical columns\ncat_cols = []\nnum_cols = []\nfor col in FEATURE_COLS:\n    if test_fe[col].dtype == \"object\":\n        from sklearn.preprocessing import LabelEncoder\n        le = LabelEncoder()\n        combined = pd.concat([\n            train_fe[col].fillna(\"__MISSING__\"),\n            test_fe[col].fillna(\"__MISSING__\")\n        ])\n        le.fit(combined)\n        train_fe[col] = le.transform(train_fe[col].fillna(\"__MISSING__\"))\n        test_fe[col] = le.transform(test_fe[col].fillna(\"__MISSING__\"))\n        cat_cols.append(col)\n    else:\n        num_cols.append(col)\n\nX_train = train_fe[FEATURE_COLS].values.astype(np.float32)\nX_test = test_fe[FEATURE_COLS].values.astype(np.float32)\n\nX_train = np.nan_to_num(X_train, nan=0.0, posinf=1e10, neginf=-1e10)\nX_test = np.nan_to_num(X_test, nan=0.0, posinf=1e10, neginf=-1e10)\n\nprint(f\"  Feature count: {len(FEATURE_COLS)}\")\nprint(f\"  X_train: {X_train.shape}, X_test: {X_test.shape}\")\n\ndel train_df, test_df, train_fe, test_fe\ngc.collect()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-27T07:03:13.187011Z","iopub.execute_input":"2026-06-27T07:03:13.187286Z","iopub.status.idle":"2026-06-27T07:03:17.983676Z","shell.execute_reply.started":"2026-06-27T07:03:13.187259Z","shell.execute_reply":"2026-06-27T07:03:17.982822Z"}},"outputs":[{"name":"stdout","text":"\n[PHASE 0] Loading data & feature engineering...\n  Train shape: (577347, 12)\n  Test shape:  (247435, 11)\n  Classes:     {'GALAXY': 377480, 'QSO': 117143, 'STAR': 82724}\n  Feature count: 56\n  X_train: (577347, 56), X_test: (247435, 56)\n","output_type":"stream"},{"execution_count":3,"output_type":"execute_result","data":{"text/plain":"30"},"metadata":{}}],"execution_count":3},{"id":"4f470ce8-c2c5-4000-a2f4-86e62765816b","cell_type":"markdown","source":"## PHASE 1: MULTI-MODEL OOF TRAINING","metadata":{}},{"id":"d92e715b-f79f-4132-862e-dc6430582957","cell_type":"code","source":"print(\"\\n[PHASE 1] Training diverse base models with OOF predictions...\")\n\n\ndef train_lightgbm_oof(X, y, X_test, n_folds, seed, params_override=None):\n    import lightgbm as lgb\n\n    base_params = {\n        \"objective\": \"multiclass\",\n        \"num_class\": 3,\n        \"metric\": \"multi_logloss\",\n        \"verbosity\": -1,\n        \"n_jobs\": -1,\n        \"device\": \"gpu\",\n        \"gpu_use_dp\": False,\n        \"learning_rate\": 0.03,\n        \"num_leaves\": 63,\n        \"max_depth\": -1,\n        \"min_child_samples\": 20,\n        \"feature_fraction\": 0.8,\n        \"bagging_fraction\": 0.8,\n        \"bagging_freq\": 5,\n        \"reg_alpha\": 0.1,\n        \"reg_lambda\": 1.0,\n        \"is_unbalance\": True,\n        \"seed\": seed,\n    }\n    if params_override:\n        base_params.update(params_override)\n\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        dtrain = lgb.Dataset(X[train_idx], y[train_idx])\n        dval = lgb.Dataset(X[val_idx], y[val_idx], reference=dtrain)\n        model = lgb.train(\n            base_params, dtrain, num_boost_round=3000,\n            valid_sets=[dval],\n            callbacks=[lgb.early_stopping(100, verbose=False), lgb.log_evaluation(0)],\n        )\n        oof_proba[val_idx] = model.predict(X[val_idx])\n        test_proba += model.predict(X_test) / n_folds\n        del model, dtrain, dval\n        gc.collect()\n\n    ba = balanced_accuracy_score(LABELS[y], LABELS[oof_proba.argmax(axis=1)])\n    return oof_proba, test_proba, ba\n\n\ndef train_xgboost_oof(X, y, X_test, n_folds, seed, params_override=None):\n    import xgboost as xgb\n\n    base_params = {\n        \"objective\": \"multi:softprob\",\n        \"num_class\": 3,\n        \"eval_metric\": \"mlogloss\",\n        \"verbosity\": 0,\n        \"nthread\": -1,\n        \"learning_rate\": 0.03,\n        \"max_depth\": 8,\n        \"min_child_weight\": 5,\n        \"subsample\": 0.8,\n        \"colsample_bytree\": 0.8,\n        \"reg_alpha\": 0.1,\n        \"reg_lambda\": 1.0,\n        \"tree_method\": \"hist\",\n        \"device\": \"cuda\",\n        \"seed\": seed,\n    }\n    if params_override:\n        base_params.update(params_override)\n\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    class_counts = np.bincount(y, minlength=3)\n    class_weights = len(y) / (3.0 * class_counts)\n    sample_weights = class_weights[y]\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        dtrain = xgb.DMatrix(X[train_idx], y[train_idx], weight=sample_weights[train_idx])\n        dval = xgb.DMatrix(X[val_idx], y[val_idx], weight=sample_weights[val_idx])\n        model = xgb.train(\n            base_params, dtrain, num_boost_round=3000,\n            evals=[(dval, \"val\")], early_stopping_rounds=100, verbose_eval=0,\n        )\n        oof_proba[val_idx] = model.predict(xgb.DMatrix(X[val_idx]),\n                                            iteration_range=(0, model.best_iteration + 1))\n        test_proba += model.predict(xgb.DMatrix(X_test),\n                                     iteration_range=(0, model.best_iteration + 1)) / n_folds\n        del model, dtrain, dval\n        gc.collect()\n\n    ba = balanced_accuracy_score(LABELS[y], LABELS[oof_proba.argmax(axis=1)])\n    return oof_proba, test_proba, ba\n\n\ndef train_catboost_oof(X, y, X_test, n_folds, seed, params_override=None):\n    from catboost import CatBoostClassifier\n\n    base_params = {\n        \"iterations\": 3000,\n        \"learning_rate\": 0.03,\n        \"depth\": 8,\n        \"l2_leaf_reg\": 3.0,\n        \"random_seed\": seed,\n        \"verbose\": 0,\n        \"early_stopping_rounds\": 100,\n        \"auto_class_weights\": \"Balanced\",\n        \"eval_metric\": \"MultiClass\",\n        \"task_type\": \"GPU\",\n        \"devices\": \"0\",\n    }\n    if params_override:\n        base_params.update(params_override)\n\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        model = CatBoostClassifier(**base_params)\n        model.fit(X[train_idx], y[train_idx], eval_set=(X[val_idx], y[val_idx]))\n        oof_proba[val_idx] = model.predict_proba(X[val_idx])\n        test_proba += model.predict_proba(X_test) / n_folds\n        del model\n        gc.collect()\n\n    ba = balanced_accuracy_score(LABELS[y], LABELS[oof_proba.argmax(axis=1)])\n    return oof_proba, test_proba, ba\n\n\ndef train_extratrees_oof(X, y, X_test, n_folds, seed):\n    oof_proba = np.zeros((len(X), 3), dtype=np.float64)\n    test_proba = np.zeros((len(X_test), 3), dtype=np.float64)\n    skf = StratifiedKFold(n_splits=n_folds, shuffle=True, random_state=seed)\n\n    for fold, (train_idx, val_idx) in enumerate(skf.split(X, y)):\n        model = ExtraTreesClassifier(\n            n_estimators=800, max_depth=None, min_samples_leaf=2,\n            max_features=\"sqrt\", class_weight=\"balanced\",\n            n_jobs=-1, random_state=seed + fold,\n        )\n        model.fit(X[train_idx], y[train_idx])\n        oof_proba[val_idx] = model.predict_proba(X[val_idx])\n        test_proba += model.predict_proba(X_test) / n_folds\n        del model\n        gc.collect()\n\n    ba = balanced_accuracy_score(LABELS[y], LABELS[oof_proba.argmax(axis=1)])\n    return oof_proba, test_proba, ba","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-27T07:03:17.984863Z","iopub.execute_input":"2026-06-27T07:03:17.985104Z","iopub.status.idle":"2026-06-27T07:03:18.004473Z","shell.execute_reply.started":"2026-06-27T07:03:17.985084Z","shell.execute_reply":"2026-06-27T07:03:18.00346Z"}},"outputs":[{"name":"stdout","text":"\n[PHASE 1] Training diverse base models with OOF predictions...\n","output_type":"stream"}],"execution_count":4},{"id":"314df11c-dbbd-4deb-8ebb-517600aebc5e","cell_type":"code","source":"# ---------------------------------------------------------------------------\n# Train all models\n# ---------------------------------------------------------------------------\nall_oof = []\nall_test = []\nmodel_names = []\n\n# LightGBM configs (3 diverse architectures × 3 seeds = 9 models)\nlgb_configs = [\n    {\"num_leaves\": 63, \"learning_rate\": 0.03, \"min_child_samples\": 20},\n    {\"num_leaves\": 127, \"learning_rate\": 0.02, \"min_child_samples\": 10},\n    {\"num_leaves\": 255, \"learning_rate\": 0.01, \"min_child_samples\": 5, \"feature_fraction\": 0.7},\n]\n\nfor cfg_idx, cfg in enumerate(lgb_configs):\n    for seed in range(42, 42 + N_SEEDS_GBDT):\n        name = f\"lgb_cfg{cfg_idx}_s{seed}\"\n        print(f\"  Training {name}...\", end=\" \")\n        t0 = time.time()\n        oof, tst, ba = train_lightgbm_oof(X_train, y_train, X_test, N_FOLDS, seed, cfg)\n        print(f\"BA={ba:.5f} ({time.time()-t0:.0f}s)\")\n        all_oof.append(oof)\n        all_test.append(tst)\n        model_names.append(name)\n\n# XGBoost configs (3 × 3 = 9 models)\nxgb_configs = [\n    {\"max_depth\": 8, \"learning_rate\": 0.03, \"min_child_weight\": 3},\n    {\"max_depth\": 10, \"learning_rate\": 0.02, \"min_child_weight\": 5, \"colsample_bytree\": 0.7},\n    {\"max_depth\": 6, \"learning_rate\": 0.05, \"min_child_weight\": 10, \"subsample\": 0.7},\n]\n\nfor cfg_idx, cfg in enumerate(xgb_configs):\n    for seed in range(42, 42 + N_SEEDS_GBDT):\n        name = f\"xgb_cfg{cfg_idx}_s{seed}\"\n        print(f\"  Training {name}...\", end=\" \")\n        t0 = time.time()\n        oof, tst, ba = train_xgboost_oof(X_train, y_train, X_test, N_FOLDS, seed, cfg)\n        print(f\"BA={ba:.5f} ({time.time()-t0:.0f}s)\")\n        all_oof.append(oof)\n        all_test.append(tst)\n        model_names.append(name)\n\n# CatBoost configs (2 × 3 = 6 models)\ncat_configs = [\n    {\"depth\": 8, \"learning_rate\": 0.03, \"l2_leaf_reg\": 1.0},\n    {\"depth\": 10, \"learning_rate\": 0.02, \"l2_leaf_reg\": 5.0},\n]\n\nfor cfg_idx, cfg in enumerate(cat_configs):\n    for seed in range(42, 42 + N_SEEDS_GBDT):\n        name = f\"cat_cfg{cfg_idx}_s{seed}\"\n        print(f\"  Training {name}...\", end=\" \")\n        t0 = time.time()\n        oof, tst, ba = train_catboost_oof(X_train, y_train, X_test, N_FOLDS, seed, cfg)\n        print(f\"BA={ba:.5f} ({time.time()-t0:.0f}s)\")\n        all_oof.append(oof)\n        all_test.append(tst)\n        model_names.append(name)\n\n# ExtraTrees (2 seeds)\nfor seed in [42, 43]:\n    name = f\"et_s{seed}\"\n    print(f\"  Training {name}...\", end=\" \")\n    t0 = time.time()\n    oof, tst, ba = train_extratrees_oof(X_train, y_train, X_test, N_FOLDS, seed)\n    print(f\"BA={ba:.5f} ({time.time()-t0:.0f}s)\")\n    all_oof.append(oof)\n    all_test.append(tst)\n    model_names.append(name)\n\nprint(f\"\\n  Total base models: {len(model_names)}\")","metadata":{"trust