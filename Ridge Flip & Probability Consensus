m sklearn.metrics import balanced_accuracy_score\nfrom sklearn.ensemble import ExtraTreesClassifier\nimport optuna\n\noptuna.logging.set_verbosity(optuna.logging.WARNING)\nwarnings.filterwarnings(\"ignore\")","metadata":{"execution":{"iopub.status.busy":"2026-06-27T07:03:10.009722Z","iopub.execute_input":"2026-06-27T07:03:10.01028Z"}}},{"id":"343b447e-4496-4fa4-a069-f83f4782873d","cell_type":"markdown","source":"## CONFIG","metadata":{}},{"id":"6636bea6-2a4a-4c96-8f7e-300cb15b55d6","cell_type":"code","source":"ID = 'id'\nTARGET = 'class'\nLABELS = np.array(['GALAXY', 'QSO', 'STAR'], dtype=object)\nL2I = {label: i for i, label in enumerate(LABELS)}\n\n# Kaggle paths\nCOMP_DIR = Path('/kaggle/input/competitions/playground-series-s6e6')\nDATA_DIR = Path('/kaggle/input/datasets/fachri00/s6e6-submission')\nNEW_DATA_DIR = Path('/kaggle/input/datasets/raunakdey07/s6e6-stellar-class-prediction')\nWORK_DIR = Path('/kaggle/working')\nWORK_DIR.mkdir(parents=True, exist_ok=True)\n\nSTART_ANCHOR_FILE = NEW_DATA_DIR / 'submission 0.97244.csv'\nSTART_ANCHOR_SCORE = 0.97244\nROUND_K = 2\n\n# Feedback scores from previous LB submissions\nROUND_FEEDBACK_SCORES = [0.97245, 0.97246]\n\nFEEDBACK_CSV = DATA_DIR / 'feedback_scores.csv'\n\nNEGATIVE_FEEDBACK_NAMES = {\n    'recent_corr_rank_k3',\n    'recent_wc_k35',\n    'recent_sparse_delta_k5',\n    'recent_patch_lr_k30',\n    'new_stack_submission',\n}\n\n# Model training config\nN_FOLDS = 5\nN_SEEDS_GBDT = 3  # more seeds for stability\n\nprint(\"=\" * 70)\nprint(\"ADVANCED RIDGE FLIP + PROBABILITY CONSENSUS V4\")\nprint(\"Target: 0.978+ Public LB\")\nprint(\"=\" * 70)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-06-27T07:03:13.17558Z","iopub.execute_input":"2026-06-27T07:03:13.17601Z","iopub.status.idle":"2026-06-27T07:03:13.185648Z","shell.execute_reply.started":"2026-06-27T07:03:13.175979Z","shell.execute_reply":"2026-06-27T07:03:13.18471Z"}},"outputs":[{"name":"stdout","text":"=================================