ources\n\nADD_EXTERN_DATA = False       # Extend dataset folds seperately with external dataset\n\ndef merge_extern_data(df, external):\n    df_columns = [col for col in df.columns if col not in ['id', 'multicat', 'strat_bin']]\n    df_merged = pd.concat([df[df_columns], external[df_columns]],\n                          ignore_index=True).reset_index(names='id')\n    df_merged = df_merged.drop_duplicates()\n    return df_merged","metadata":{"execution":{"iopub.status.busy":"2026-07-03T06:37:10.5474Z","iopub.execute_input":"2026-07-03T06:37:10.547653Z","iopub.status.idle":"2026-07-03T06:37:10.561415Z","shell.execute_reply.started":"2026-07-03T06:37:10.547626Z","shell.execute_reply":"2026-07-03T06:37:10.560551Z"},"papermill":{"duration":0.016247,"end_time":"2026-07-02T06:17:46.198326+00:00","exception":false,"start_time":"2026-07-02T06:17:46.182079+00:00","status":"completed"},"tags":[],"trusted":true},"outputs":[],"execution_count":19},{"id":"adv-validation-md","cell_type":"markdown","source":"## Adversarial validation (train vs. test distribution shift check)","metadata":{"tags":[]}},{"id":"adv-validation-code","cell_type":"code","source":"## Adversarial validation: detect train/test covariate shift (advanced Kaggle trick)\n# Train a GPU classifier to distinguish trainval rows from test rows. Features with high\n# importance here are the ones whose distribution differs between train and test -- prime\n# candidates to drop or downweight, since a model can \"cheat\" on them without generalizing.\n\nDROP_DRIFT_FEATURES = False   # Set True to actually remove the top drifting features below\nN_DRIFT_FEATURES_TO_FLAG = 10\n\n# Defined locally (this cell runs before the section-5 model-space cell that also sets GPU_ACC)\nGPU_ACC = torch.cuda.is_available()\n\nadv_features = num_columns + cat_columns\nadv_df = pd.concat([\n    trainval[adv_features].assign(is_test=0),\n    test[adv_features].assign(is_test=1)\n], ignore_index=True)\n\nadv_cat = make_column_selector(dtype_i