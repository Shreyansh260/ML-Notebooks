X.iloc[tr_idx], adv_y.iloc[tr_idx])\n    adv_oof[va_idx] = adv_model.predict_proba(adv_X.iloc[va_idx])[:, 1]\n\nfrom sklearn.metrics import roc_auc_score\nadv_auc = roc_auc_score(adv_y, adv_oof)\nprint(f'Adversarial validation AUC (0.5 = train/test indistinguishable, 1.0 = fully separable): {adv_auc:.4f}')\n\nadv_model.fit(adv_X, adv_y)\nadv_importance = pd.Series(adv_model.feature_importances_, index=adv_features).sort_values(ascending=False)\ndrift_features = adv_importance.head(N_DRIFT_FEATURES_TO_FLAG).index.tolist()\nprint(f'Top {N_DRIFT_FEATURES_TO_FLAG} features driving train/test separability:')\nprint(adv_importance.head(N_DRIFT_FEATURES_TO_FLAG))\n\nif DROP_DRIFT_FEATURES:\n    num_columns = [c for c in num_columns if c not in drift_features]\n    cat_columns = [c for c in cat_columns if c not in drift_features]\n    print(f'Dropped {len(drift_features)} drifting features. Remaining: {len(num_columns)} numeric, {len(cat_columns)} categorical')","metadata":{"tags":[]},"outputs":[],"execution_count":null},{"id":"fadeaf1b","cell_type":"markdown","source":"# 5. Define model space for ML methods","metadata":{"papermill":{"duration":0.009399,"end_time":"2026-07-02T06:17:46.217514+00:00","exception":false,"start_time":"2026-07-02T06:17:46.208115+00:00","status":"completed"},"tags":[]}},{"id":"ddafe580","cell_type":"code","source":"## Machine learning models and their hyperparameter search space\n\nGPU_ACC = torch.cuda.is_available()\nprint(f'GPU acceleration active: {GPU_ACC}')\nif GPU_ACC:\n    print(f'GPU device: {torch.cuda.get_device_name(0)}')\n\n# Models\nsvc = SVC(kernel='rbf', class_weight='balanced', random_state=42)\nrfc = RandomForestClassifier(class_weight='balanced', random_state=42) #ExtraTreesClassifier\nkneigh = KNeighborsClassifier()\ngbc = GradientBoostingClassifier(random_state=42)\nxgb = xgboost.XGBClassifier(objective='multi:softprob', eval_metric='mlogloss', num_class=3,\n                            enable_categorical=True, device='cuda' if 