nd non-plausible or missing values\n\n#trainval = trainval.dropna().reset_index(drop=True)\n#extern_data = extern_data.dropna().reset_index(drop=True)","metadata":{"execution":{"iopub.execute_input":"2026-07-02T06:16:51.870554Z","iopub.status.busy":"2026-07-02T06:16:51.869911Z","iopub.status.idle":"2026-07-02T06:16:51.87374Z","shell.execute_reply":"2026-07-02T06:16:51.872924Z"},"papermill":{"duration":0.011495,"end_time":"2026-07-02T06:16:51.875166+00:00","exception":false,"start_time":"2026-07-02T06:16:51.863671+00:00","status":"completed"},"tags":[]},"outputs":[],"execution_count":3},{"id":"19c2b5a5","cell_type":"code","source":"## Handcrafted feature engineering\n\n# Physics-based feature engineering\norig_num_columns = [col for col in make_column_selector(dtype_include=['float', 'int'])(trainval) if col not in ['id']]\n\n# Pick the highest-variance numeric columns to build interaction/ratio features from.\n# Using variance (computed once on trainval only, never touching test labels) keeps this leakage-free.\n_TOP_K_INTERACTIONS = 6\n_top_var_cols = trainval[orig_num_columns].var().sort_values(ascending=False).head(_TOP_K_INTERACTIONS).index.tolist()\n\ndef feature_engineering(df):\n    df = df.copy()\n    eps = 1e-6\n\n    ## --- Row-wise statistical features across all original numeric columns ---\n    num_block = df[orig_num_columns]\n    df['row_mean']   = num_block.mean(axis=1)\n    df['row_std']    = num_block.std(axis=1)\n    df['row_min']    = num_block.min(axis=1)\n    df['row_max']    = num_block.max(axis=1)\n    df['row_sum']    = num_block.sum(axis=1)\n    df['row_range']  = df['row_max'] - df['row_min']\n    df['row_median'] = num_block.median(axis=1)\n    df['row_skew']   = num_block.skew(axis=1)\n    df['row_nan_count'] = num_block.isna().sum(axis=1).astype('int16')\n\n    ## --- Pairwise interaction features (ratio / diff / product) on top-variance columns ---\n    for c1, c2 in combinations(_top_var_cols, 2):\n        df[f'{c1}_div_{c2}']  = df[c1] / (df[c2].abs() + eps)\n        df[f'{c1}_minus_{c2}'] = df[c1] - df[c2]\n        df[f'{c1}_x_{c2}']    = df[c1] * df[c2]\n\n    ## --- Simple per-row outlier flag based on global (trainval-only) column z-scores ---\n    z_scores = (num_block - trainval[orig_num_columns].mean()) / (trainval[orig_num_columns].std() + eps)\n    df['row_outlier_count'] = (z_scores.abs() > 3).sum(axis=1).astype('int16')\n\n    return df\n\ntrainval = feature_engineering(trainval)\nextern_data = feature_engineering(extern_data)\ntest = feature_engineering(test)\n\nprint(f'Added {len(_top_var_cols)*3 + 9} handcrafted numeric features '\n      f'(row-stats + pairwise interactions of {_top_var_cols})')","metadata":{"execution":{"iopub.execute_input":"2026-07-02T06:16:51.886122Z","iopub.status.busy":"2026-07-02T06:16:51.885784Z","iopub.status.idle":"2026-07-02T06:16:51.980034Z","shell.execute_reply":"2026-07-02T06:16:51.979033Z"},"tags":[]},"outputs":[],"execution_count":null},{"id":"98699ec2","cell_type":"code","source":"## General feature engineering\n\n# Target column\ntarget = 'health_condition'\nlabel_mapping = {'at-risk': 0, 'unhealthy': 1, 'fit': 2}\nreverse_label_mapping = {v: k for k, v in label_mapping.items()}\ntrainval[target] = trainval[target].map(label_mapping).astype(np.uint8)\nextern_data[target] = extern_data[target].map(label_mapping).astype(np.uint8)\n\n# Declare low cardinality integer features as categorical\ncolumns_to_cat = []\nfor df in [trainval, extern_data, test]:\n    df[columns_to_cat] = df[columns_to_cat].astype('object')\norig_cat_columns = [col for col in make_column_selector(dtype_include='object')(trainval) if col not in ['class']]\n\n# Create n-grams from selected categorical columns\nN_GRAMS = [2]          # Choose n-grams to derive (2-grams = pairwise categorical crosses, a strong Kaggle trick)\nN_GRAMS_EXT = True     # Choose whether to add n-grams to categorical features\n\n# Auto-select the 2 highest-cardinality (but not too sparse) categorical columns for n-gram crossing\n# instead of hardcoding column names -- keeps this notebook data-agnostic.\n_cat_card = trainval[orig_cat_columns].nunique().sort_values(ascending=False)\ncat_columns2ngrams = _cat_card.index.tolist()[:2] if len(orig_cat_columns) >= 2 else orig_cat_columns\n\ndef create_ngrams(df, n_grams=N_GRAMS):\n    ngram_columns_dict = {} # Collect and concat the new columns to avoid memory fragmentation issues\n    for n in n_grams:\n        for ngram in combinations(cat_columns2ngrams, n):\n            ngram_columns_dict[f'{n}gram_'+'_'.join(ngram)] = df[list(ngram)].astype(str).agg('_'.join, axis=1)\n    ngram_columns_df = pd.DataFrame(ngram_columns_dict)\n    updated_df = pd.concat([df, ngram_columns_df], axis=1)\n    return updated_df\n\ntrainval = create_ngrams(trainval)\nextern_data = create_ngrams(extern_data)\ntest = create_ngrams(test)\n\n# Define categorical features\nngram_cat_columns = trainval.filter(like='gram_').columns.tolist()\ncat_columns = (orig_cat_columns + ngram_cat_columns) if N_GRAMS_EXT else orig_cat_columns\nprint(f'Number of original categorical features: {len(orig_cat_columns)}')\nprint(f'Number of extended categorical features: {len(cat_columns)}')\nprint(f'Columns used for n-gram crossing: {cat_columns2ngrams}')\n\n# Define numerical features\nnum_columns = [col for col in make_column_selector(dtype_include=['float', 'int'])(trainval) if col not in ['id', target]]\nprint(f'Number of original numerical features: {len(orig_num_columns)}')\nprint(f'Number of extended numerical features (incl. handcrafted FE): {len(num_columns)}')","metadata":{"execution":{"iopub.execute_input":"2026-07-02T06:16:51.993568Z","iopub.status.busy":"2026-07-02T06:16:51.993292Z","iopub.status.idle":"2026-07-02T06:16:52.132485Z","shell.execute_reply":"2026-07-02T06:16:52.13174Z"},"tags":[]},"outputs":[],"execution_count":null},{"id":"40af4476","cell_type":"code","source":"## Configure data spliting strategy for k-fold training\n\nSTRAT = True       