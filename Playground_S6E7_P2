= le.transform(train[TARGET].astype(str))\n\nprint(\"X:\", X.shape, \"| X_test:\", X_test.shape)\nprint(\"Class mapping:\", dict(zip(le.classes_, le.transform(le.classes_))))\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-09T17:01:46.290954Z","iopub.execute_input":"2026-07-09T17:01:46.291698Z","iopub.status.idle":"2026-07-09T17:01:48.638983Z","shell.execute_reply.started":"2026-07-09T17:01:46.291671Z","shell.execute_reply":"2026-07-09T17:01:48.63802Z"}},"outputs":[{"name":"stdout","text":"13 features | 7 numeric | 6 categorical\nCategorical: ['diet_type', 'stress_level', 'sleep_quality', 'physical_activity_level', 'smoking_alcohol', 'gender']\nX: (690088, 13) | X_test: (295753, 13)\nClass mapping: {np.str_('at-risk'): np.int64(0), np.str_('fit'): np.int64(1), np.str_('unhealthy'): np.int64(2)}\n","output_type":"stream"}],"execution_count":9},{"id":"97ca016d-873c-4db9-92cc-c502df4fabfd","cell_type":"markdown","source":"## 3 · Cross-validated GPU training\n\nThree gradient-boosting libraries, each configured to use the GPU when available:\n- **XGBoost** — `tree_method=\"hist\", device=\"cuda\"`\n- **LightGBM** — `device=\"gpu\"`\n- **CatBoost** — `task_type=\"GPU\"`, with native categorical-feature support\n\nEach model produces out-of-fold (OOF) predictions for honest validation and\ntest-set predictions averaged across folds.\n","metadata":{}},{"id":"003abd49-28b4-46f2-a7d5-11b9431e95de","cell_type":"code","source":"import xgboost as xgb\nimport lightgbm as lgb\nfrom catboost import CatBoostClassifier, Pool\n\nskf = StratifiedKFold(n_splits=N_SPLITS, shuffle=True, random_state=SEED)\n\nn_classes = len(CLASSES)\noof_xgb = np.zeros((len(X), n_classes))\noof_lgb = np.zeros((len(X), n_classes))\noof_cat = np.zeros((len(X), n_classes))\npred_xgb = np.zeros((len(X_test), n_classes))\npred_lgb = np.zeros((len(X_test), n_classes))\npred_cat = np.zeros((len(X_test), n_classes))\n\ncat_idx = [X.columns.get_loc(c) for c in cat_cols]\n\nfor fold, (tr_idx, va_idx) in enumerate(skf.split(X, y)):\n    print(f\"\\n===== Fold {fold + 1}/{N_SPLITS} =====\")\n    X_tr, X_va = X.iloc[tr_idx], X.iloc[va_idx]\n    y_tr, y_va = y[tr_idx], y[va_idx]\n\n    # ---- XGBoost ----\n    xgb_params = dict(\n        n_estimators=2000,\n        learning_rate=0.03,\n        max_depth=7,\n        subsample=0.8,\n        colsample_bytree=0.8,\n        reg_lambda=2.0,\n        objective=\"multi:softprob\",\n        num_class=n_classes,\n        eval_metric=\"mlogloss\",\n        tree_method=\"hist\",\n        random_state=SEED,\n        early_stopping_rounds=100,\n    )\n    if USE_GPU:\n        xgb_params[\"device\"] = \"cuda\"\n    model_xgb = xgb.XGBClassifier(**xgb_params)\n    model_xgb.fit(X_tr, y_tr, eval_set=[(X_va, y_va)], verbose=False)\n    oof_xgb[va_idx] = model_xgb.predict_proba(X_va)\n    pred_xgb += model_xgb.predict_proba(X_test) / N_SPLITS\n\n    # ---- LightGBM ----\n    lgb_params = dict(\n        n_estimators=3000,\n        learning_rate=0.03,\n        num_leaves=63,\n        subsample=0.8,\n        colsample_bytree=0.8,\n        reg_lambda=2.0,\n        objective=\"multiclass\",\n        num_class=n_classes,\n        random_state=SEED,\n        verbosity=-1,\n    )\n    if USE_GPU:\n        lgb_params[\"device\"] = \"gpu\"\n    model_lgb = lgb.LGBMClassifier(**lgb_params)\n    model_lgb.fit(\n        X_tr, y_tr,\n        eval_set=[(X_va, y_va)],\n        categorical_feature=cat_idx if cat_idx else \"auto\",\n        callbacks=[lgb.early_stopping(100, verbose=False)],\n    )\n    oof_lgb[va_idx] = model_lgb.predict_proba(X_va)\n    pred_lgb += model_lgb.predict_proba(X_test) / N_SPLITS\n\n    # ---- CatBoost ----\n    cat_params = dict(\n        iterations=3000,\n        learning_rate=0.03,\n        depth=8,\n        loss_function=\"MultiClass\",\n        random_seed=SEED,\n        early_stopping_rounds=100,\n        verbose=False,\n        task_type=\"GPU\" if USE_GPU else \"CPU\",\n    )\n    model_cat = CatBoostClassifier(**cat_params)\n    train_pool = Pool(X_tr, y_tr, cat_features=cat_idx)\n    valid_pool = Pool(X_va, y_va, cat_features=cat_idx)\n    model_cat.fit(train_pool, eval_set=valid_pool)\n    oof_cat[va_idx] = model_cat.predict_proba(X_va)\n    pred_cat += model_cat.predict_proba(X_test) / N_SPLITS\n\n    fold_acc = accuracy_score(y_va, oof_xgb[va_idx].argmax(1))\n    print(f\"Fold {fold + 1} XGB acc: {fold_acc:.5f}\")\n\nprint(\"\\nTraining complete.\")\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-09T17:01:48.640194Z","iopub.execute_input":"2026-07-09T17:01:48.640389Z","iopub.status.idle":"2026-07-09T17:14:07.306628Z","shell.execute_reply.started":"2026-07-09T17:01:48.640371Z","shell.execute_reply":"2026-07-09T17:14:07.305742Z"}},"outputs":[{"name":"stdout","text":"\n===== Fold 1/5 =====\nFold 1 XGB acc: 0.96707\n\n===== Fold 2/5 =====\nFold 2 XGB acc: 0.96741\n\n===== Fold 3/5 =====\nFold 3 XGB acc: 0.96715\n\n===== Fold 4/5 =====\nFold 4 XGB acc: 0.96687\n\n===== Fold 5/5 =====\nFold 5 XGB acc: 0.96713\n\nTraining complete.\n","output_type":"stream"}],"execution_count":10},{"id":"3cdf8593-bc1c-4c50-b42f-16c7cc3fd977","cell_type":"markdown","source":"## 4 · Score individual models and find the best blend weights","metadata":{}},{"id":"1fc2a93c-ff3f-4b39-b86d-e145ae42eb4b","cell_type":"code","source":"def report(name, oof_proba):\n    pred = oof_proba.argmax(1)\n    acc = accuracy_score(y, pred)\n    bacc = balanced_accuracy_score(y, pred)\n    f1 = f1_score(y, pred, average=\"macro\")\n    print(f\"{name:10s} | accuracy: {acc:.5f} | balanced_acc: {bacc:.5f} | macro_f1: {f1:.5f}\")\n    return acc\n\nreport(\"XGBoost\", oof_xgb)\nreport(\"LightGBM\", oof_lgb)\nreport(\"CatBoost\", oof_cat)\n\n# Coarse grid search over blend weights (sum to 1) to maximize OOF accuracy.\nbest_acc, best_w = -1, (1/3, 1/3, 1/3)\nstep = 0.05\nweights = np.arange(0, 1 + step, step)\nfor w1 in weights:\n    for w2 in weights:\n        w3 = 1 - w1 - w2\n        if w3 < -1e-9 or w3 > 1 + 1e-9:\n            continue\n        w3 = max(w3, 0)\n        blend = w1 * oof_xgb + w2 * oof_lgb + w3 * oof_cat\n        acc = accuracy_score(y, blend.argmax(1))\n        if acc > best_acc:\n            best_acc, best_w = acc, (w1, w2, w3)\n\nprint(f\"\\nBest OOF blend weights (xgb, lgb, cat) = {best_w} -> accuracy: {best_acc:.5f}\")\n\nblend_oof = best_w[0] * oof_xgb + best_w[1] * oof_lgb + best_w[2] * oof_cat\nreport(\"Blend\", blend_oof)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-07-09T17:14:07.308453Z","iopub.execute_input":"2026-07-09T17:14:07.308762Z","iopub.status.idle":"2026-07-09T17:14:13.801072Z","shell.execute_reply.started":"2026-07-09T17:14:07.308687Z","shell.execute_reply":"2026-07-09T17:14:13.800182Z"}},"outputs":[{"name":"stdout","text":"XGBoost    | accuracy: 0.96713 | balanced_acc: 0.87809 | macro_f1: 0.91066\nLightGBM   | accuracy: 0.96709 | balanced_acc: 0.87736 | macro_f1: 0.91045\nCatBoost   | accuracy: 0.96661 | balanced_acc: 0.87267 | macro_f1: 0.90871\n\nBest OOF blend weights (xgb, lgb, cat) = (np.float64(0.45), np.float64(0.45), np.float64(0.10000000000000003)) -> accuracy: 0.96725\nBlend      | accuracy: 0.96725 | balanced_acc: 0.87727 | macro_f1: 0.91085\n","output_type":"stream"},{"execution_count":11,"output_type":"execute_result","data":{"text/plain":"0.9672476553714888"},"metadata":{}}],"execution_count":11},{"id":"a8f953f1-5ab9-4de4-99a1-e5a4076e019c","cell_type":"markdown","source":"## 5 · Predict on test set and write `submission.csv`","metadata":{}},{"id":"21eb0899-76b7-4f97-83d3-1505f135c03f","cell_type":"code","source":"final_proba = best_w[0] * pred_xgb + best_w[1] * pred_lgb + best_w[2] * pred_cat\nfinal_pred = le.inverse_transform(final_proba.argmax(1))\n\nsubmission = pd.DataFrame({ID: sample_sub[ID].values, TARGET: final_pred})\n\n# Validate before writing.\nassert list(submission.columns) == [ID, TARGET]\nassert len(submission) == len(sample_sub)\nassert submission[ID].